        function TabObj:AddFPSCounter()
            local F = TabObj:AddStatistic("FPS", "0")
            local last = tick()
            local conn = RunService.RenderStepped:Connect(function()
                local n = tick()
                if not F or not WindowObj.Main.Parent then return end
                F:SetValue(math.floor(1 / (n - last)))
                last = n
            end)
            table.insert(DevLib.Connections, conn)
        end

