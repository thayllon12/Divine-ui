        function TabObj:AddToggleGroup(togglesData, callback)
            local F = TabObj:AddFolder("Toggle Group")
            local active = nil
            local btns = {}
            for _, d in ipairs(togglesData) do
                local Btn = Create("TextButton", {
                    Parent = F.Container,
                    BackgroundColor3=theme.ElementBackground,
                    Size=UDim2.new(1,0,0,30),
                    Font=Enum.Font.GothamMedium,
                    Text=d,
                    TextColor3=theme.Text,
                    TextSize=13,
                    AutoButtonColor=false,
                    ZIndex=6
                })
                Create("UICorner", { Parent = Btn, CornerRadius=UDim.new(0,6) })
                Create("UIStroke", { Parent = Btn, Color=theme.StrokeColor, Thickness=1 })
                
                Btn.MouseButton1Click:Connect(function()
                    for _, b in pairs(btns) do
                        b.BackgroundColor3=theme.ElementBackground
                        b.TextColor3=theme.Text
                    end
                    Btn.BackgroundColor3=theme.Accent
                    Btn.TextColor3=Color3.new(1,1,1)
                    active = d
                    if callback then
                        pcall(function() callback(active) end)
                    end
                end)
                table.insert(btns, Btn)
            end
        end
        TabObj.AddButtonGroup = TabObj.AddToggleGroup
        TabObj.AddRadioButton = TabObj.AddToggleGroup

        function TabObj:AddTimeline(events)
            local F = TabObj:AddFolder("Timeline")
            for i, e in ipairs(events) do
                local ev = Create("Frame", {
                    Parent = F.Container,
                    BackgroundTransparency=1,
                    Size=UDim2.new(1,0,0,40),
                    ZIndex=5
                })
                Create("Frame", {
                    Parent = ev,
                    BackgroundColor3=theme.StrokeColor,
                    Size=UDim2.new(0,2,1,0),
                    Position=UDim2.new(0,10,0,0),
                    ZIndex=6
                })
                local Dot = Create("Frame", {
                    Parent = ev,
                    BackgroundColor3=theme.Accent,
                    Size=UDim2.new(0,12,0,12),
                    Position=UDim2.new(0,5,0.5,0),
                    AnchorPoint=Vector2.new(0,0.5),
                    ZIndex=7
                })
                Create("UICorner", { Parent = Dot, CornerRadius=UDim.new(1,0) })
                
                Create("TextLabel", {
                    Parent = ev,
                    BackgroundTransparency=1,
                    Size=UDim2.new(1,-30,1,0),
                    Position=UDim2.new(0,30,0,0),
                    Font=Enum.Font.GothamMedium,
                    Text=e,
                    TextColor3=theme.Text,
                    TextSize=13,
                    TextXAlignment=Enum.TextXAlignment.Left,
                    ZIndex=6
                })
            end
        end

