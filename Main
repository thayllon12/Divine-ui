TextSize = 13,
TextXAlignment = Enum.TextXAlignment.Left,
TextWrapped = true,
RichText = true,
ZIndex = 5
})
local PObj = {}
function PObj:SetDesc(txt) LblDesc.Text = txt end
return PObj
end

