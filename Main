Create("UICorner", {Parent = bBoxC, CornerRadius = UDim.new(0, 4)})

local function updateMini()
tempAccent = Color3.fromHSV(h, s, v)
tpSat.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
rBoxC.Text = tostring(math.floor(tempAccent.R * 255))
gBoxC.Text = tostring(math.floor(tempAccent.G * 255))
bBoxC.Text = tostring(math.floor(tempAccent.B * 255))
miniAccent.BackgroundColor3 = tempAccent
miniTglOn.BackgroundColor3 = tempAccent
end

local dcs, dch = false, false
tpSat.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then dcs = true end end)
tpHue.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then dch = true end end)
UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then dcs = false dch = false end end)
UserInputService.InputChanged:Connect(function(i)
if i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch then
if dcs then
s = math.clamp((i.Position.X - tpSat.AbsolutePosition.X) / tpSat.AbsoluteSize.X, 0, 1)
v = 1 - math.clamp((i.Position.Y - tpSat.AbsolutePosition.Y) / tpSat.AbsoluteSize.Y, 0, 1)
updateMini()
elseif dch then
h = 1 - math.clamp((i.Position.Y - tpHue.AbsolutePosition.Y) / tpHue.AbsoluteSize.Y, 0, 1)
updateMini()
end
end
end)

local function rgbBoxUpdate()
local cr = math.clamp(tonumber(rBoxC.Text) or 255, 0, 255)
local cg = math.clamp(tonumber(gBoxC.Text) or 255, 0, 255)
local cbb = math.clamp(tonumber(bBoxC.Text) or 255, 0, 255)
tempAccent = Color3.fromRGB(cr, cg, cbb)
h, s, v = Color3.toHSV(tempAccent)
updateMini()
end
rBoxC.FocusLost:Connect(rgbBoxUpdate)
gBoxC.FocusLost:Connect(rgbBoxUpdate)
bBoxC.FocusLost:Connect(rgbBoxUpdate)

