    local function CreateTopBtn(iconName, hoverColor)
        local btn = Create("TextButton", { Parent = TopbarControls, BackgroundTransparency = 1, Size = UDim2.new(0, 24, 0, 24), Text = "", ZIndex = 13 })
        local icon = Create("ImageLabel", { Parent = btn, BackgroundTransparency = 1, Size = UDim2.new(0, 16, 0, 16), Position = UDim2.new(0.5,0,0.5,0), AnchorPoint = Vector2.new(0.5,0.5), Image = DevLib:GetIcon(iconName), ImageColor3 = theme.SubText, ZIndex = 13 })
        btn.MouseEnter:Connect(function() Tween(icon, {ImageColor3 = hoverColor or theme.Text}, 0.2) end)
        btn.MouseLeave:Connect(function() Tween(icon, {ImageColor3 = theme.SubText}, 0.2) end)
        return btn, icon
    end

    local BtnMinimize, IconMin = CreateTopBtn("minus", theme.Accent)
