local TranspBg = Create("TextButton", {Parent = SetScroll, BackgroundColor3 = theme.TabBackground, Size = UDim2.new(1, -30, 0, 6), Text = "", ZIndex = 3002})
Create("UICorner", {Parent = TranspBg, CornerRadius = UDim.new(1, 0)})
local initialTransp = useAcrylic and 0.15 or 0
local TranspFill = Create("Frame", {Parent = TranspBg, BackgroundColor3 = theme.Accent, Size = UDim2.new(initialTransp, 0, 1, 0), ZIndex = 3003})
Create("UICorner", {Parent = TranspFill, CornerRadius = UDim.new(1, 0)})
local draggingT = false
TranspBg.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then draggingT = true end end)
UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then draggingT = false end end)
UserInputService.InputChanged:Connect(function(i)
if draggingT and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then
local pct = math.clamp((i.Position.X - TranspBg.AbsolutePosition.X) / TranspBg.AbsoluteSize.X, 0, 1)
TranspFill.Size = UDim2.new(pct, 0, 1, 0)
MainFrame.BackgroundTransparency = pct
end
end)

