    local BtnClose, IconClose = CreateTopBtn("x", theme.Error)

    --=========================================================================
    -- 💻 WINDOW LOGIC METHODS (Minimize, Expand, Destroy, Dialog)
    --=========================================================================
    function WindowObj:Minimize()
        self.IsMinimized = true
        Tween(MainFrame, { Size = UDim2.fromScale(0, 0), BackgroundTransparency = 1 }, 0.5, Enum.EasingStyle.Exponential)
        if useAcrylic and Blur then Tween(Blur, { Size = 0 }, 0.5) end
        self.OnMinimize:Fire()
        task.delay(0.5, function() if self.IsMinimized and MainFrame then MainFrame.Visible = false end end)
    end

    function WindowObj:Maximize()
        self.IsMinimized = false
        MainFrame.Visible = true
        Tween(MainFrame, { Size = self.IsExpanded and UDim2.fromOffset(self.OriginalSize.X.Offset * 1.5, self.OriginalSize.Y.Offset) or self.OriginalSize, BackgroundTransparency = useAcrylic and 0.15 or 0 }, 0.5, Enum.EasingStyle.Exponential)
        if useAcrylic and Blur then Tween(Blur, { Size = 15 }, 0.5) end
        self.OnRestore:Fire()
    end

    function WindowObj:Expand()
        if self.IsExpanded then
            self.IsExpanded = false
            Tween(MainFrame, { Size = self.OriginalSize }, 0.4, Enum.EasingStyle.Exponential)
            self.OnRestore:Fire()
        else
            self.IsExpanded = true
            local expW = math.clamp(self.OriginalSize.X.Offset * 1.5, self.ResizeLimits.MinWidth, self.ResizeLimits.MaxWidth)
            Tween(MainFrame, { Size = UDim2.fromOffset(expW, self.OriginalSize.Y.Offset) }, 0.4, Enum.EasingStyle.Exponential)
            self.OnExpand:Fire()
        end
    end

    function WindowObj:Dialog(dlgOptions)
        if type(dlgOptions) ~= "table" then dlgOptions = {} end
        local title = dlgOptions.Title or "Dialog"
        local content = dlgOptions.Content or "Content"
        local buttons = dlgOptions.Buttons or {}
        
        local DialogBG = Create("Frame", { Parent = ScreenGui, BackgroundColor3 = Color3.new(0, 0, 0), BackgroundTransparency = 1, Size = UDim2.new(1, 0, 1, 0), ZIndex = 9999 })
        Tween(DialogBG, { BackgroundTransparency = 0.5 }, 0.3)
        
        local DialogFrame = Create("Frame", { Parent = DialogBG, BackgroundColor3 = theme.WindowBackground, Size = UDim2.new(0, 340, 0, 180), Position = UDim2.fromScale(0.5, 0.5), AnchorPoint = Vector2.new(0.5, 0.5), ClipsDescendants = true, ZIndex = 10000 })
        Create("UICorner", { Parent = DialogFrame, CornerRadius = UDim.new(0, 10) })
        Create("UIStroke", { Parent = DialogFrame, Color = theme.StrokeColor, Thickness = 1 })
        
        local LblTitle = Create("TextLabel", { Parent = DialogFrame, BackgroundTransparency = 1, Size = UDim2.new(1, -40, 0, 40), Position = UDim2.new(0, 20, 0, 10), Font = Enum.Font.GothamBold, TextColor3 = theme.Text, TextSize = 16, TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 10001 })
        local LblContent = Create("TextLabel", { Parent = DialogFrame, BackgroundTransparency = 1, Size = UDim2.new(1, -40, 1, -110), Position = UDim2.new(0, 20, 0, 50), Font = Enum.Font.Gotham, TextColor3 = theme.SubText, TextSize = 13, TextXAlignment = Enum.TextXAlignment.Left, TextYAlignment = Enum.TextYAlignment.Top, TextWrapped = true, ZIndex = 10001 })
        
        if dlgOptions.TransTitle then RegisterTranslation(LblTitle, dlgOptions.TransTitle) else LblTitle.Text = title end
        if dlgOptions.TransContent then RegisterTranslation(LblContent, dlgOptions.TransContent) else LblContent.Text = content end

        local ButtonContainer = Create("Frame", { Parent = DialogFrame, BackgroundTransparency = 1, Size = UDim2.new(1, -40, 0, 40), Position = UDim2.new(0, 20, 1, -50), ZIndex = 10001 })
        Create("UIListLayout", { Parent = ButtonContainer, FillDirection = Enum.FillDirection.Horizontal, HorizontalAlignment = Enum.HorizontalAlignment.Right, VerticalAlignment = Enum.VerticalAlignment.Center, Padding = UDim.new(0, 10) })
        
        for _, btnData in ipairs(buttons) do
            local Btn = Create("TextButton", { Parent = ButtonContainer, BackgroundColor3 = theme.ElementBackground, Size = UDim2.new(0, 100, 0, 35), Font = Enum.Font.GothamMedium, TextColor3 = theme.Text, TextSize = 13, AutoButtonColor = false, ZIndex = 10002 })
            Create("UICorner", { Parent = Btn, CornerRadius = UDim.new(0, 6) })
            Create("UIStroke", { Parent = Btn, Color = theme.StrokeColor, Thickness = 1 })
            
            if btnData.TransTitle then RegisterTranslation(Btn, btnData.TransTitle) else Btn.Text = btnData.Title or "Btn" end

            Btn.MouseEnter:Connect(function() Tween(Btn, { BackgroundColor3 = theme.ElementHover }, 0.2) end)
            Btn.MouseLeave:Connect(function() Tween(Btn, { BackgroundColor3 = theme.ElementBackground }, 0.2) end)
            Btn.MouseButton1Click:Connect(function()
                Tween(DialogBG, { BackgroundTransparency = 1 }, 0.3)
                Tween(DialogFrame, { Size = UDim2.new(0, 0, 0, 0) }, 0.3)
                task.delay(0.3, function() if DialogBG then DialogBG:Destroy() end end)
                if btnData.Callback then btnData.Callback() end
            end)
        end
        DialogFrame.Size = UDim2.new(0, 0, 0, 0)
        Tween(DialogFrame, { Size = UDim2.new(0, 340, 0, 180) }, 0.4, Enum.EasingStyle.Back)
    end

    function WindowObj:Destroy()
        self.OnDestroy:Fire()
        self.OnResize:DisconnectAll(); self.OnExpand:DisconnectAll(); self.OnRestore:DisconnectAll(); self.OnMinimize:DisconnectAll(); self.OnDestroy:DisconnectAll()
        for _, conn in ipairs(DevLib.Connections) do if conn then pcall(function() conn:Disconnect() end) end end
        for _, inst in ipairs(DevLib.Instances) do if inst then pcall(function() inst:Destroy() end) end end
        DevLib.Connections = {}
        DevLib.Instances = {}
        if DevLib.NotificationGui then pcall(function() DevLib.NotificationGui:Destroy() end) end
        if self.Gui then pcall(function() self.Gui:Destroy() end) end
    end

    BtnMinimize.MouseButton1Click:Connect(function() WindowObj:Minimize() end)
    BtnExpand.MouseButton1Click:Connect(function() WindowObj:Expand() end)
    BtnClose.MouseButton1Click:Connect(function()
        WindowObj:Dialog({
            TransTitle = "ConfirmClose",
            TransContent = "ConfirmCloseDesc",
            Buttons = {
                { TransTitle = "Cancel", Callback = function() end },
                { TransTitle = "OK", Callback = function() WindowObj:Destroy() end }
            }
        })
    end)

