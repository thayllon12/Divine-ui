-- [ INÍCIO DO CÓDIGO BLINDADO DA GUI ] --
local GUI_TARGET = nil
pcall(function()
    local target = (gethui and gethui()) or game:GetService("CoreGui")
    local test = Instance.new("ScreenGui")
    test.Parent = target
    test:Destroy()
    GUI_TARGET = target
end)

if not GUI_TARGET then
    GUI_TARGET = game:GetService("Players").LocalPlayer:WaitForChild("PlayerGui")
end
