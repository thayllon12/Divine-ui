        function TabObj:AddPlayerCard(player)
            local Card = Create("Frame", { Parent = TabContainer, BackgroundColor3 = theme.ElementBackground, Size = UDim2.new(1, 0, 0, 80), ZIndex=4 }, { Create("UICorner", { CornerRadius=UDim.new(0,6) }), Create("UIStroke", { Color=theme.StrokeColor, Thickness=1 }) })
