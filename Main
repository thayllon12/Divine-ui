--=============================================================================================================================
-- [2] 🔐 BASE64 ENCRYPTION MODULE (For Safe Config Saving)
--=============================================================================================================================
local Base64 = {}
local b64chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/'
function Base64.encode(data)
    return ((data:gsub('.', function(x) 
        local r, b = '', x:byte()
        for i = 8, 1, -1 do r = r .. (b % 2^i - b % 2^(i-1) > 0 and '1' or '0') end
        return r;
    end) .. '0000'):gsub('%d%d%d?%d?%d?%d?', function(x)
        if (#x < 6) then return '' end
        local c = 0
        for i = 1, 6 do c = c + (x:sub(i,i) == '1' and 2^(6-i) or 0) end
        return b64chars:sub(c+1, c+1)
    end) .. ({ '', '==', '=' })[#data%3+1])
end

function Base64.decode(data)
    data = string.gsub(data, '[^'..b64chars..'=]', '')
    return (data:gsub('.', function(x)
        if (x == '=') then return '' end
        local r, f = '', (b64chars:find(x)-1)
        for i = 6, 1, -1 do r = r .. (f % 2^i - f % 2^(i-1) > 0 and '1' or '0') end
        return r;
    end):gsub('%d%d%d?%d?%d?%d?%d?%d?', function(x)
        if (#x ~= 8) then return '' end
        local c = 0
        for i = 1, 8 do c = c + (x:sub(i,i) == '1' and 2^(8-i) or 0) end
        return string.char(c)
    end))
end

--=============================================================================================================================
-- [3] 📡 SIGNAL/EVENTS MODULE
--=============================================================================================================================
local Signal = {}
Signal.__index = Signal
function Signal.new()
    local self = setmetatable({}, Signal)
    self._binds = {}
    return self
end
function Signal:Connect(callback)
    if type(callback) ~= "function" then error("Callback must be a function") end
    local connection = {
        _callback = callback,
        _disconnected = false,
        Disconnect = function(conn)
            conn._disconnected = true
            for i, v in ipairs(self._binds) do
                if v == conn then
                    table.remove(self._binds, i)
                    break
                end
            end
        end
    }
    table.insert(self._binds, connection)
    return connection
end
function Signal:Fire(...)
    for _, conn in ipairs(self._binds) do
        if not conn._disconnected then
            task.spawn(conn._callback, ...)
        end
    end
end
function Signal:DisconnectAll()
    for _, conn in ipairs(self._binds) do
        conn._disconnected = true
    end
    self._binds = {}
end

