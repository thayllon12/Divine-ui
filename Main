        function TabObj:AddMusicPlayer(soundId)
            local S = Create("Sound", { Parent = CoreGui, SoundId = soundId, Looped = true })
            local F = Create("Frame", {
                Parent = TabContainer,
                BackgroundColor3=theme.ElementBackground,
                Size=UDim2.new(1, 0, 0, 70),
                ZIndex=4
            })
            Create("UICorner", { Parent = F, CornerRadius=UDim.new(0,6) })
            Create("UIStroke", { Parent = F, Color=theme.StrokeColor, Thickness=1 })
            
            local B = Create("TextButton", {
                Parent = F,
                BackgroundColor3=theme.Accent,
                Size=UDim2.new(0,40,0,40),
                Position=UDim2.new(0,15,0,15),
                Font=Enum.Font.GothamBold,
                Text="▶",
                TextColor3=Color3.new(1,1,1),
                TextSize=18,
                ZIndex=5
            })
            Create("UICorner", { Parent = B, CornerRadius=UDim.new(0,6) })
            
            local playing = false
            B.MouseButton1Click:Connect(function()
                playing = not playing
                if playing then
                    S:Play()
                    B.Text="⏸"
                else
                    S:Pause()
                    B.Text="▶"
                end
            end)
            
            Create("TextLabel", {
                Parent = F,
                BackgroundTransparency=1,
                Size=UDim2.new(1,-80,0,20),
                Position=UDim2.new(0,70,0,15),
                Font=Enum.Font.GothamMedium,
                Text="Audio Track",
                TextColor3=theme.Text,
                TextSize=14,
                TextXAlignment=Enum.TextXAlignment.Left,
                ZIndex=5
            })
            
            local BarBG = Create("Frame", {
                Parent = F,
                BackgroundColor3=theme.TabBackground,
                Size=UDim2.new(1,-80,0,6),
                Position=UDim2.new(0,70,0,45),
                ZIndex=5
            })
            Create("UICorner", { Parent = BarBG, CornerRadius=UDim.new(1,0) })
            
            local Bar = Create("Frame", {
                Parent = BarBG,
                BackgroundColor3=theme.Accent,
                Size=UDim2.new(0,0,1,0),
                ZIndex=6
            })
            Create("UICorner", { Parent = Bar, CornerRadius=UDim.new(1,0) })
            
            task.spawn(function()
                while F and F.Parent do
                    if playing and S.TimeLength > 0 then
                        Tween(Bar, {Size=UDim2.new(S.TimePosition / S.TimeLength, 0, 1, 0)}, 0.1)
                    end
                    task.wait(0.1)
                end
            end)
            return { Destroy = function() S:Destroy() end }
        end
        TabObj.AddAudioPlayer = TabObj.AddMusicPlayer

        function TabObj:AddSearchBar(callback)
            TabObj:AddInput({Title = "Search Elements", Placeholder = "Type to filter...", Callback = function(txt)
                for _, child in pairs(TabContainer:GetChildren()) do
                    if child:IsA("Frame") or child:IsA("TextButton") then
                        local lbl = child:FindFirstChildWhichIsA("TextLabel", true)
                        if lbl then
                            if txt == "" or string.find(string.lower(lbl.Text), string.lower(txt)) then
                                child.Visible = true
                            else
                                child.Visible = false
                            end
                        end
                    end
                end
                if callback then pcall(function() callback(txt) end) end
            end})
        end
        TabObj.AddAutoComplete = TabObj.AddSearchBar

        function TabObj:AddDatePicker() TabObj:AddInput({Title = "Date Picker (DD/MM/YYYY)"}) end
        TabObj.AddTimePicker = TabObj.AddDatePicker
        TabObj.AddCalendar = TabObj.AddDatePicker

        function TabObj:AddPlayerDropdown(id, cb)
            local plrs = {}
            for _, p in pairs(Players:GetPlayers()) do table.insert(plrs, p.Name) end
            local dd = TabObj:AddDropdown(id, {Title = "Select Player", Values = plrs, Callback = cb})
            local c1 = Players.PlayerAdded:Connect(function(p)
                table.insert(plrs, p.Name)
                dd:Refresh(plrs)
            end)
            local c2 = Players.PlayerRemoving:Connect(function(p)
                for i,v in pairs(plrs) do
                    if v==p.Name then
                        table.remove(plrs,i)
                        break
                    end
                end
                dd:Refresh(plrs)
            end)
            table.insert(DevLib.Connections, c1)
            table.insert(DevLib.Connections, c2)
            return dd
        end

        function TabObj:AddServerDropdown() TabObj:AddDropdown({Title = "Server List", Values = {"Server #1 [US]", "Server #2 [EU]"}}) end
        function TabObj:AddTeamDropdown() TabObj:AddDropdown({Title = "Team Selector", Values = {"Red", "Blue", "Green", "Yellow"}}) end

        function TabObj:AddTeleportButton(placeId) TabObj:AddButton({Title = "Teleport to Game", Description = "ID: " .. tostring(placeId), Callback = function() TeleportService:Teleport(placeId, LocalPlayer) end}) end

