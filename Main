DevLib.Themes = GenerateThemes()
DevLib.Themes["Custom"] = DevLib.Themes["DEV"]
DevLib.CurrentTheme = "DEV"
function DevLib:GetTheme()
return DevLib.Themes[DevLib.CurrentTheme]
end
local function Create(className, properties, children)
local instance = Instance.new(className)
if type(properties) == "table" then
for property, value in pairs(properties) do
pcall(function()
instance[property] = value
end)
end
end
if type(children) == "table" then
for _, child in pairs(children) do
if typeof(child) == "Instance" then
child.Parent = instance
end
end
end
table.insert(DevLib.Instances, instance)
return instance
end
local function Tween(instance, properties, duration, style, direction)
if typeof(instance) ~= "Instance" or not instance.Parent then return end
duration = duration or 0.3
style = style or Enum.EasingStyle.Quad
direction = direction or Enum.EasingDirection.Out
local tweenInfo = TweenInfo.new(duration, style, direction)
local success, tween = pcall(function()
return TweenService:Create(instance, tweenInfo, properties)
end)
if success and tween then
tween:Play()
return tween
end
return nil
end
local function MakeDraggable(dragPart, targetPart)
local dragging = false
local dragInput, mousePos, framePos
local dragStartConn, dragChangeConn, inputChangeConn
dragStartConn = dragPart.InputBegan:Connect(function(input)
if DevLib.IsResizing then return end
if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
dragging = true
mousePos = input.Position
framePos = targetPart.Position
local releaseConn
releaseConn = input.Changed:Connect(function()
if input.UserInputState == Enum.UserInputState.End then
dragging = false
if releaseConn then
releaseConn:Disconnect()
releaseConn = nil
end
end
end)
end
end)
dragChangeConn = dragPart.InputChanged:Connect(function(input)
if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
dragInput = input
end
end)
inputChangeConn = UserInputService.InputChanged:Connect(function(input)
if input == dragInput and dragging then
local delta = input.Position - mousePos
targetPart.Position = UDim2.new(
framePos.X.Scale,
framePos.X.Offset + delta.X,
framePos.Y.Scale,
framePos.Y.Offset + delta.Y
)
end
end)
table.insert(DevLib.Connections, dragStartConn)
table.insert(DevLib.Connections, dragChangeConn)
table.insert(DevLib.Connections, inputChangeConn)
end
local function getId(id, options)
if type(id) == "table" then
options = id
id = options.Id or options.Title or ("DevAuto_" .. tostring(math.random(100000, 999999)))
end
if type(options) ~= "table" then
options = {}
end
return id, options
end
function DevLib:GetIcon(name)
if type(name) ~= "string" or name == "" then return "" end
if string.find(name, "rbxassetid") then return name end
if DevLib.Icons["lucide-" .. name] then return DevLib.Icons["lucide-" .. name] end
if DevLib.Icons[name] then return DevLib.Icons[name] end
return ""
end
function DevLib:SetTheme(name)
if DevLib.Themes[name] then
DevLib.CurrentTheme = name
end
end
function DevLib:ApplyTheme(newThemeTable)
local oldTheme = DevLib:GetTheme()
for _, inst in ipairs(DevLib.Instances) do
pcall(function()
if inst:IsA("GuiObject") then
for k, color in pairs(oldTheme) do
if inst.BackgroundColor3 == color then inst.BackgroundColor3 = newThemeTable[k] end
if inst.BorderColor3 == color then inst.BorderColor3 = newThemeTable[k] end
if inst:IsA("TextLabel") or inst:IsA("TextButton") or inst:IsA("TextBox") then
if inst.TextColor3 == color then inst.TextColor3 = newThemeTable[k] end
end
if inst:IsA("ImageLabel") or inst:IsA("ImageButton") then
if inst.ImageColor3 == color then inst.ImageColor3 = newThemeTable[k] end
end
if inst:IsA("UIStroke") then
if inst.Color == color then inst.Color = newThemeTable[k] end
end
end
end
end)
end
for k, v in pairs(newThemeTable) do
DevLib.Themes["Custom"][k] = v
end
DevLib.CurrentTheme = "Custom"
end
function DevLib:SendWebhook(url, embedData)
if not RequestFunc then return end
local data = {
username = "DevLib System",
avatar_url = "https://i.imgur.com/3Z6KxH7.png",
embeds = {embedData}
}
pcall(function()
RequestFunc({
Url = url,
Method = "POST",
Headers = {["Content-Type"] = "application/json"},
Body = HttpService:JSONEncode(data)
})
end)
end
function DevLib:SaveConfig(customName)
local name = customName or DevLib.SaveName
if writefile then
local success, encoded = pcall(HttpService.JSONEncode, HttpService, DevLib.Flags)
if success then
writefile(name .. ".json", encoded)
end
end
end
function DevLib:LoadConfig(customName)
local name = customName or DevLib.SaveName
if readfile and isfile and isfile(name .. ".json") then
local success, decoded = pcall(HttpService.JSONDecode, HttpService, readfile(name .. ".json"))
if success then
for key, value in pairs(decoded) do
if DevLib.Options[key] and type(DevLib.Options[key].SetValue) == "function" then
pcall(function()
DevLib.Options[key]:SetValue(value)
end)
end
end
end
end
end
