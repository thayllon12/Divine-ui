local function applyProps(inst, props)
for k, v in pairs(props) do
if k == "BackgroundColor" then inst.BackgroundColor3 = v
elseif k == "TextColor" then inst.TextColor3 = v
elseif k == "ImageColor" then inst.ImageColor3 = v
else pcall(function() inst[k] = v end) end
end
end
function WindowObj:AddMinimizeButton(options)
if type(options) ~= "table" then options = {} end
local text = options.Text or "DEV"
local size = options.Size or UDim2.fromOffset(40, 40)
local pos = options.Position or UDim2.new(1, -60, 1, -60)
local anchor = options.AnchorPoint or Vector2.new(0, 0)
local visible = options.Visible == nil and true or options.Visible
local draggable = options.Draggable == nil and true or options.Draggable
local bgColor = options.BackgroundColor or options.Color or theme.ElementBackground
local bgTrans = options.BackgroundTransparency or options.Transparency or 0
local txtColor = options.TextColor or theme.Text
local txtTrans = options.TextTransparency or 0
local font = options.Font or Enum.Font.GothamBold
local txtSize = options.TextSize or 14
local image = options.Image or ""
local imgColor = options.ImageColor or Color3.new(1,1,1)
local imgTrans = options.ImageTransparency or 0
local radius = options.CornerRadius or 8
local strokeColor = options.StrokeColor or theme.StrokeColor
local strokeThick = options.StrokeThickness or 1
local strokeTrans = options.StrokeTransparency or 0
local MinGui = Create("ScreenGui", {Parent = GUI_TARGET, ResetOnSpawn = false})
table.insert(DevLib.Instances, MinGui)
local btn = Create("TextButton", {
Parent = MinGui, Size = size, Position = pos, AnchorPoint = anchor,
BackgroundColor3 = bgColor, BackgroundTransparency = bgTrans,
Text = image == "" and text or "", TextColor3 = txtColor, TextTransparency = txtTrans,
Font = font, TextSize = txtSize, Visible = visible, AutoButtonColor = false,
ClipsDescendants = true
})
Create("UICorner", {Parent = btn, CornerRadius = UDim.new(0, radius)})
Create("UIStroke", {Parent = btn, Color = strokeColor, Thickness = strokeThick, Transparency = strokeTrans})
if image ~= "" then
Create("ImageLabel", {
Parent = btn, BackgroundTransparency = 1, Size = UDim2.fromScale(0.6, 0.6),
Position = UDim2.fromScale(0.5, 0.5), AnchorPoint = Vector2.new(0.5, 0.5),
Image = image, ImageColor3 = imgColor, ImageTransparency = imgTrans
})
end
if draggable then MakeDraggable(btn, btn) end
local lastClick = 0
btn.MouseButton1Click:Connect(function()
local now = tick()
if now - lastClick < 0.3 then
local vSize = workspace.CurrentCamera and workspace.CurrentCamera.ViewportSize or Vector2.new(1920, 1080)
local nX = (vSize.X - MainFrame.Size.X.Offset) / 2
local nY = (vSize.Y - MainFrame.Size.Y.Offset) / 2
Tween(MainFrame, {Position = UDim2.new(0, nX, 0, nY)}, 0.3, Enum.EasingStyle.Exponential)
else
MainFrame.Visible = not MainFrame.Visible
if useAcrylic and Blur then
Tween(Blur, {Size = MainFrame.Visible and 15 or 0}, 0.3)
end
end
lastClick = now
end)
end
function WindowObj:Destroy()
for _, conn in ipairs(DevLib.Connections) do
if conn then
pcall(function() conn:Disconnect() end)
end
end
for _, inst in ipairs(DevLib.Instances) do
if inst then
pcall(function() inst:Destroy() end)
end
end
DevLib.Connections = {}
DevLib.Instances = {}
if DevLib.NotificationGui then
pcall(function() DevLib.NotificationGui:Destroy() end)
end
if self.Gui then
pcall(function() self.Gui:Destroy() end)
end
end
