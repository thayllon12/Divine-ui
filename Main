        function TabObj:AddPlayerDropdown(id, cb)
            local plrs = {}
            for _, p in pairs(Players:GetPlayers()) do table.insert(plrs, p.Name) end
            local dd = TabObj:AddDropdown(id, {Title = "Select Player", Values = plrs, Callback = cb})
            local c1 = Players.PlayerAdded:Connect(function(p) table.insert(plrs, p.Name) dd:Refresh(plrs) end)
            local c2 = Players.PlayerRemoving:Connect(function(p) for i,v in pairs(plrs) do if v==p.Name then table.remove(plrs,i) break end end dd:Refresh(plrs) end)
            table.insert(DevLib.Connections, c1) table.insert(DevLib.Connections, c2)
            return dd
        end

