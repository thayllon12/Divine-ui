        function TabObj:AddCommandBar(callback)
            local Inp = Create("TextBox", { Parent = TabContainer, BackgroundColor3=theme.ElementBackground, Size=UDim2.new(1,0,0,40), Font=Enum.Font.Code, PlaceholderText="> command", Text="", TextColor3=theme.Accent, TextSize=14, ClearTextOnFocus=false }, { Create("UICorner", { CornerRadius=UDim.new(0,6) }) })
            Inp.FocusLost:Connect(function(enter) if enter and callback then callback(Inp.Text) Inp.Text="" end end)
        end

        function TabObj:AddMiniWindow(title)
            local W = Create("Frame", { Parent = ScreenGui, BackgroundColor3=theme.WindowBackground, Size=UDim2.new(0,300,0,200), Position=UDim2.new(0.5,0,0.5,0) }, { Create("UICorner", { CornerRadius=UDim.new(0,8) }), Create("UIStroke", { Color=theme.StrokeColor, Thickness=1 }) })
            MakeDraggable(W, W)
            local T = Create("TextLabel", { Parent = W, BackgroundColor3=theme.MainBackground, Size=UDim2.new(1,0,0,30), Font=Enum.Font.GothamBold, Text="  " .. title, TextColor3=theme.Text, TextSize=14, TextXAlignment=Enum.TextXAlignment.Left }, { Create("UICorner", { CornerRadius=UDim.new(0,8) }) })
            local C = Create("Frame", { Parent = W, BackgroundTransparency=1, Size=UDim2.new(1,0,1,-30), Position=UDim2.new(0,0,0,30) })
            return { Container = C, Destroy = function() W:Destroy() end }
        end

