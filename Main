        function TabObj:AddTerminal()
            local TermFrame = Create("Frame", { Parent = TabContainer, BackgroundColor3 = Color3.fromRGB(10,10,10), Size = UDim2.new(1, 0, 0, 200), ClipsDescendants = true }, { Create("UICorner", { CornerRadius = UDim.new(0,6) }), Create("UIStroke", { Color = theme.StrokeColor, Thickness = 1 }) })
            local Scroll = Create("ScrollingFrame", { Parent = TermFrame, BackgroundTransparency = 1, Size = UDim2.new(1,-10,1,-10), Position = UDim2.new(0,5,0,5), CanvasSize = UDim2.new(0,0,0,0), AutomaticCanvasSize = Enum.AutomaticSize.Y, ScrollBarThickness = 2 }, { Create("UIListLayout", { Padding = UDim.new(0,2) }) })
            local obj = {}
            function obj:Log(text, color)
                Create("TextLabel", { Parent = Scroll, BackgroundTransparency = 1, Size = UDim2.new(1,0,0,16), Font = Enum.Font.Code, Text = "> " .. tostring(text), TextColor3 = color or Color3.new(0,1,0), TextSize = 13, TextXAlignment = Enum.TextXAlignment.Left, RichText = true })
                Scroll.CanvasPosition = Vector2.new(0, Scroll.AbsoluteWindowSize.Y + 9999)
            end
            return obj
        end

        function TabObj:AddConsole(callback)
            local ConFrame = Create("Frame", { Parent = TabContainer, BackgroundColor3 = Color3.fromRGB(10,10,10), Size = UDim2.new(1, 0, 0, 230), ClipsDescendants = true }, { Create("UICorner", { CornerRadius = UDim.new(0,6) }), Create("UIStroke", { Color = theme.StrokeColor, Thickness = 1 }) })
            local Scroll = Create("ScrollingFrame", { Parent = ConFrame, BackgroundTransparency = 1, Size = UDim2.new(1,-10,1,-40), Position = UDim2.new(0,5,0,5), CanvasSize = UDim2.new(0,0,0,0), AutomaticCanvasSize = Enum.AutomaticSize.Y, ScrollBarThickness = 2 }, { Create("UIListLayout", { Padding = UDim.new(0,2) }) })
            local Input = Create("TextBox", { Parent = ConFrame, BackgroundColor3 = theme.ElementBackground, Size = UDim2.new(1,-10,0,30), Position = UDim2.new(0,5,1,-35), Font = Enum.Font.Code, Text = "", TextColor3 = theme.Text, TextSize = 13, PlaceholderText = "Enter command...", ClearTextOnFocus = false }, { Create("UICorner", { CornerRadius = UDim.new(0,4) }), Create("UIStroke", { Color = theme.StrokeColor, Thickness = 1 }) })
            Input.FocusLost:Connect(function(enter)
                if enter and Input.Text ~= "" then
                    local cmd = Input.Text
                    Create("TextLabel", { Parent = Scroll, BackgroundTransparency = 1, Size = UDim2.new(1,0,0,16), Font = Enum.Font.Code, Text = "$ <font color='rgb(0,255,255)'>" .. cmd .. "</font>", RichText = true, TextColor3 = Color3.new(1,1,1), TextSize = 13, TextXAlignment = Enum.TextXAlignment.Left })
                    Input.Text = ""
                    if callback then callback(cmd) end
                    Scroll.CanvasPosition = Vector2.new(0, Scroll.AbsoluteWindowSize.Y + 9999)
                end
            end)
            local obj = {}
            function obj:Print(t) Create("TextLabel", { Parent = Scroll, BackgroundTransparency = 1, Size = UDim2.new(1,0,0,16), Font = Enum.Font.Code, Text = tostring(t), TextColor3 = Color3.new(0.8,0.8,0.8), TextSize = 13, TextXAlignment = Enum.TextXAlignment.Left }) Scroll.CanvasPosition = Vector2.new(0, 9999) end
            return obj
        end

        function TabObj:AddCodeBlock(codeStr)
