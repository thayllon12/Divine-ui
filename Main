function TabObj:AddSlider(id, options)
id, options = getId(id, options)
local title = options.Title or "Slider"
local desc = options.Description or ""
local min = options.Min or 0
local max = options.Max or 100
local val = options.Default or 0
local rounding = options.Rounding or 0
local cb = options.Callback or function() end
local SldFrame = Create("Frame", {
Parent = TabContainer,
BackgroundColor3 = theme.ElementBackground,
Size = UDim2.new(1, 0, 0, desc == "" and 65 or 80),
ZIndex = 4
})
Create("UICorner", {Parent = SldFrame, CornerRadius = UDim.new(0, 6)})
Create("UIStroke", {Parent = SldFrame, Color = theme.StrokeColor, Thickness = 1})
Create("TextLabel", {
Parent = SldFrame,
BackgroundTransparency = 1,
Size = UDim2.new(1, -80, 0, 20),
Position = UDim2.new(0, 15, 0, 10),
Font = Enum.Font.GothamMedium,
Text = title,
TextColor3 = theme.Text,
TextSize = 14,
TextXAlignment = Enum.TextXAlignment.Left,
ZIndex = 5
})
local ValLbl = Create("TextLabel", {
Parent = SldFrame,
BackgroundTransparency = 1,
Size = UDim2.new(0, 50, 0, 20),
Position = UDim2.new(1, -65, 0, 10),
Font = Enum.Font.GothamBold,
Text = tostring(val),
TextColor3 = theme.SubText,
TextSize = 14,
TextXAlignment = Enum.TextXAlignment.Right,
ZIndex = 5
})
local DescLbl
if desc ~= "" then
DescLbl = Create("TextLabel", {
Parent = SldFrame,
BackgroundTransparency = 1,
Size = UDim2.new(1, -80, 0, 15),
Position = UDim2.new(0, 15, 0, 28),
Font = Enum.Font.Gotham,
Text = desc,
TextColor3 = theme.SubText,
TextSize = 12,
TextXAlignment = Enum.TextXAlignment.Left,
ZIndex = 5
})
end
local SliderBg = Create("TextButton", {
Parent = SldFrame,
BackgroundColor3 = theme.TabBackground,
Size = UDim2.new(1, -30, 0, 6),
Position = UDim2.new(0, 15, 1, -15),
Text = "",
AutoButtonColor = false,
ZIndex = 5
})
Create("UICorner", {Parent = SliderBg, CornerRadius = UDim.new(1, 0)})
Create("UIStroke", {Parent = SliderBg, Color = theme.StrokeColor, Thickness = 1})
local SliderFill = Create("Frame", {
Parent = SliderBg,
BackgroundColor3 = theme.Accent,
Size = UDim2.new((val - min) / (max - min), 0, 1, 0),
ZIndex = 6
})
Create("UICorner", {Parent = SliderFill, CornerRadius = UDim.new(1, 0)})
local SliderCirc = Create("Frame", {
Parent = SliderFill,
BackgroundColor3 = Color3.fromRGB(255, 255, 255),
Size = UDim2.new(0, 12, 0, 12),
Position = UDim2.new(1, -6, 0.5, 0),
AnchorPoint = Vector2.new(0, 0.5),
ZIndex = 7
})
Create("UICorner", {Parent = SliderCirc, CornerRadius = UDim.new(1, 0)})
local SldObj = {Value = val}
local changeCb = cb
function SldObj:SetValue(v)
val = math.clamp(math.round(v * (10 ^ rounding)) / (10 ^ rounding), min, max)
self.Value = val
DevLib.Flags[id] = val
ValLbl.Text = tostring(val)
Tween(SliderFill, {Size = UDim2.new((val - min) / (max - min), 0, 1, 0)}, 0.1)
if changeCb then
pcall(function() changeCb(val) end)
end
end
function SldObj:OnChanged(newCb)
changeCb = newCb
end
function SldObj:SetDesc(txt) if DescLbl then DescLbl.Text = txt end end
local dragging = false
local function update(input)
local sizeX = SliderBg.AbsoluteSize.X
local posX = SliderBg.AbsolutePosition.X
local pct = math.clamp((input.Position.X - posX) / sizeX, 0, 1)
SldObj:SetValue(min + ((max - min) * pct))
end
local hc1 = SliderBg.InputBegan:Connect(function(i)
if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
dragging = true
Tween(SliderCirc, {Size = UDim2.new(0, 16, 0, 16)}, 0.2)
update(i)
end
end)
local hc2 = UserInputService.InputEnded:Connect(function(i)
if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
dragging = false
Tween(SliderCirc, {Size = UDim2.new(0, 12, 0, 12)}, 0.2)
end
end)
local hc3 = UserInputService.InputChanged:Connect(function(i)
if dragging and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then
update(i)
end
end)
table.insert(DevLib.Connections, hc1)
table.insert(DevLib.Connections, hc2)
table.insert(DevLib.Connections, hc3)
DevLib.Flags[id] = val
DevLib.Options[id] = SldObj
return SldObj
end

function TabObj:AddDropdown(id, options)
id, options = getId(id, options)
local title = options.Title or "Dropdown"
local desc = options.Description or ""
local values = options.Values or {}
local multi = options.Multi or false
local default = options.Default
local selected = multi and (type(default) == "table" and default or {}) or default
local cb = options.Callback or function() end
local isOpen = false
local DdFrame = Create("Frame", {
Parent = TabContainer,
BackgroundColor3 = theme.ElementBackground,
Size = UDim2.new(1, 0, 0, desc == "" and 42 or 55),
ClipsDescendants = true,
ZIndex = 4
})
Create("UICorner", {Parent = DdFrame, CornerRadius = UDim.new(0, 6)})
Create("UIStroke", {Parent = DdFrame, Color = theme.StrokeColor, Thickness = 1})
local DdBtn = Create("TextButton", {
Parent = DdFrame,
BackgroundTransparency = 1,
Size = UDim2.new(1, 0, 0, desc == "" and 42 or 55),
Text = "",
ZIndex = 5
})
Create("TextLabel", {
Parent = DdBtn,
BackgroundTransparency = 1,
Size = UDim2.new(1, -120, 0, 20),
Position = UDim2.new(0, 15, 0, desc == "" and 11 or 8),
Font = Enum.Font.GothamMedium,
Text = title,
TextColor3 = theme.Text,
TextSize = 14,
TextXAlignment = Enum.TextXAlignment.Left,
ZIndex = 6
})
local SelLbl = Create("TextLabel", {
Parent = DdBtn,
BackgroundTransparency = 1,
Size = UDim2.new(0, 100, 0, 20),
Position = UDim2.new(1, -135, 0, desc == "" and 11 or 8),
Font = Enum.Font.Gotham,
Text = "None",
TextColor3 = theme.SubText,
TextSize = 13,
TextXAlignment = Enum.TextXAlignment.Right,
ZIndex = 6
})
local DropIcon = Create("ImageLabel", {
Parent = DdBtn,
BackgroundTransparency = 1,
Size = UDim2.new(0, 16, 0, 16),
Position = UDim2.new(1, -25, 0.5, 0),
AnchorPoint = Vector2.new(0, 0.5),
Image = DevLib:GetIcon("chevron-down") ~= "" and DevLib:GetIcon("chevron-down") or "rbxassetid://10709790948",
ImageColor3 = theme.SubText,
ZIndex = 6
})
local DescLbl
if desc ~= "" then
DescLbl = Create("TextLabel", {
Parent = DdBtn,
BackgroundTransparency = 1,
Size = UDim2.new(1, -120, 0, 15),
Position = UDim2.new(0, 15, 0, 28),
Font = Enum.Font.Gotham,
Text = desc,
TextColor3 = theme.SubText,
TextSize = 12,
TextXAlignment = Enum.TextXAlignment.Left,
ZIndex = 6
})
end
local ListScroll = Create("ScrollingFrame", {
Parent = DdFrame,
BackgroundTransparency = 1,
Size = UDim2.new(1, -10, 0, 120),
Position = UDim2.new(0, 5, 0, desc == "" and 47 or 60),
ScrollBarThickness = 2,
CanvasSize = UDim2.new(0, 0, 0, 0),
AutomaticCanvasSize = Enum.AutomaticSize.Y,
ZIndex = 6
})
Create("UIListLayout", {Parent = ListScroll, Padding = UDim.new(0, 4)})
local DdObj = {Value = selected}
local changeCb = cb
local function upVis()
if multi then
local arr = {}
for k, v in pairs(selected) do
if v then table.insert(arr, k) end
end
SelLbl.Text = #arr > 0 and table.concat(arr, ", ") or "None"
else
SelLbl.Text = tostring(selected or "None")
end
DdObj.Value = selected
DevLib.Flags[id] = selected
if changeCb then
pcall(function() changeCb(selected) end)
end
end
function DdObj:Refresh(newVals)
values = newVals
for _, c in pairs(ListScroll:GetChildren()) do
if c:IsA("TextButton") then
c:Destroy()
end
end
for _, v in ipairs(values) do
local isSel = multi and selected[v] or (not multi and selected == v)
local btn = Create("TextButton", {
Parent = ListScroll,
BackgroundColor3 = isSel and theme.Accent or theme.TabBackground,
Size = UDim2.new(1, -10, 0, 30),
Text = "",
AutoButtonColor = false,
ZIndex = 7
})
Create("UICorner", {Parent = btn, CornerRadius = UDim.new(0, 4)})
local btnLbl = Create("TextLabel", {
Parent = btn,
BackgroundTransparency = 1,
Size = UDim2.new(1, -20, 1, 0),
Position = UDim2.new(0, 10, 0, 0),
Font = Enum.Font.Gotham,
Text = tostring(v),
TextColor3 = isSel and Color3.new(1, 1, 1) or theme.Text,
TextSize = 13,
TextXAlignment = Enum.TextXAlignment.Left,
ZIndex = 8
})
btn.MouseButton1Click:Connect(function()
if multi then
selected[v] = not selected[v]
btn.BackgroundColor3 = selected[v] and theme.Accent or theme.TabBackground
btnLbl.TextColor3 = selected[v] and Color3.new(1, 1, 1) or theme.Text
else
selected = v
for _, c in pairs(ListScroll:GetChildren()) do
if c:IsA("TextButton") then
c.BackgroundColor3 = theme.TabBackground
local l = c:FindFirstChildWhichIsA("TextLabel")
if l then l.TextColor3 = theme.Text end
end
end
btn.BackgroundColor3 = theme.Accent
btnLbl.TextColor3 = Color3.new(1, 1, 1)
isOpen = false
Tween(DdFrame, {Size = UDim2.new(1, 0, 0, desc == "" and 42 or 55)}, 0.3)
Tween(DropIcon, {Rotation = 0}, 0.3)
end
upVis()
end)
end
end
function DdObj:SetValue(val)
if multi and type(val) == "table" then
for k, v in pairs(val) do
selected[k] = v
end
else
selected = val
end
self:Refresh(values)
upVis()
end
function DdObj:OnChanged(newCb)
changeCb = newCb
end
function DdObj:SetDesc(txt) if DescLbl then DescLbl.Text = txt end end
DdBtn.MouseButton1Click:Connect(function()
isOpen = not isOpen
Tween(DdFrame, {Size = isOpen and UDim2.new(1, 0, 0, (desc == "" and 42 or 55) + 130) or UDim2.new(1, 0, 0, desc == "" and 42 or 55)}, 0.3, Enum.EasingStyle.Exponential)
Tween(DropIcon, {Rotation = isOpen and 180 or 0}, 0.3)
end)
DdObj:Refresh(values)
upVis()
DevLib.Flags[id] = selected
DevLib.Options[id] = DdObj
return DdObj
end

