local GUI_TARGET = RunService:IsStudio() and LocalPlayer.PlayerGui or (gethui and gethui() or CoreGui)

local function Create(className, properties, children)
    local instance = Instance.new(className)
    for property, value in pairs(properties or {}) do
        instance[property] = value
    end
    for _, child in pairs(children or {}) do
        child.Parent = instance
    end
    table.insert(DevLib.Instances, instance)
    return instance
end

local function Tween(instance, properties, duration, style, direction)
    local tweenInfo = TweenInfo.new(duration or 0.3, style or Enum.EasingStyle.Quad, direction or Enum.EasingDirection.Out)
    local tween = TweenService:Create(instance, tweenInfo, properties)
    tween:Play()
    return tween
end

local function MakeDraggable(dragPart, targetPart)
    local dragging = false
    local dragInput, mousePos, framePos

    local conn1 = dragPart.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            mousePos = input.Position
            framePos = targetPart.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)

    local conn2 = dragPart.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)

    local conn3 = UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - mousePos
            Tween(targetPart, {
                Position = UDim2.new(framePos.X.Scale, framePos.X.Offset + delta.X, framePos.Y.Scale, framePos.Y.Offset + delta.Y)
            }, 0.15)
        end
    end)
    table.insert(DevLib.Connections, conn1)
    table.insert(DevLib.Connections, conn2)
    table.insert(DevLib.Connections, conn3)
end

function DevLib:SetTheme(name)
    if DevLib.Themes[name] then
        DevLib.CurrentTheme = name
    end
end

function DevLib:GetTheme()
    return DevLib.Themes[DevLib.CurrentTheme]
end

function DevLib:SendWebhook(url, embedData)
    if not RequestFunc then return end
    local data = {
        username = "DevLib System",
        avatar_url = "https://i.imgur.com/3Z6KxH7.png",
        embeds = {embedData}
    }
    pcall(function()
        RequestFunc({
            Url = url,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode(data)
        })
    end)
end

function DevLib:SaveConfig(customName)
    local name = customName or DevLib.SaveName
    if writefile then
        local success, encoded = pcall(HttpService.JSONEncode, HttpService, DevLib.Flags)
        if success then
            writefile(name .. ".json", encoded)
        end
    end
end

function DevLib:LoadConfig(customName)
    local name = customName or DevLib.SaveName
    if readfile and isfile and isfile(name .. ".json") then
        local success, decoded = pcall(HttpService.JSONDecode, HttpService, readfile(name .. ".json"))
        if success then
            for key, value in pairs(decoded) do
                if DevLib.Configs[key] then
                    DevLib.Configs[key](value)
                end
            end
        end
    end
end

function DevLib:DeleteConfig(customName)
    local name = customName or DevLib.SaveName
    if delfile and isfile and isfile(name .. ".json") then
        delfile(name .. ".json")
    end
end

function DevLib:Notify(options)
    options = options or {}
    local title = options.Title or "Notification"
    local content = options.Content or ""
    local duration = options.Duration or 5
    local theme = DevLib:GetTheme()

    if not DevLib.NotificationGui then
        DevLib.NotificationGui = Create("ScreenGui", {
            Name = "DevLibNotifications",
            Parent = GUI_TARGET,
            ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
            ResetOnSpawn = false
        })
        
        DevLib.NotificationContainer = Create("Frame", {
            Name = "Container",
            Parent = DevLib.NotificationGui,
            BackgroundTransparency = 1,
            Size = UDim2.fromScale(0.2, 1),
            Position = UDim2.fromScale(0.8, 0),
            AnchorPoint = Vector2.new(0, 0)
        }, {
            Create("UIListLayout", {
                SortOrder = Enum.SortOrder.LayoutOrder,
                VerticalAlignment = Enum.VerticalAlignment.Bottom,
                HorizontalAlignment = Enum.HorizontalAlignment.Right,
                Padding = UDim.new(0, 10)
            }),
            Create("UIPadding", {
                PaddingBottom = UDim.new(0, 20),
                PaddingRight = UDim.new(0, 20)
            })
        })
    end

    local notifFrame = Create("Frame", {
        Size = UDim2.new(1, 0, 0, 0),
        BackgroundColor3 = theme.WindowBackground,
        BackgroundTransparency = 0.1,
        AutomaticSize = Enum.AutomaticSize.Y,
        ClipsDescendants = true,
        Parent = DevLib.NotificationContainer
    }, {
        Create("UICorner", { CornerRadius = UDim.new(0, 8) }),
        Create("UIStroke", { Color = theme.StrokeColor, Thickness = 1 }),
        Create("UIPadding", { PaddingTop = UDim.new(0, 10), PaddingBottom = UDim.new(0, 10), PaddingLeft = UDim.new(0, 10), PaddingRight = UDim.new(0, 10) }),
        Create("TextLabel", {
            Name = "Title",
            BackgroundTransparency = 1,
            Size = UDim2.new(1, 0, 0, 20),
            Font = Enum.Font.GothamBold,
            Text = title,
            TextColor3 = theme.Text,
            TextSize = 14,
            TextXAlignment = Enum.TextXAlignment.Left
        }),
        Create("TextLabel", {
            Name = "Content",
            BackgroundTransparency = 1,
            Size = UDim2.new(1, 0, 0, 0),
            Position = UDim2.new(0, 0, 0, 25),
            AutomaticSize = Enum.AutomaticSize.Y,
            Font = Enum.Font.Gotham,
            Text = content,
            TextColor3 = theme.SubText,
            TextSize = 13,
            TextXAlignment = Enum.TextXAlignment.Left,
            TextWrapped = true
        })
    })

    notifFrame.Size = UDim2.new(0, 0, 0, notifFrame.AbsoluteSize.Y)
    Tween(notifFrame, { Size = UDim2.new(1, 0, 0, notifFrame.AbsoluteSize.Y) }, 0.4, Enum.EasingStyle.Back)

    task.delay(duration, function()
        local t = Tween(notifFrame, { Size = UDim2.new(0, 0, 0, notifFrame.AbsoluteSize.Y), BackgroundTransparency = 1 }, 0.4, Enum.EasingStyle.Quad)
        t.Completed:Connect(function()
            notifFrame:Destroy()
        end)
    end)
end

function DevLib:CreateWindow(options)
    options = options or {}
    local windowTitle = options.Title or "DevLib"
    local windowSubTitle = options.SubTitle or ""
    local windowSize = options.Size or UDim2.fromScale(0.65, 0.75)
    local themeName = options.Theme or "Dark"
    local useAcrylic = options.Acrylic or false
    local draggable = options.Draggable == nil and true or options.Draggable
    local keySystem = options.KeySystem or false
    local keySettings = options.KeySettings or {}

    DevLib:SetTheme(themeName)
    local theme = DevLib:GetTheme()

    local ScreenGui = Create("ScreenGui", {
        Name = "DevLibWindow",
        Parent = GUI_TARGET,
        ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
        ResetOnSpawn = false,
        IgnoreGuiInset = true
    })

    local Blur
    if useAcrylic then
        Blur = Create("BlurEffect", {
            Size = 0,
            Parent = Lighting
        })
        table.insert(DevLib.Instances, Blur)
    end

    local MainFrame = Create("Frame", {
        Name = "MainFrame",
        Parent = ScreenGui,
        BackgroundColor3 = theme.MainBackground,
        BackgroundTransparency = useAcrylic and 0.2 or 0,
        Size = UDim2.fromScale(0, 0),
        Position = UDim2.fromScale(0.5, 0.5),
        AnchorPoint = Vector2.new(0.5, 0.5),
        ClipsDescendants = true,
        Visible = false
    }, {
        Create("UICorner", { CornerRadius = UDim.new(0, 10) }),
        Create("UIStroke", { Color = theme.StrokeColor, Thickness = 1 }),
        Create("ImageLabel", {
            Name = "Shadow",
            BackgroundTransparency = 1,
            Image = "rbxassetid://6015897843",
            ImageColor3 = theme.Shadow,
            ImageTransparency = 0.5,
            ScaleType = Enum.ScaleType.Slice,
            SliceCenter = Rect.new(49, 49, 450, 450),
            Size = UDim2.new(1, 40, 1, 40),
            Position = UDim2.new(0, -20, 0, -20),
            ZIndex = 0
        })
    })

    local function OpenMainUI()
        MainFrame.Visible = true
        Tween(MainFrame, { Size = windowSize }, 0.5, Enum.EasingStyle.Exponential)
        if useAcrylic and Blur then Tween(Blur, { Size = 15 }, 0.5) end
    end

    if keySystem then
        local validKeys = keySettings.Keys or {"DevLib123"}
        local savedKeyPath = "DevLibKey.txt"
        
        local hasSavedKey = false
        if isfile and readfile then
            if isfile(savedKeyPath) then
                local sKey = readfile(savedKeyPath)
                for _, k in pairs(validKeys) do
                    if k == sKey then
                        hasSavedKey = true
                        break
                    end
                end
            end
        end

        if hasSavedKey then
            OpenMainUI()
        else
            if useAcrylic and Blur then Tween(Blur, { Size = 15 }, 0.5) end
            local KeyFrame = Create("Frame", {
                Parent = ScreenGui,
                BackgroundColor3 = theme.WindowBackground,
                Size = UDim2.new(0, 400, 0, 200),
                Position = UDim2.fromScale(0.5, 0.5),
                AnchorPoint = Vector2.new(0.5, 0.5),
                ClipsDescendants = true
            }, {
                Create("UICorner", { CornerRadius = UDim.new(0, 10) }),
                Create("UIStroke", { Color = theme.StrokeColor, Thickness = 1 }),
                Create("TextLabel", {
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 0, 40),
                    Font = Enum.Font.GothamBold,
                    Text = keySettings.Title or "Key System",
                    TextColor3 = theme.Text,
                    TextSize = 18
                }),
                Create("TextLabel", {
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 0, 20),
                    Position = UDim2.new(0, 0, 0, 40),
                    Font = Enum.Font.Gotham,
                    Text = keySettings.Note or "Enter your key to continue",
                    TextColor3 = theme.SubText,
                    TextSize = 13
                }),
                Create("TextBox", {
                    Name = "KeyInput",
                    BackgroundColor3 = theme.ElementBackground,
                    Size = UDim2.new(1, -40, 0, 40),
                    Position = UDim2.new(0, 20, 0, 80),
                    Font = Enum.Font.Gotham,
                    PlaceholderText = "Enter Key Here...",
                    Text = "",
                    TextColor3 = theme.Text,
                    TextSize = 14,
                    ClearTextOnFocus = false
                }, {
                    Create("UICorner", { CornerRadius = UDim.new(0, 6) }),
                    Create("UIStroke", { Color = theme.StrokeColor, Thickness = 1 })
                }),
                Create("TextButton", {
                    Name = "CheckBtn",
                    BackgroundColor3 = theme.Accent,
                    Size = UDim2.new(1, -40, 0, 40),
                    Position = UDim2.new(0, 20, 0, 135),
                    Font = Enum.Font.GothamBold,
                    Text = "Verify Key",
                    TextColor3 = Color3.fromRGB(255, 255, 255),
                    TextSize = 14
                }, {
                    Create("UICorner", { CornerRadius = UDim.new(0, 6) })
                })
            })
            
            KeyFrame.Size = UDim2.new(0,0,0,0)
            Tween(KeyFrame, {Size = UDim2.new(0,400,0,200)}, 0.5, Enum.EasingStyle.Exponential)

            KeyFrame.CheckBtn.MouseButton1Click:Connect(function()
                local typed = KeyFrame.KeyInput.Text
                local correct = false
                for _, k in pairs(validKeys) do
                    if k == typed then correct = true break end
                end
                
                if correct then
                    if writefile then pcall(writefile, savedKeyPath, typed) end
                    Tween(KeyFrame, {Size = UDim2.new(0,0,0,0)}, 0.5, Enum.EasingStyle.Exponential)
                    task.wait(0.5)
                    KeyFrame:Destroy()
                    OpenMainUI()
                else
                    KeyFrame.KeyInput.Text = "INVALID KEY"
                    Tween(KeyFrame.KeyInput.UIStroke, {Color = theme.Error}, 0.2)
                    task.wait(1)
                    KeyFrame.KeyInput.Text = ""
                    Tween(KeyFrame.KeyInput.UIStroke, {Color = theme.StrokeColor}, 0.2)
                end
            end)
        end
    else
        OpenMainUI()
    end

    local Topbar = Create("Frame", {
        Name = "Topbar",
        Parent = MainFrame,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 40),
        Position = UDim2.new(0, 0, 0, 0)
    })

    if draggable then MakeDraggable(Topbar, MainFrame) end

    local TitleLabel = Create("TextLabel", {
        Name = "Title",
        Parent = Topbar,
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 15, 0, 0),
        Size = UDim2.new(0, 0, 1, 0),
        AutomaticSize = Enum.AutomaticSize.X,
        Font = Enum.Font.GothamBold,
        Text = windowTitle,
        TextColor3 = theme.Text,
        TextSize = 16,
        TextXAlignment = Enum.TextXAlignment.Left
    })

    local SubTitleLabel = Create("TextLabel", {
        Name = "SubTitle",
        Parent = Topbar,
        BackgroundTransparency = 1,
        Position = UDim2.new(0, TitleLabel.AbsoluteSize.X + 25, 0, 0),
        Size = UDim2.new(0, 0, 1, 0),
        AutomaticSize = Enum.AutomaticSize.X,
        Font = Enum.Font.Gotham,
        Text = windowSubTitle,
        TextColor3 = theme.SubText,
        TextSize = 14,
        TextXAlignment = Enum.TextXAlignment.Left
    })

    TitleLabel:GetPropertyChangedSignal("AbsoluteSize"):Connect(function()
        SubTitleLabel.Position = UDim2.new(0, TitleLabel.AbsoluteSize.X + 25, 0, 0)
    end)

    local ControlButtons = Create("Frame", {
        Name = "ControlButtons",
        Parent = Topbar,
        BackgroundTransparency = 1,
        Size = UDim2.new(0, 120, 1, 0),
        Position = UDim2.new(1, -130, 0, 0)
    }, {
        Create("UIListLayout", {
            FillDirection = Enum.FillDirection.Horizontal,
            HorizontalAlignment = Enum.HorizontalAlignment.Right,
            VerticalAlignment = Enum.VerticalAlignment.Center,
            Padding = UDim.new(0, 5)
        })
    })

    local function CreateControlButton(icon, color, hoverColor)
        local btn = Create("TextButton", {
            Parent = ControlButtons,
            BackgroundColor3 = theme.ElementBackground,
            BackgroundTransparency = 1,
            Size = UDim2.new(0, 30, 0, 30),
            Text = "",
            AutoButtonColor = false
        }, {
            Create("UICorner", { CornerRadius = UDim.new(0, 6) }),
            Create("ImageLabel", {
                BackgroundTransparency = 1,
                Size = UDim2.new(0, 16, 0, 16),
                Position = UDim2.fromScale(0.5, 0.5),
                AnchorPoint = Vector2.new(0.5, 0.5),
                Image = icon,
                ImageColor3 = color
            })
        })
        btn.MouseEnter:Connect(function() Tween(btn, { BackgroundTransparency = 0 }, 0.2) Tween(btn.ImageLabel, { ImageColor3 = hoverColor }, 0.2) end)
        btn.MouseLeave:Connect(function() Tween(btn, { BackgroundTransparency = 1 }, 0.2) Tween(btn.ImageLabel, { ImageColor3 = color }, 0.2) end)
        return btn
    end

    local TopMinimizeBtn = CreateControlButton("rbxassetid://10736934244", theme.Text, theme.Accent)
    local CloseBtn = CreateControlButton("rbxassetid://10747384394", theme.Text, theme.Error)

    local Sidebar = Create("Frame", {
        Name = "Sidebar",
        Parent = MainFrame,
        BackgroundColor3 = theme.WindowBackground,
        BackgroundTransparency = 0.3,
        Size = UDim2.new(0, 200, 1, -40),
        Position = UDim2.new(0, 0, 0, 40)
    }, {
        Create("UIStroke", { Color = theme.StrokeColor, Thickness = 1 }),
        Create("ScrollingFrame", {
            Name = "TabList",
            BackgroundTransparency = 1,
            Size = UDim2.new(1, 0, 1, 0),
            ScrollBarThickness = 0,
            CanvasSize = UDim2.new(0, 0, 0, 0),
            AutomaticCanvasSize = Enum.AutomaticSize.Y
        }, {
            Create("UIListLayout", { Padding = UDim.new(0, 5), HorizontalAlignment = Enum.HorizontalAlignment.Center }),
            Create("UIPadding", { PaddingTop = UDim.new(0, 10), PaddingBottom = UDim.new(0, 10) })
        })
    })

    local ContentContainer = Create("Frame", {
        Name = "ContentContainer",
        Parent = MainFrame,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, -200, 1, -40),
        Position = UDim2.new(0, 200, 0, 40)
    })

    local WindowObj = {
        Tabs = {},
        ActiveTab = nil,
        Gui = ScreenGui,
        Main = MainFrame,
        Blur = Blur
    }
    DevLib.ActiveWindow = WindowObj

    CloseBtn.MouseButton1Click:Connect(function() WindowObj:Destroy() end)
    TopMinimizeBtn.MouseButton1Click:Connect(function() WindowObj:Minimize() end)

    function WindowObj:Minimize()
        Tween(MainFrame, { Size = UDim2.fromScale(0, 0), BackgroundTransparency = 1 }, 0.5, Enum.EasingStyle.Exponential)
        if useAcrylic and Blur then Tween(Blur, { Size = 0 }, 0.5) end
        MainFrame.Visible = false
    end

    function WindowObj:Maximize()
        MainFrame.Visible = true
        Tween(MainFrame, { Size = windowSize, BackgroundTransparency = useAcrylic and 0.2 or 0 }, 0.5, Enum.EasingStyle.Exponential)
        if useAcrylic and Blur then Tween(Blur, { Size = 15 }, 0.5) end
    end

    function WindowObj:Destroy()
        Tween(MainFrame, { Size = UDim2.fromScale(0, 0), BackgroundTransparency = 1 }, 0.5, Enum.EasingStyle.Exponential)
        if useAcrylic and Blur then
            local t = Tween(Blur, { Size = 0 }, 0.5)
            t.Completed:Connect(function() Blur:Destroy() end)
        end
        for _, conn in pairs(DevLib.Connections) do conn:Disconnect() end
        task.delay(0.5, function()
            for _, inst in pairs(DevLib.Instances) do if inst and inst.Parent then inst:Destroy() end end
            ScreenGui:Destroy()
            if DevLib.NotificationGui then DevLib.NotificationGui:Destroy() end
        end)
    end

    function WindowObj:AddMinimizeButton(minOptions)
        minOptions = minOptions or {}
        local minSize = minOptions.Size or UDim2.fromOffset(40, 40)
        local minPos = minOptions.Position or UDim2.new(1, -60, 1, -60)
        local minVisible = minOptions.Visible == nil and true or minOptions.Visible

        local MinGui = Create("ScreenGui", { Parent = GUI_TARGET, ResetOnSpawn = false })
        table.insert(DevLib.Instances, MinGui)

        local FloatingBtn = Create("TextButton", {
            Parent = MinGui,
            Size = minSize,
            Position = minPos,
            BackgroundColor3 = theme.ElementBackground,
            Text = minOptions.Text or "DEV",
            Font = Enum.Font.GothamBold,
            TextColor3 = theme.Text,
            AutoButtonColor = false,
            Visible = minVisible
        }, {
            Create("UICorner", { CornerRadius = UDim.new(0, 20) }),
            Create("UIStroke", { Color = theme.StrokeColor, Thickness = 2 })
        })

        MakeDraggable(FloatingBtn, FloatingBtn)

        FloatingBtn.MouseButton1Click:Connect(function()
            if MainFrame.Visible then WindowObj:Minimize() else WindowObj:Maximize() end
        end)
    end

    function WindowObj:AddTab(tabOptions)
        tabOptions = tabOptions or {}
        local tabTitle = tabOptions.Title or "Tab"
        local tabIcon = tabOptions.Icon or "rbxassetid://10723396652"

        local TabButton = Create("TextButton", {
            Parent = Sidebar.TabList,
            BackgroundColor3 = theme.ElementBackground,
            BackgroundTransparency = 1,
            Size = UDim2.new(1, -20, 0, 35),
            Text = "",
            AutoButtonColor = false
        }, {
            Create("UICorner", { CornerRadius = UDim.new(0, 6) }),
            Create("ImageLabel", {
                Name = "Icon",
                BackgroundTransparency = 1,
                Size = UDim2.new(0, 20, 0, 20),
                Position = UDim2.new(0, 10, 0.5, 0),
                AnchorPoint = Vector2.new(0, 0.5),
                Image = tabIcon,
                ImageColor3 = theme.SubText
            }),
            Create("TextLabel", {
                Name = "Title",
                BackgroundTransparency = 1,
                Size = UDim2.new(1, -40, 1, 0),
                Position = UDim2.new(0, 40, 0, 0),
                Font = Enum.Font.GothamMedium,
                Text = tabTitle,
                TextColor3 = theme.SubText,
                TextSize = 14,
                TextXAlignment = Enum.TextXAlignment.Left
            }),
            Create("Frame", {
                Name = "Indicator",
                BackgroundColor3 = theme.Accent,
                Size = UDim2.new(0, 3, 0, 0),
                Position = UDim2.new(0, 0, 0.5, 0),
                AnchorPoint = Vector2.new(0, 0.5),
                BackgroundTransparency = 1
            }, { Create("UICorner", { CornerRadius = UDim.new(0, 2) }) })
        })

        local TabContainer = Create("ScrollingFrame", {
            Name = tabTitle .. "Container",
            Parent = ContentContainer,
            BackgroundTransparency = 1,
            Size = UDim2.new(1, 0, 1, 0),
            ScrollBarThickness = 2,
            ScrollBarImageColor3 = theme.StrokeColor,
            Visible = false,
            CanvasSize = UDim2.new(0, 0, 0, 0),
            AutomaticCanvasSize = Enum.AutomaticSize.Y
        }, {
            Create("UIListLayout", { Padding = UDim.new(0, 8), HorizontalAlignment = Enum.HorizontalAlignment.Center }),
            Create("UIPadding", { PaddingTop = UDim.new(0, 15), PaddingBottom = UDim.new(0, 15), PaddingLeft = UDim.new(0, 15), PaddingRight = UDim.new(0, 15) })
        })

        local TabObj = { Name = tabTitle, Container = TabContainer, Button = TabButton }

        TabButton.MouseButton1Click:Connect(function() WindowObj:SelectTab(TabObj) end)
        table.insert(WindowObj.Tabs, TabObj)
        if #WindowObj.Tabs == 1 then WindowObj:SelectTab(TabObj) end

        function TabObj:AddSection(text)
            Create("TextLabel", {
                Parent = TabContainer,
                BackgroundTransparency = 1,
                Size = UDim2.new(1, 0, 0, 30),
                Font = Enum.Font.GothamBold,
                Text = text,
                TextColor3 = theme.Accent,
                TextSize = 14,
                TextXAlignment = Enum.TextXAlignment.Left
            })
        end

        function TabObj:AddButton(btnOptions)
            local title = btnOptions.Title or "Button"
            local cb = btnOptions.Callback or function() end
            local BtnFrame = Create("TextButton", {
                Parent = TabContainer, BackgroundColor3 = theme.ElementBackground, Size = UDim2.new(1, 0, 0, 40), Text = "", AutoButtonColor = false
            }, {
                Create("UICorner", { CornerRadius = UDim.new(0, 6) }), Create("UIStroke", { Color = theme.StrokeColor, Thickness = 1 }),
                Create("TextLabel", { BackgroundTransparency = 1, Size = UDim2.new(1, -20, 1, 0), Position = UDim2.new(0, 10, 0, 0), Font = Enum.Font.GothamMedium, Text = title, TextColor3 = theme.Text, TextSize = 14, TextXAlignment = Enum.TextXAlignment.Left })
            })
            BtnFrame.MouseEnter:Connect(function() Tween(BtnFrame, { BackgroundColor3 = theme.ElementHover }, 0.2) end)
            BtnFrame.MouseLeave:Connect(function() Tween(BtnFrame, { BackgroundColor3 = theme.ElementBackground }, 0.2) end)
            BtnFrame.MouseButton1Click:Connect(cb)
        end

        function TabObj:AddToggle(flag, tglOptions)
            local state = tglOptions.Default or false
            local TglFrame = Create("TextButton", { Parent = TabContainer, BackgroundColor3 = theme.ElementBackground, Size = UDim2.new(1, 0, 0, 40), Text = "", AutoButtonColor = false }, {
                Create("UICorner", { CornerRadius = UDim.new(0, 6) }), Create("UIStroke", { Color = theme.StrokeColor, Thickness = 1 }),
                Create("TextLabel", { BackgroundTransparency = 1, Size = UDim2.new(1, -60, 1, 0), Position = UDim2.new(0, 10, 0, 0), Font = Enum.Font.GothamMedium, Text = tglOptions.Title or "Toggle", TextColor3 = theme.Text, TextSize = 14, TextXAlignment = Enum.TextXAlignment.Left })
            })
            local Switch = Create("Frame", { Parent = TglFrame, BackgroundColor3 = state and theme.Accent or theme.TabBackground, Size = UDim2.new(0, 40, 0, 20), Position = UDim2.new(1, -50, 0.5, 0), AnchorPoint = Vector2.new(0, 0.5) }, { Create("UICorner", { CornerRadius = UDim.new(1, 0) }) })
            local Circle = Create("Frame", { Parent = Switch, BackgroundColor3 = Color3.fromRGB(255, 255, 255), Size = UDim2.new(0, 14, 0, 14), Position = state and UDim2.new(1, -17, 0.5, 0) or UDim2.new(0, 3, 0.5, 0), AnchorPoint = Vector2.new(0, 0.5) }, { Create("UICorner", { CornerRadius = UDim.new(1, 0) }) })
            TglFrame.MouseButton1Click:Connect(function()
                state = not state
                DevLib.Flags[flag] = state
                Tween(Switch, { BackgroundColor3 = state and theme.Accent or theme.TabBackground }, 0.2)
                Tween(Circle, { Position = state and UDim2.new(1, -17, 0.5, 0) or UDim2.new(0, 3, 0.5, 0) }, 0.2)
                if tglOptions.Callback then tglOptions.Callback(state) end
            end)
            DevLib.Flags[flag] = state
            return {SetValue = function(_, v) state = not v TglFrame.MouseButton1Click:Fire() end, GetValue = function() return state end}
        end

        function TabObj:AddSlider(flag, sldOptions)
            local min, max, val = sldOptions.Min or 0, sldOptions.Max or 100, sldOptions.Default or 0
            local SldFrame = Create("Frame", { Parent = TabContainer, BackgroundColor3 = theme.ElementBackground, Size = UDim2.new(1, 0, 0, 60) }, {
                Create("UICorner", { CornerRadius = UDim.new(0, 6) }), Create("UIStroke", { Color = theme.StrokeColor, Thickness = 1 }),
                Create("TextLabel", { BackgroundTransparency = 1, Size = UDim2.new(1, -20, 0, 30), Position = UDim2.new(0, 10, 0, 0), Font = Enum.Font.GothamMedium, Text = sldOptions.Title or "Slider", TextColor3 = theme.Text, TextSize = 14, TextXAlignment = Enum.TextXAlignment.Left }),
                Create("TextLabel", { Name = "Val", BackgroundTransparency = 1, Size = UDim2.new(0, 50, 0, 30), Position = UDim2.new(1, -60, 0, 0), Font = Enum.Font.Gotham, Text = tostring(val), TextColor3 = theme.SubText, TextSize = 14, TextXAlignment = Enum.TextXAlignment.Right })
            })
            local SliderBg = Create("TextButton", { Parent = SldFrame, BackgroundColor3 = theme.TabBackground, Size = UDim2.new(1, -20, 0, 6), Position = UDim2.new(0, 10, 0, 40), Text = "", AutoButtonColor = false }, { Create("UICorner", { CornerRadius = UDim.new(1, 0) }) })
            local SliderFill = Create("Frame", { Parent = SliderBg, BackgroundColor3 = theme.Accent, Size = UDim2.new((val - min) / (max - min), 0, 1, 0) }, { Create("UICorner", { CornerRadius = UDim.new(1, 0) }) })
            
            local function update(input)
                local pct = math.clamp((input.Position.X - SliderBg.AbsolutePosition.X) / SliderBg.AbsoluteSize.X, 0, 1)
                val = math.floor(min + ((max - min) * pct))
                DevLib.Flags[flag] = val
                SldFrame.Val.Text = tostring(val)
                Tween(SliderFill, { Size = UDim2.new(pct, 0, 1, 0) }, 0.1)
                if sldOptions.Callback then sldOptions.Callback(val) end
            end
            
            local dragging = false
            SliderBg.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true update(i) end end)
            UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)
            UserInputService.InputChanged:Connect(function(i) if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then update(i) end end)
            DevLib.Flags[flag] = val
        end

        function TabObj:AddColorPicker(flag, cpOptions)
            local color = cpOptions.Default or Color3.new(1,1,1)
            local h,s,v = Color3.toHSV(color)
            local CpFrame = Create("Frame", { Parent = TabContainer, BackgroundColor3 = theme.ElementBackground, Size = UDim2.new(1, 0, 0, 40), ClipsDescendants = true }, {
                Create("UICorner", { CornerRadius = UDim.new(0, 6) }), Create("UIStroke", { Color = theme.StrokeColor, Thickness = 1 })
            })
            local Btn = Create("TextButton", { Parent = CpFrame, BackgroundTransparency=1, Size=UDim2.new(1,0,0,40), Text="" }, {
                Create("TextLabel", { BackgroundTransparency=1, Size=UDim2.new(1,-60,1,0), Position=UDim2.new(0,10,0,0), Font=Enum.Font.GothamMedium, Text=cpOptions.Title or "Color", TextColor3=theme.Text, TextSize=14, TextXAlignment=Enum.TextXAlignment.Left }),
                Create("Frame", { Name="Display", BackgroundColor3=color, Size=UDim2.new(0,30,0,20), Position=UDim2.new(1,-40,0.5,0), AnchorPoint=Vector2.new(0,0.5) }, { Create("UICorner", { CornerRadius=UDim.new(0,4) }) })
            })
            local Drop = Create("Frame", { Parent = CpFrame, BackgroundTransparency=1, Size=UDim2.new(1,-20,0,110), Position=UDim2.new(0,10,0,45) })
            local SatVal = Create("TextButton", { Parent = Drop, BackgroundColor3=Color3.fromHSV(h,1,1), Size=UDim2.new(1,-30,1,0), Text="", AutoButtonColor=false }, { Create("UICorner", { CornerRadius=UDim.new(0,4) }) })
            local Hue = Create("TextButton", { Parent = Drop, Size=UDim2.new(0,20,1,0), Position=UDim2.new(1,-20,0,0), Text="", AutoButtonColor=false }, { Create("UICorner", { CornerRadius=UDim.new(0,4) }), Create("UIGradient", { Rotation=90, Color=ColorSequence.new({ColorSequenceKeypoint.new(0,Color3.new(1,0,0)),ColorSequenceKeypoint.new(0.5,Color3.new(0,1,0)),ColorSequenceKeypoint.new(1,Color3.new(0,0,1))}) }) })
            
            local open = false
            Btn.MouseButton1Click:Connect(function() open = not open Tween(CpFrame, {Size = open and UDim2.new(1,0,0,165) or UDim2.new(1,0,0,40)}, 0.3) end)
            
            local ds, dh = false, false
            local function upC() color = Color3.fromHSV(h,s,v) Btn.Display.BackgroundColor3 = color SatVal.BackgroundColor3 = Color3.fromHSV(h,1,1) DevLib.Flags[flag] = color if cpOptions.Callback then cpOptions.Callback(color) end end
            SatVal.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then ds = true end end)
            Hue.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dh = true end end)
            UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then ds, dh = false, false end end)
            UserInputService.InputChanged:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseMovement then
                    if ds then s = math.clamp((i.Position.X - SatVal.AbsolutePosition.X)/SatVal.AbsoluteSize.X,0,1) v = 1 - math.clamp((i.Position.Y - SatVal.AbsolutePosition.Y)/SatVal.AbsoluteSize.Y,0,1) upC() end
                    if dh then h = 1 - math.clamp((i.Position.Y - Hue.AbsolutePosition.Y)/Hue.AbsoluteSize.Y,0,1) upC() end
                end
            end)
            DevLib.Flags[flag] = color
        end

        function TabObj:AddTerminal()
            local TermFrame = Create("Frame", { Parent = TabContainer, BackgroundColor3 = Color3.fromRGB(10,10,10), Size = UDim2.new(1,0,0,200), ClipsDescendants = true }, { Create("UICorner", { CornerRadius = UDim.new(0,6) }), Create("UIStroke", { Color = theme.StrokeColor, Thickness = 1 }) })
            local Scroll = Create("ScrollingFrame", { Parent = TermFrame, BackgroundTransparency = 1, Size = UDim2.new(1,-10,1,-10), Position = UDim2.new(0,5,0,5), CanvasSize = UDim2.new(0,0,0,0), AutomaticCanvasSize = Enum.AutomaticSize.Y, ScrollBarThickness = 2 })
            Create("UIListLayout", { Parent = Scroll, Padding = UDim.new(0,2) })
            local obj = {}
            function obj:Log(text, color)
                Create("TextLabel", { Parent = Scroll, BackgroundTransparency = 1, Size = UDim2.new(1,0,0,16), Font = Enum.Font.Code, Text = "> " .. text, TextColor3 = color or Color3.new(0,1,0), TextSize = 12, TextXAlignment = Enum.TextXAlignment.Left })
            end
            return obj
        end

        function TabObj:AddConsole(callback)
            local ConFrame = Create("Frame", { Parent = TabContainer, BackgroundColor3 = Color3.fromRGB(10,10,10), Size = UDim2.new(1,0,0,230), ClipsDescendants = true }, { Create("UICorner", { CornerRadius = UDim.new(0,6) }) })
            local Scroll = Create("ScrollingFrame", { Parent = ConFrame, BackgroundTransparency = 1, Size = UDim2.new(1,-10,1,-40), Position = UDim2.new(0,5,0,5), CanvasSize = UDim2.new(0,0,0,0), AutomaticCanvasSize = Enum.AutomaticSize.Y, ScrollBarThickness = 2 })
            Create("UIListLayout", { Parent = Scroll, Padding = UDim.new(0,2) })
            local Input = Create("TextBox", { Parent = ConFrame, BackgroundColor3 = theme.ElementBackground, Size = UDim2.new(1,-10,0,30), Position = UDim2.new(0,5,1,-35), Font = Enum.Font.Code, Text = "", TextColor3 = theme.Text, TextSize = 13, PlaceholderText = "Enter command..." }, { Create("UICorner", { CornerRadius = UDim.new(0,4) }) })
            Input.FocusLost:Connect(function(enter)
                if enter and Input.Text ~= "" then
                    Create("TextLabel", { Parent = Scroll, BackgroundTransparency = 1, Size = UDim2.new(1,0,0,16), Font = Enum.Font.Code, Text = "$ " .. Input.Text, TextColor3 = Color3.new(1,1,1), TextSize = 12, TextXAlignment = Enum.TextXAlignment.Left })
                    if callback then callback(Input.Text) end
                    Input.Text = ""
                end
            end)
            local obj = {}
            function obj:Print(t) Create("TextLabel", { Parent = Scroll, BackgroundTransparency = 1, Size = UDim2.new(1,0,0,16), Font = Enum.Font.Code, Text = t, TextColor3 = Color3.new(0.7,0.7,0.7), TextSize = 12, TextXAlignment = Enum.TextXAlignment.Left }) end
            return obj
        end

        function TabObj:AddCodeBlock(code)
