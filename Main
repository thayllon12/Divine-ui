        function TabObj:AddScriptHub() TabObj:AddButton({Title="Execute Internal Script", Callback=function() if loadstring then pcall(function() loadstring("print('Executed via DevLib')")() end) end end}) end
        function TabObj:AddExecutorInfo() TabObj:AddLabel("Running on: " .. (identifyexecutor and identifyexecutor() or "Unknown Executor")) end

        function TabObj:AddPerformanceMonitor()
            local Mem = TabObj:AddStatistic("Memory Usage", "0 MB")
            local conn = RunService.RenderStepped:Connect(function()
                if not Mem or not WindowObj.Main.Parent then return end
                Mem:SetValue(math.floor(Stats:GetTotalMemoryUsageMb()) .. " MB")
            end)
            table.insert(DevLib.Connections, conn)
        end
        TabObj.AddMemoryMonitor = TabObj.AddPerformanceMonitor
        TabObj.AddNetworkStats = TabObj.AddPerformanceMonitor

        function TabObj:AddLogger() TabObj:AddTerminal() end
        function TabObj:AddDebugPanel() TabObj:AddConsole() end
        function TabObj:AddPropertyEditor() TabObj:AddInput({Title="Property Name"}) TabObj:AddInput({Title="Property Value"}) end

        return TabObj
    end

    return WindowObj
end

