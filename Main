        function TabObj:AddToggle(id, options)
            id, options = getId(id, options)
            local title = options.Title or "Toggle"
            local desc = options.Description or ""
            local state = options.Default or false
            local cb = options.Callback or function() end
            
            local TglFrame = Create("TextButton", {
                Parent = TabContainer,
                BackgroundColor3 = theme.ElementBackground,
                Size = UDim2.new(1, 0, 0, desc == "" and 42 or 55),
                Text = "",
                AutoButtonColor = false,
                ZIndex = 4
            })
            
            Create("UICorner", { Parent = TglFrame, CornerRadius = UDim.new(0, 6) })
            Create("UIStroke", { Parent = TglFrame, Color = theme.StrokeColor, Thickness = 1 })
            
            Create("TextLabel", {
                Parent = TglFrame,
                BackgroundTransparency = 1,
                Size = UDim2.new(1, -80, 0, 20),
                Position = UDim2.new(0, 15, 0, desc == "" and 11 or 8),
                Font = Enum.Font.GothamMedium,
                Text = title,
                TextColor3 = theme.Text,
                TextSize = 14,
                TextXAlignment = Enum.TextXAlignment.Left,
                ZIndex = 5
            })
            
            if desc ~= "" then
                Create("TextLabel", {
                    Parent = TglFrame,
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, -80, 0, 15),
                    Position = UDim2.new(0, 15, 0, 28),
                    Font = Enum.Font.Gotham,
                    Text = desc,
                    TextColor3 = theme.SubText,
                    TextSize = 12,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    ZIndex = 5
                })
            end
            
            local Switch = Create("Frame", {
                Parent = TglFrame,
                BackgroundColor3 = state and theme.Accent or theme.TabBackground,
                Size = UDim2.new(0, 42, 0, 22),
                Position = UDim2.new(1, -55, 0.5, 0),
                AnchorPoint = Vector2.new(0, 0.5),
                ZIndex = 5
            })
            
            Create("UICorner", { Parent = Switch, CornerRadius = UDim.new(1, 0) })
            Create("UIStroke", { Parent = Switch, Color = theme.StrokeColor, Thickness = 1 })
            
            local Circle = Create("Frame", {
                Parent = Switch,
                BackgroundColor3 = Color3.fromRGB(255, 255, 255),
                Size = UDim2.new(0, 16, 0, 16),
                Position = state and UDim2.new(1, -19, 0.5, 0) or UDim2.new(0, 3, 0.5, 0),
                AnchorPoint = Vector2.new(0, 0.5),
                ZIndex = 6
            })
            
            Create("UICorner", { Parent = Circle, CornerRadius = UDim.new(1, 0) })
            
            Create("ImageLabel", {
                Parent = Circle,
                BackgroundTransparency = 1,
                Image = "rbxassetid://6015897843",
                ImageColor3 = theme.Shadow,
                ImageTransparency = 0.5,
                ScaleType = Enum.ScaleType.Slice,
                SliceCenter = Rect.new(49, 49, 450, 450),
                Size = UDim2.new(1, 10, 1, 10),
                Position = UDim2.new(0, -5, 0, -5),
                ZIndex = 5
            })

            local TglObj = { Value = state }
            local changeCb = cb
            
            function TglObj:SetValue(val)
                self.Value = val
                state = val
                DevLib.Flags[id] = state
                Tween(Switch, { BackgroundColor3 = state and theme.Accent or theme.TabBackground }, 0.2)
                Tween(Circle, { Position = state and UDim2.new(1, -19, 0.5, 0) or UDim2.new(0, 3, 0.5, 0) }, 0.2, Enum.EasingStyle.Back)
                if changeCb then
                    pcall(function() changeCb(state) end)
                end
            end
            
            function TglObj:OnChanged(newCb)
                changeCb = newCb
            end
            
            TglFrame.MouseButton1Click:Connect(function()
                TglObj:SetValue(not state)
            end)
            
            DevLib.Flags[id] = state
            DevLib.Options[id] = TglObj
            return TglObj
        end

        function TabObj:AddSlider(id, options)
            id, options = getId(id, options)
            local title = options.Title or "Slider"
            local desc = options.Description or ""
            local min = options.Min or 0
            local max = options.Max or 100
            local val = options.Default or 0
            local rounding = options.Rounding or 0
            local cb = options.Callback or function() end

            local SldFrame = Create("Frame", {
                Parent = TabContainer,
                BackgroundColor3 = theme.ElementBackground,
                Size = UDim2.new(1, 0, 0, desc == "" and 65 or 80),
                ZIndex = 4
            })
            
            Create("UICorner", { Parent = SldFrame, CornerRadius = UDim.new(0, 6) })
            Create("UIStroke", { Parent = SldFrame, Color = theme.StrokeColor, Thickness = 1 })
            
            Create("TextLabel", {
                Parent = SldFrame,
                BackgroundTransparency = 1,
                Size = UDim2.new(1, -80, 0, 20),
                Position = UDim2.new(0, 15, 0, 10),
                Font = Enum.Font.GothamMedium,
                Text = title,
                TextColor3 = theme.Text,
                TextSize = 14,
                TextXAlignment = Enum.TextXAlignment.Left,
                ZIndex = 5
            })
            
            local ValLbl = Create("TextLabel", {
                Parent = SldFrame,
                BackgroundTransparency = 1,
                Size = UDim2.new(0, 50, 0, 20),
                Position = UDim2.new(1, -65, 0, 10),
                Font = Enum.Font.GothamBold,
                Text = tostring(val),
                TextColor3 = theme.SubText,
                TextSize = 14,
                TextXAlignment = Enum.TextXAlignment.Right,
                ZIndex = 5
            })
            
            if desc ~= "" then
                Create("TextLabel", {
                    Parent = SldFrame,
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, -80, 0, 15),
                    Position = UDim2.new(0, 15, 0, 28),
                    Font = Enum.Font.Gotham,
                    Text = desc,
                    TextColor3 = theme.SubText,
                    TextSize = 12,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    ZIndex = 5
                })
            end

            local SliderBg = Create("TextButton", {
                Parent = SldFrame,
                BackgroundColor3 = theme.TabBackground,
                Size = UDim2.new(1, -30, 0, 6),
                Position = UDim2.new(0, 15, 1, -15),
                Text = "",
                AutoButtonColor = false,
                ZIndex = 5
            })
            
            Create("UICorner", { Parent = SliderBg, CornerRadius = UDim.new(1, 0) })
            Create("UIStroke", { Parent = SliderBg, Color = theme.StrokeColor, Thickness = 1 })
            
            local SliderFill = Create("Frame", {
                Parent = SliderBg,
                BackgroundColor3 = theme.Accent,
                Size = UDim2.new((val - min)/(max - min), 0, 1, 0),
                ZIndex = 6
            })
            Create("UICorner", { Parent = SliderFill, CornerRadius = UDim.new(1, 0) })
            
            local SliderCirc = Create("Frame", {
                Parent = SliderFill,
                BackgroundColor3 = Color3.fromRGB(255, 255, 255),
                Size = UDim2.new(0, 12, 0, 12),
                Position = UDim2.new(1, -6, 0.5, 0),
                AnchorPoint = Vector2.new(0, 0.5),
                ZIndex = 7
            })
            Create("UICorner", { Parent = SliderCirc, CornerRadius = UDim.new(1, 0) })

            local SldObj = { Value = val }
            local changeCb = cb
            
            function SldObj:SetValue(v)
                val = math.clamp(math.round(v * (10^rounding)) / (10^rounding), min, max)
                self.Value = val
                DevLib.Flags[id] = val
                ValLbl.Text = tostring(val)
                Tween(SliderFill, { Size = UDim2.new((val - min)/(max - min), 0, 1, 0) }, 0.1)
                if changeCb then
                    pcall(function() changeCb(val) end)
                end
            end
            
            function SldObj:OnChanged(newCb)
                changeCb = newCb
            end

            local dragging = false
            local function update(input)
                local sizeX = SliderBg.AbsoluteSize.X
                local posX = SliderBg.AbsolutePosition.X
                local pct = math.clamp((input.Position.X - posX) / sizeX, 0, 1)
                SldObj:SetValue(min + ((max - min) * pct))
            end
            
            SliderBg.InputBegan:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
                    dragging = true
                    Tween(SliderCirc, {Size=UDim2.new(0,16,0,16)}, 0.2)
                    update(i)
                end
            end)
            
            local conn1 = UserInputService.InputEnded:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
                    dragging = false
                    Tween(SliderCirc, {Size=UDim2.new(0,12,0,12)}, 0.2)
                end
            end)
            
            local conn2 = UserInputService.InputChanged:Connect(function(i)
                if dragging and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then
                    update(i)
                end
            end)
            
            table.insert(DevLib.Connections, conn1)
            table.insert(DevLib.Connections, conn2)

            DevLib.Flags[id] = val
            DevLib.Options[id] = SldObj
            return SldObj
        end

        function TabObj:AddDropdown(id, options)
            id, options = getId(id, options)
            local title = options.Title or "Dropdown"
            local desc = options.Description or ""
            local values = options.Values or {}
            local multi = options.Multi or false
            local default = options.Default
            
            local selected = multi and (type(default) == "table" and default or {}) or default
            local cb = options.Callback or function() end
            local isOpen = false

            local DdFrame = Create("Frame", {
                Parent = TabContainer,
                BackgroundColor3 = theme.ElementBackground,
                Size = UDim2.new(1, 0, 0, desc == "" and 42 or 55),
                ClipsDescendants = true,
                ZIndex = 4
            })
            Create("UICorner", { Parent = DdFrame, CornerRadius = UDim.new(0, 6) })
            Create("UIStroke", { Parent = DdFrame, Color = theme.StrokeColor, Thickness = 1 })
            
            local DdBtn = Create("TextButton", {
                Parent = DdFrame,
                BackgroundTransparency = 1,
                Size = UDim2.new(1, 0, 0, desc == "" and 42 or 55),
                Text = "",
                ZIndex = 5
            })
            
            Create("TextLabel", {
                Parent = DdBtn,
                BackgroundTransparency = 1,
                Size = UDim2.new(1, -120, 0, 20),
                Position = UDim2.new(0, 15, 0, desc == "" and 11 or 8),
                Font = Enum.Font.GothamMedium,
                Text = title,
                TextColor3 = theme.Text,
                TextSize = 14,
                TextXAlignment = Enum.TextXAlignment.Left,
                ZIndex = 6
            })
            
            local SelLbl = Create("TextLabel", {
                Parent = DdBtn,
                BackgroundTransparency = 1,
                Size = UDim2.new(0, 100, 0, 20),
                Position = UDim2.new(1, -135, 0, desc == "" and 11 or 8),
                Font = Enum.Font.Gotham,
                Text = "None",
                TextColor3 = theme.SubText,
                TextSize = 13,
                TextXAlignment = Enum.TextXAlignment.Right,
                ZIndex = 6
            })
            
            local DropIcon = Create("ImageLabel", {
                Parent = DdBtn,
                BackgroundTransparency = 1,
                Size = UDim2.new(0, 16, 0, 16),
                Position = UDim2.new(1, -25, 0.5, 0),
                AnchorPoint = Vector2.new(0, 0.5),
                Image = DevLib:GetIcon("chevron-down") ~= "" and DevLib:GetIcon("chevron-down") or "rbxassetid://10709790948",
                ImageColor3 = theme.SubText,
                ZIndex = 6
            })
            
            if desc ~= "" then
                Create("TextLabel", {
                    Parent = DdBtn,
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, -120, 0, 15),
                    Position = UDim2.new(0, 15, 0, 28),
                    Font = Enum.Font.Gotham,
                    Text = desc,
                    TextColor3 = theme.SubText,
                    TextSize = 12,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    ZIndex = 6
                })
            end
            
            local ListScroll = Create("ScrollingFrame", {
                Parent = DdFrame,
                BackgroundTransparency = 1,
                Size = UDim2.new(1, -10, 0, 120),
                Position = UDim2.new(0, 5, 0, desc == "" and 47 or 60),
                ScrollBarThickness = 2,
                CanvasSize = UDim2.new(0,0,0,0),
                AutomaticCanvasSize = Enum.AutomaticSize.Y,
                ZIndex = 6
            })
            
            Create("UIListLayout", { Parent = ListScroll, Padding = UDim.new(0, 4) })

            local DdObj = { Value = selected }
            local changeCb = cb
            
            local function upVis()
                if multi then
                    local arr = {}
                    for k,v in pairs(selected) do
                        if v then table.insert(arr, k) end
                    end
                    SelLbl.Text = #arr > 0 and table.concat(arr, ", ") or "None"
                else
                    SelLbl.Text = tostring(selected or "None")
                end
                DdObj.Value = selected
                DevLib.Flags[id] = selected
                if changeCb then
                    pcall(function() changeCb(selected) end)
                end
            end

            function DdObj:Refresh(newVals)
                values = newVals
                for _,c in pairs(ListScroll:GetChildren()) do
                    if c:IsA("TextButton") then
                        c:Destroy()
                    end
                end
                
                for _, v in ipairs(values) do
                    local isSel = multi and selected[v] or (not multi and selected == v)
                    local btn = Create("TextButton", {
                        Parent = ListScroll,
                        BackgroundColor3 = isSel and theme.Accent or theme.TabBackground,
                        Size = UDim2.new(1, -10, 0, 30),
                        Text = "",
                        AutoButtonColor = false,
                        ZIndex = 7
                    })
                    Create("UICorner", { Parent = btn, CornerRadius = UDim.new(0, 4) })
                    
                    local btnLbl = Create("TextLabel", {
                        Parent = btn,
                        BackgroundTransparency = 1,
                        Size = UDim2.new(1, -20, 1, 0),
                        Position = UDim2.new(0, 10, 0, 0),
                        Font = Enum.Font.Gotham,
                        Text = tostring(v),
                        TextColor3 = isSel and Color3.new(1,1,1) or theme.Text,
                        TextSize = 13,
                        TextXAlignment = Enum.TextXAlignment.Left,
                        ZIndex = 8
                    })
                    
                    btn.MouseButton1Click:Connect(function()
                        if multi then
                            selected[v] = not selected[v]
                            btn.BackgroundColor3 = selected[v] and theme.Accent or theme.TabBackground
                            btnLbl.TextColor3 = selected[v] and Color3.new(1,1,1) or theme.Text
                        else
                            selected = v
                            for _,c in pairs(ListScroll:GetChildren()) do
                                if c:IsA("TextButton") then
                                    c.BackgroundColor3 = theme.TabBackground
                                    local l = c:FindFirstChildWhichIsA("TextLabel")
                                    if l then l.TextColor3 = theme.Text end
                                end
                            end
                            btn.BackgroundColor3 = theme.Accent
                            btnLbl.TextColor3 = Color3.new(1,1,1)
                            isOpen = false
                            Tween(DdFrame, {Size=UDim2.new(1,0,0,desc=="" and 42 or 55)}, 0.3)
                            Tween(DropIcon, {Rotation=0}, 0.3)
                        end
                        upVis()
                    end)
                end
            end

            function DdObj:SetValue(val)
                if multi and type(val) == "table" then
                    for k,v in pairs(val) do
                        selected[k] = v
                    end
                else
                    selected = val
                end
                self:Refresh(values)
                upVis()
            end
            
            function DdObj:OnChanged(newCb)
                changeCb = newCb
            end

            DdBtn.MouseButton1Click:Connect(function()
                isOpen = not isOpen
                Tween(DdFrame, {Size = isOpen and UDim2.new(1, 0, 0, (desc=="" and 42 or 55) + 130) or UDim2.new(1, 0, 0, desc=="" and 42 or 55)}, 0.3, Enum.EasingStyle.Exponential)
                Tween(DropIcon, {Rotation = isOpen and 180 or 0}, 0.3)
            end)

            DdObj:Refresh(values)
            upVis()
            
            DevLib.Flags[id] = selected
            DevLib.Options[id] = DdObj
            return DdObj
        end

        function TabObj:AddColorpicker(id, options)
            id, options = getId(id, options)
            local title = options.Title or "Colorpicker"
            local desc = options.Description or ""
            local default = options.Default or Color3.new(1,1,1)
            local cb = options.Callback or function() end
            local hasTransp = options.Transparency ~= nil
            local transp = options.Transparency or 0
            local color = default
            local h,s,v = Color3.toHSV(color)
            local isOpen = false

            local CpFrame = Create("Frame", {
                Parent = TabContainer,
                BackgroundColor3 = theme.ElementBackground,
                Size = UDim2.new(1, 0, 0, desc == "" and 42 or 55),
                ClipsDescendants = true,
                ZIndex = 4
            })
            Create("UICorner", { Parent = CpFrame, CornerRadius = UDim.new(0, 6) })
            Create("UIStroke", { Parent = CpFrame, Color = theme.StrokeColor, Thickness = 1 })
            
            local CpBtn = Create("TextButton", {
                Parent = CpFrame,
                BackgroundTransparency = 1,
                Size = UDim2.new(1, 0, 0, desc == "" and 42 or 55),
                Text = "",
                ZIndex = 5
            })
            
            Create("TextLabel", {
                Parent = CpBtn,
                BackgroundTransparency = 1,
                Size = UDim2.new(1, -80, 0, 20),
                Position = UDim2.new(0, 15, 0, desc == "" and 11 or 8),
                Font = Enum.Font.GothamMedium,
                Text = title,
                TextColor3 = theme.Text,
                TextSize = 14,
                TextXAlignment = Enum.TextXAlignment.Left,
                ZIndex = 6
            })
            
            local DispColor = Create("Frame", {
                Parent = CpBtn,
                BackgroundColor3 = color,
                BackgroundTransparency = transp,
                Size = UDim2.new(0, 36, 0, 20),
                Position = UDim2.new(1, -55, 0.5, 0),
                AnchorPoint = Vector2.new(0, 0.5),
                ZIndex = 6
            })
            Create("UICorner", { Parent = DispColor, CornerRadius = UDim.new(0, 4) })
            Create("UIStroke", { Parent = DispColor, Color = theme.StrokeColor, Thickness = 1 })
            
            if desc ~= "" then
                Create("TextLabel", {
                    Parent = CpBtn,
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, -80, 0, 15),
                    Position = UDim2.new(0, 15, 0, 28),
                    Font = Enum.Font.Gotham,
                    Text = desc,
                    TextColor3 = theme.SubText,
                    TextSize = 12,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    ZIndex = 6
                })
            end
            
            local DropArea = Create("Frame", {
                Parent = CpFrame,
                BackgroundTransparency = 1,
                Size = UDim2.new(1, -30, 0, 140),
                Position = UDim2.new(0, 15, 0, desc == "" and 50 or 65),
                ZIndex = 5
            })
            
            local SatVal = Create("TextButton", {
                Parent = DropArea,
                BackgroundColor3 = Color3.fromHSV(h,1,1),
                Size = UDim2.new(1, -30, 0, 100),
                Text = "",
                AutoButtonColor = false,
                ZIndex = 6
            })
            Create("UICorner", { Parent = SatVal, CornerRadius = UDim.new(0, 4) })
            Create("UIGradient", {
                Parent = SatVal,
                Color = ColorSequence.new({
                    ColorSequenceKeypoint.new(0, Color3.new(1,1,1)),
                    ColorSequenceKeypoint.new(1, Color3.new(1,1,1))
                }),
                Transparency = NumberSequence.new({
                    NumberSequenceKeypoint.new(0,0),
                    NumberSequenceKeypoint.new(1,1)
                })
            })
            
            local SatValShadow = Create("Frame", {
                Parent = SatVal,
                BackgroundColor3 = Color3.new(0,0,0),
                Size = UDim2.new(1,0,1,0),
                ZIndex = 7
            })
            Create("UICorner", { Parent = SatValShadow, CornerRadius = UDim.new(0,4) })
            Create("UIGradient", {
                Parent = SatValShadow,
                Rotation = 90,
                Transparency = NumberSequence.new({
                    NumberSequenceKeypoint.new(0,1),
                    NumberSequenceKeypoint.new(1,0)
                })
            })
            
            local Hue = Create("TextButton", {
                Parent = DropArea,
                Size = UDim2.new(0, 20, 0, 100),
                Position = UDim2.new(1, -20, 0, 0),
                Text = "",
                AutoButtonColor = false,
                ZIndex = 6
            })
            Create("UICorner", { Parent = Hue, CornerRadius = UDim.new(0, 4) })
            Create("UIGradient", {
                Parent = Hue,
                Rotation = 90,
                Color = ColorSequence.new({
                    ColorSequenceKeypoint.new(0, Color3.new(1,0,0)),
                    ColorSequenceKeypoint.new(0.16, Color3.new(1,1,0)),
                    ColorSequenceKeypoint.new(0.33, Color3.new(0,1,0)),
                    ColorSequenceKeypoint.new(0.5, Color3.new(0,1,1)),
                    ColorSequenceKeypoint.new(0.66, Color3.new(0,0,1)),
                    ColorSequenceKeypoint.new(0.83, Color3.new(1,0,1)),
                    ColorSequenceKeypoint.new(1, Color3.new(1,0,0))
                })
            })

            local TranspSlider = nil
            if hasTransp then
                TranspSlider = Create("TextButton", {
                    Parent = DropArea,
                    BackgroundColor3 = Color3.new(1,1,1),
                    Size = UDim2.new(1, 0, 0, 15),
                    Position = UDim2.new(0, 0, 0, 115),
                    Text = "",
                    AutoButtonColor = false,
                    ZIndex = 6
                })
                Create("UICorner", { Parent = TranspSlider, CornerRadius = UDim.new(0, 4) })
                Create("UIGradient", {
                    Parent = TranspSlider,
                    Color = ColorSequence.new({
                        ColorSequenceKeypoint.new(0, Color3.new(1,1,1)),
                        ColorSequenceKeypoint.new(1, Color3.new(0,0,0))
                    })
                })
            end

            local CpObj = { Value = color, Transparency = transp }
            local changeCb = cb

            local function updateVis()
                color = Color3.fromHSV(h,s,v)
                DispColor.BackgroundColor3 = color
                DispColor.BackgroundTransparency = transp
                SatVal.BackgroundColor3 = Color3.fromHSV(h,1,1)
                CpObj.Value = color
                CpObj.Transparency = transp
                DevLib.Flags[id] = {R = color.R, G = color.G, B = color.B, T = transp}
                if changeCb then
                    pcall(function() changeCb(color, transp) end)
                end
            end

            function CpObj:SetValueRGB(c)
                color = c
                h,s,v = Color3.toHSV(c)
                updateVis()
            end
            
            function CpObj:OnChanged(newCb)
                changeCb = newCb
            end

            local ds, dh, dt = false, false, false
            
            SatVal.InputBegan:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 then ds = true end
            end)
            
            Hue.InputBegan:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 then dh = true end
            end)
            
            if hasTransp then
                TranspSlider.InputBegan:Connect(function(i)
                    if i.UserInputType == Enum.UserInputType.MouseButton1 then dt = true end
                end)
            end

            local conn1 = UserInputService.InputEnded:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 then
                    ds = false
                    dh = false
                    dt = false
                end
            end)
            
            local conn2 = UserInputService.InputChanged:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseMovement then
                    if ds then
                        s = math.clamp((i.Position.X - SatVal.AbsolutePosition.X)/SatVal.AbsoluteSize.X,0,1)
                        v = 1 - math.clamp((i.Position.Y - SatVal.AbsolutePosition.Y)/SatVal.AbsoluteSize.Y,0,1)
                        updateVis()
                    end
                    if dh then
                        h = 1 - math.clamp((i.Position.Y - Hue.AbsolutePosition.Y)/Hue.AbsoluteSize.Y,0,1)
                        updateVis()
                    end
                    if dt and hasTransp then
                        transp = math.clamp((i.Position.X - TranspSlider.AbsolutePosition.X)/TranspSlider.AbsoluteSize.X,0,1)
                        updateVis()
                    end
                end
            end)
            
            table.insert(DevLib.Connections, conn1)
            table.insert(DevLib.Connections, conn2)

            CpBtn.MouseButton1Click:Connect(function()
                isOpen = not isOpen
                Tween(CpFrame, {Size = isOpen and UDim2.new(1,0,0, (desc=="" and 42 or 55) + 150) or UDim2.new(1,0,0,desc=="" and 42 or 55)}, 0.3, Enum.EasingStyle.Exponential)
            end)

            DevLib.Flags[id] = {R = color.R, G = color.G, B = color.B, T = transp}
            DevLib.Options[id] = CpObj
            return CpObj
        end

        function TabObj:AddKeybind(id, options)
            id, options = getId(id, options)
            local title = options.Title or "Keybind"
            local desc = options.Description or ""
            local mode = options.Mode or "Toggle"
            local default = options.Default or "None"
            
            if type(default) == "string" and default ~= "None" then
                default = Enum.KeyCode[default] or Enum.UserInputType[default] or Enum.KeyCode.Unknown
            end
            
            local key = default
            local cb = options.Callback or function() end
            local changeCb = options.ChangedCallback or function() end
            
            local KbFrame = Create("Frame", {
                Parent = TabContainer,
                BackgroundColor3 = theme.ElementBackground,
                Size = UDim2.new(1, 0, 0, desc == "" and 42 or 55),
                ZIndex = 4
            })
            Create("UICorner", { Parent = KbFrame, CornerRadius = UDim.new(0, 6) })
            Create("UIStroke", { Parent = KbFrame, Color = theme.StrokeColor, Thickness = 1 })
            
            Create("TextLabel", {
                Parent = KbFrame,
                BackgroundTransparency = 1,
                Size = UDim2.new(1, -120, 0, 20),
                Position = UDim2.new(0, 15, 0, desc == "" and 11 or 8),
                Font = Enum.Font.GothamMedium,
                Text = title,
                TextColor3 = theme.Text,
                TextSize = 14,
                TextXAlignment = Enum.TextXAlignment.Left,
                ZIndex = 5
            })
            
            if desc ~= "" then
                Create("TextLabel", {
                    Parent = KbFrame,
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, -120, 0, 15),
                    Position = UDim2.new(0, 15, 0, 28),
                    Font = Enum.Font.Gotham,
                    Text = desc,
                    TextColor3 = theme.SubText,
                    TextSize = 12,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    ZIndex = 5
                })
            end
            
            local BindBtn = Create("TextButton", {
                Parent = KbFrame,
                BackgroundColor3 = theme.TabBackground,
                Size = UDim2.new(0, 80, 0, 26),
                Position = UDim2.new(1, -95, 0.5, 0),
                AnchorPoint = Vector2.new(0, 0.5),
                Text = key == Enum.KeyCode.Unknown and "None" or key.Name,
                Font = Enum.Font.Gotham,
                TextColor3 = theme.Text,
                TextSize = 13,
                AutoButtonColor = false,
                ZIndex = 5
            })
            Create("UICorner", { Parent = BindBtn, CornerRadius = UDim.new(0, 4) })
            local BindStroke = Create("UIStroke", { Parent = BindBtn, Color = theme.StrokeColor, Thickness = 1 })

            local KbObj = { Value = key, State = false }
            local clickCb = cb
            local binding = false

            function KbObj:SetValue(newKey, newMode)
                if type(newKey) == "string" then
                    newKey = Enum.KeyCode[newKey] or Enum.UserInputType[newKey] or Enum.KeyCode.Unknown
                end
                key = newKey
                if newMode then mode = newMode end
                BindBtn.Text = key == Enum.KeyCode.Unknown and "None" or key.Name
                self.Value = key
                DevLib.Flags[id] = key.Name
                if changeCb then
                    pcall(function() changeCb(key) end)
                end
            end
            
            function KbObj:GetState() return self.State end
            function KbObj:OnClick(c) clickCb = c end
            function KbObj:OnChanged(c) changeCb = c end

            BindBtn.MouseButton1Click:Connect(function()
                binding = true
                BindBtn.Text = "..."
                Tween(BindStroke, {Color=theme.Accent}, 0.2)
            end)

            local conn1 = UserInputService.InputBegan:Connect(function(input, gpe)
                if binding then
                    if input.KeyCode == Enum.KeyCode.Escape or input.KeyCode == Enum.KeyCode.Backspace then
                        KbObj:SetValue(Enum.KeyCode.Unknown)
                    elseif input.UserInputType == Enum.UserInputType.Keyboard then
                        KbObj:SetValue(input.KeyCode)
                    elseif input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.MouseButton2 or input.UserInputType == Enum.UserInputType.MouseButton3 then
                        KbObj:SetValue(input.UserInputType)
                    end
                    binding = false
                    Tween(BindStroke, {Color=theme.StrokeColor}, 0.2)
                elseif not gpe and (input.KeyCode == key or input.UserInputType == key) then
                    if mode == "Toggle" then
                        KbObj.State = not KbObj.State
                        if clickCb then pcall(function() clickCb(KbObj.State) end) end
                    elseif mode == "Hold" then
                        KbObj.State = true
                        if clickCb then pcall(function() clickCb(true) end) end
                    elseif mode == "Always" then
                        if clickCb then pcall(function() clickCb(true) end) end
                    end
                end
            end)
            
            local conn2 = UserInputService.InputEnded:Connect(function(input, gpe)
                if not binding and not gpe and mode == "Hold" and (input.KeyCode == key or input.UserInputType == key) then
                    KbObj.State = false
                    if clickCb then pcall(function() clickCb(false) end) end
                end
            end)
            
            table.insert(DevLib.Connections, conn1)
            table.insert(DevLib.Connections, conn2)

            DevLib.Flags[id] = key.Name
            DevLib.Options[id] = KbObj
            return KbObj
        end

        function TabObj:AddInput(id, options)
            id, options = getId(id, options)
            local title = options.Title or "Input"
            local desc = options.Description or ""
            local default = options.Default or ""
            local placeholder = options.Placeholder or "Type here..."
            local numeric = options.Numeric or false
            local finished = options.Finished or false
            local cb = options.Callback or function() end

            local InpFrame = Create("Frame", {
                Parent = TabContainer,
                BackgroundColor3 = theme.ElementBackground,
                Size = UDim2.new(1, 0, 0, desc == "" and 42 or 55),
                ZIndex = 4
            })
            Create("UICorner", { Parent = InpFrame, CornerRadius = UDim.new(0, 6) })
            Create("UIStroke", { Parent = InpFrame, Color = theme.StrokeColor, Thickness = 1 })
            
            Create("TextLabel", {
                Parent = InpFrame,
                BackgroundTransparency = 1,
                Size = UDim2.new(0.4, 0, 0, 20),
                Position = UDim2.new(0, 15, 0, desc == "" and 11 or 8),
                Font = Enum.Font.GothamMedium,
                Text = title,
                TextColor3 = theme.Text,
                TextSize = 14,
                TextXAlignment = Enum.TextXAlignment.Left,
                ZIndex = 5
            })
            
            if desc ~= "" then
                Create("TextLabel", {
                    Parent = InpFrame,
                    BackgroundTransparency = 1,
                    Size = UDim2.new(0.4, 0, 0, 15),
                    Position = UDim2.new(0, 15, 0, 28),
                    Font = Enum.Font.Gotham,
                    Text = desc,
                    TextColor3 = theme.SubText,
                    TextSize = 12,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    ZIndex = 5
                })
            end

            local TextBox = Create("TextBox", {
                Parent = InpFrame,
                BackgroundColor3 = theme.TabBackground,
                Size = UDim2.new(0.5, -15, 0, 26),
                Position = UDim2.new(0.5, 0, 0.5, 0),
                AnchorPoint = Vector2.new(0, 0.5),
                Font = Enum.Font.Gotham,
                Text = default,
                TextColor3 = theme.Text,
                TextSize = 13,
                PlaceholderText = placeholder,
                ClearTextOnFocus = false,
                ZIndex = 5
            })
            Create("UICorner", { Parent = TextBox, CornerRadius = UDim.new(0, 4) })
            Create("UIStroke", { Parent = TextBox, Color = theme.StrokeColor, Thickness = 1 })

            local InpObj = { Value = default }
            local changeCb = cb

            function InpObj:SetValue(val)
                self.Value = val
                TextBox.Text = tostring(val)
                DevLib.Flags[id] = val
                if changeCb then
                    pcall(function() changeCb(val) end)
                end
            end
            
            function InpObj:OnChanged(newCb)
                changeCb = newCb
            end

            local function handleInput()
                local txt = TextBox.Text
                if numeric and not tonumber(txt) and txt ~= "" then
                    txt = InpObj.Value
                    TextBox.Text = tostring(txt)
                end
                InpObj:SetValue(txt)
            end

            TextBox.FocusLost:Connect(function(enter)
                if finished and not enter then return end
                handleInput()
            end)
            
            if not finished then
                TextBox:GetPropertyChangedSignal("Text"):Connect(handleInput)
            end

            DevLib.Flags[id] = default
            DevLib.Options[id] = InpObj
            return InpObj
        end

        -- ====================================================================
        -- 🌐 WIDGETS AVANÇADOS (Terminal, Console, Logs, Monitor)
        -- ====================================================================

        function TabObj:AddTerminal()
            local TermFrame = Create("Frame", {
                Parent = TabContainer,
                BackgroundColor3 = Color3.fromRGB(10,10,10),
                Size = UDim2.new(1, 0, 0, 200),
                ClipsDescendants = true,
                ZIndex = 4
            })
            Create("UICorner", { Parent = TermFrame, CornerRadius = UDim.new(0,6) })
            Create("UIStroke", { Parent = TermFrame, Color = theme.StrokeColor, Thickness = 1 })
            
            local Scroll = Create("ScrollingFrame", {
                Parent = TermFrame,
                BackgroundTransparency = 1,
                Size = UDim2.new(1,-10,1,-10),
                Position = UDim2.new(0,5,0,5),
                CanvasSize = UDim2.new(0,0,0,0),
                AutomaticCanvasSize = Enum.AutomaticSize.Y,
                ScrollBarThickness = 2,
                ZIndex = 5
            })
            Create("UIListLayout", { Parent = Scroll, Padding = UDim.new(0,2) })
            
            local obj = {}
            function obj:Log(text, color)
                Create("TextLabel", {
                    Parent = Scroll,
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1,0,0,16),
                    Font = Enum.Font.Code,
                    Text = "> " .. tostring(text),
                    TextColor3 = color or Color3.new(0,1,0),
                    TextSize = 13,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    RichText = true,
                    ZIndex = 6
                })
                task.defer(function()
                    if Scroll and Scroll.Parent then
                        Scroll.CanvasPosition = Vector2.new(0, Scroll.AbsoluteWindowSize.Y + 9999)
                    end
                end)
            end
            return obj
        end

        function TabObj:AddConsole(callback)
            local ConFrame = Create("Frame", {
                Parent = TabContainer,
                BackgroundColor3 = Color3.fromRGB(10,10,10),
                Size = UDim2.new(1, 0, 0, 230),
                ClipsDescendants = true,
                ZIndex = 4
            })
            Create("UICorner", { Parent = ConFrame, CornerRadius = UDim.new(0,6) })
            Create("UIStroke", { Parent = ConFrame, Color = theme.StrokeColor, Thickness = 1 })
            
            local Scroll = Create("ScrollingFrame", {
                Parent = ConFrame,
                BackgroundTransparency = 1,
                Size = UDim2.new(1,-10,1,-40),
                Position = UDim2.new(0,5,0,5),
                CanvasSize = UDim2.new(0,0,0,0),
                AutomaticCanvasSize = Enum.AutomaticSize.Y,
                ScrollBarThickness = 2,
                ZIndex = 5
            })
            Create("UIListLayout", { Parent = Scroll, Padding = UDim.new(0,2) })
            
            local Input = Create("TextBox", {
                Parent = ConFrame,
                BackgroundColor3 = theme.ElementBackground,
                Size = UDim2.new(1,-10,0,30),
                Position = UDim2.new(0,5,1,-35),
                Font = Enum.Font.Code,
                Text = "",
                TextColor3 = theme.Text,
                TextSize = 13,
                PlaceholderText = "Enter command...",
                ClearTextOnFocus = false,
                ZIndex = 6
            })
            Create("UICorner", { Parent = Input, CornerRadius = UDim.new(0,4) })
            Create("UIStroke", { Parent = Input, Color = theme.StrokeColor, Thickness = 1 })
            
            Input.FocusLost:Connect(function(enter)
                if enter and Input.Text ~= "" then
                    local cmd = Input.Text
                    Create("TextLabel", {
                        Parent = Scroll,
                        BackgroundTransparency = 1,
                        Size = UDim2.new(1,0,0,16),
                        Font = Enum.Font.Code,
                        Text = "$ <font color='rgb(0,255,255)'>" .. cmd .. "</font>",
                        RichText = true,
                        TextColor3 = Color3.new(1,1,1),
                        TextSize = 13,
                        TextXAlignment = Enum.TextXAlignment.Left,
                        ZIndex = 6
                    })
                    Input.Text = ""
                    if callback then
                        pcall(function() callback(cmd) end)
                    end
                    task.defer(function()
                        if Scroll and Scroll.Parent then
                            Scroll.CanvasPosition = Vector2.new(0, Scroll.AbsoluteWindowSize.Y + 9999)
                        end
                    end)
                end
            end)
            
            local obj = {}
            function obj:Print(t)
                Create("TextLabel", {
                    Parent = Scroll,
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1,0,0,16),
                    Font = Enum.Font.Code,
                    Text = tostring(t),
                    TextColor3 = Color3.new(0.8,0.8,0.8),
                    TextSize = 13,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    ZIndex = 6
                })
                task.defer(function()
                    if Scroll and Scroll.Parent then
                        Scroll.CanvasPosition = Vector2.new(0, 9999)
                    end
                end)
            end
            return obj
        end

        function TabObj:AddCodeBlock(codeStr)
