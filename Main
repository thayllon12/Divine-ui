Size = UDim2.new(1, 30, 0, 3),
Position = UDim2.new(0, -15, 1, 12),
ZIndex = 1002,
BorderSizePixel = 0
})
local ProgBar = Create("Frame", {
Parent = ProgBG,
BackgroundColor3 = theme.Accent,
Size = UDim2.new(1, 0, 1, 0),
ZIndex = 1003,
BorderSizePixel = 0
})
task.defer(function()
if notifFrame and notifFrame.Parent then
local sizeY = notifFrame.AbsoluteSize.Y
if sizeY < 10 then sizeY = 60 end
notifFrame.Size = UDim2.new(1, 0, 0, sizeY)
Tween(notifFrame, { Size = UDim2.new(1, 0, 0, sizeY) }, 0.4, Enum.EasingStyle.Back)
end
end)
local loopConn
local function endNotification()
if loopConn then loopConn:Disconnect() end
if notifFrame and notifFrame.Parent then
local sizeY = notifFrame.AbsoluteSize.Y
local t = Tween(notifFrame, { Size = UDim2.new(0, 0, 0, sizeY), BackgroundTransparency = 1 }, 0.4, Enum.EasingStyle.Quad)
if t then
t.Completed:Connect(function()
notifFrame:Destroy()
end)
end
end
end
CloseBtn.MouseButton1Click:Connect(endNotification)
loopConn = RunService.RenderStepped:Connect(function(dt)
timeLeft = timeLeft - dt
if timeLeft <= 0 then
timeLeft = 0
endNotification()
return
end
if TimeLabel and TimeLabel.Parent then
TimeLabel.Text = "[" .. tostring(math.ceil(timeLeft)) .. "s]"
end
if ProgBar and ProgBar.Parent then
ProgBar.Size = UDim2.new(timeLeft / duration, 0, 1, 0)
end
end)
end
function DevLib:CreateWindow(options)
if type(options) ~= "table" then options = {} end
local windowTitle = options.Title or "DevLib"
local windowSubTitle = options.SubTitle or "Edition"
local windowSize = options.Size or UDim2.fromOffset(600, 450)
local themeName = options.Theme or "DEV"
local useAcrylic = options.Acrylic == nil and true or options.Acrylic
local minimizeKey = options.MinimizeKey or Enum.KeyCode.RightControl
local tabWidth = options.TabWidth or 160
local keySystem = options.KeySystem or false
local keySettings = options.KeySettings or {}
local minWidth = options.MinWidth or 400
local minHeight = options.MinHeight or 300
local maxWidth = options.MaxWidth or 1600
local maxHeight = options.MaxHeight or 1200
DevLib:SetTheme(themeName)
local theme = DevLib:GetTheme()
local ScreenGui = Create("ScreenGui", {
Name = "DevLibWindow",
Parent = GUI_TARGET,
ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
ResetOnSpawn = false,
IgnoreGuiInset = true
})
local SafeDragBar = Create("Frame", {
Parent = ScreenGui,
BackgroundColor3 = Color3.fromRGB(255,255,255),
Size = UDim2.new(0, 100, 0, 6),
Position = UDim2.new(0.5, -50, 1, -10),
ZIndex = 9999,
BackgroundTransparency = 0.8
})
Create("UICorner", {Parent = SafeDragBar, CornerRadius = UDim.new(1,0)})
local Blur
if useAcrylic then
Blur = Create("BlurEffect", {
Size = 0,
Parent = Lighting
})
table.insert(DevLib.Instances, Blur)
end
local currentWidth = windowSize.X.Offset
local currentHeight = windowSize.Y.Offset
local viewSize = workspace.CurrentCamera and workspace.CurrentCamera.ViewportSize or Vector2.new(1920, 1080)
local startX = (viewSize.X - currentWidth) / 2
local startY = (viewSize.Y - currentHeight) / 2
local MainFrame = Create("Frame", {
Name = "MainFrame",
Parent = ScreenGui,
BackgroundColor3 = theme.MainBackground,
BackgroundTransparency = useAcrylic and 0.15 or 0,
Size = UDim2.new(0, currentWidth, 0, currentHeight),
Position = UDim2.new(0, startX, 0, startY),
AnchorPoint = Vector2.new(0, 0),
ClipsDescendants = true,
ZIndex = 1,
Visible = false
})
MakeDraggable(SafeDragBar, MainFrame)
Create("UICorner", { Parent = MainFrame, CornerRadius = UDim.new(0, 10) })
Create("UIStroke", { Parent = MainFrame, Color = theme.StrokeColor, Thickness = 1 })
Create("ImageLabel", {
Name = "Shadow",
Parent = MainFrame,
BackgroundTransparency = 1,
Image = "rbxassetid://6015897843",
ImageColor3 = theme.Shadow,
ImageTransparency = 0.5,
ScaleType = Enum.ScaleType.Slice,
SliceCenter = Rect.new(49, 49, 450, 450),
Size = UDim2.new(1, 40, 1, 40),
Position = UDim2.new(0, -20, 0, -20),
ZIndex = 0
})
local function OpenMainUI()
MainFrame.Visible = true
if useAcrylic and Blur then
Tween(Blur, { Size = 15 }, 0.5)
end
end
if keySystem then
local validKeys = keySettings.Keys or {"DevLib123"}
local savedKeyPath = "DevLibKey.txt"
local hasSavedKey = false
if isfile and readfile then
pcall(function()
if isfile(savedKeyPath) then
local sKey = readfile(savedKeyPath)
for _, k in pairs(validKeys) do
if k == sKey then
hasSavedKey = true
break
end
end
end
end)
end
if hasSavedKey then
OpenMainUI()
else
if useAcrylic and Blur then
Tween(Blur, { Size = 15 }, 0.5)
end
local KeyFrame = Create("Frame", {
Parent = ScreenGui,
BackgroundColor3 = theme.WindowBackground,
Size = UDim2.new(0, 400, 0, 200),
Position = UDim2.fromScale(0.5, 0.5),
AnchorPoint = Vector2.new(0.5, 0.5),
ClipsDescendants = true
})
Create("UICorner", { Parent = KeyFrame, CornerRadius = UDim.new(0, 10) })
Create("UIStroke", { Parent = KeyFrame, Color = theme.StrokeColor, Thickness = 1 })
Create("TextLabel", {
Parent = KeyFrame,
BackgroundTransparency = 1,
Size = UDim2.new(1, 0, 0, 40),
