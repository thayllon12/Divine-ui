function WindowObj:Minimize()
self.IsMinimized = true
btnExp.Visible = false
btnSet.Visible = false
TitleLabel.Visible = true
SubTitleLabel.Visible = false
Sidebar.Visible = false
ContentContainer.Visible = false
Tween(MainFrame, { Size = UDim2.new(0, 180, 0, 40) }, 0.4, Enum.EasingStyle.Exponential)
imgMin.Image = IconMaxAsset
if useAcrylic and Blur then
Tween(Blur, { Size = 0 }, 0.4)
end
end
function WindowObj:Maximize()
self.IsMinimized = false
btnExp.Visible = true
btnSet.Visible = true
SubTitleLabel.Visible = true
Sidebar.Visible = true
ContentContainer.Visible = true
Tween(MainFrame, { Size = UDim2.new(0, currentWidth, 0, currentHeight) }, 0.4, Enum.EasingStyle.Exponential)
imgMin.Image = IconMinAsset
if useAcrylic and Blur then
Tween(Blur, { Size = 15 }, 0.4)
end
end
btnMin.MouseButton1Click:Connect(function()
if WindowObj.IsMinimized then
WindowObj:Maximize()
else
WindowObj:Minimize()
end
end)
local isExpanded = false
local preExpandWidth = currentWidth
btnExp.MouseButton1Click:Connect(function()
isExpanded = not isExpanded
if isExpanded then
preExpandWidth = currentWidth
currentWidth = math.min(currentWidth + 300, 800)
else
currentWidth = preExpandWidth
end
local vSize = workspace.CurrentCamera and workspace.CurrentCamera.ViewportSize or Vector2.new(1920, 1080)
local nX = (vSize.X - currentWidth) / 2
local nY = (vSize.Y - currentHeight) / 2
Tween(MainFrame, {
Size = UDim2.new(0, currentWidth, 0, currentHeight),
Position = UDim2.new(0, nX, 0, nY)
}, 0.4, Enum.EasingStyle.Exponential)
end)
