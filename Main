Position = UDim2.fromScale(0.5, 0.5),
AnchorPoint = Vector2.new(0.5, 0.5),
BorderSizePixel = 0,
ZIndex = 5
})
local DivObj = {}
function DivObj:SetVisible(vis)
DivFrame.Visible = vis
end
return DivObj
end

