        function TabObj:AddCounter(title)
            local count = 0
            local F = Create("Frame", { Parent = TabContainer, BackgroundColor3=theme.ElementBackground, Size=UDim2.new(1, 0, 0, 55) }, { Create("UICorner", { CornerRadius=UDim.new(0,6) }), Create("UIStroke", { Color=theme.StrokeColor, Thickness=1 }) })
            Create("TextLabel", { Parent = F, BackgroundTransparency=1, Size=UDim2.new(0.5,0,1,0), Position=UDim2.new(0,15,0,0), Font=Enum.Font.GothamMedium, Text=title, TextColor3=theme.Text, TextSize=14, TextXAlignment=Enum.TextXAlignment.Left })
            local BtnM = Create("TextButton", { Parent = F, BackgroundColor3=theme.TabBackground, Size=UDim2.new(0,34,0,34), Position=UDim2.new(1,-120,0.5,0), AnchorPoint=Vector2.new(0,0.5), Font=Enum.Font.GothamBold, Text="-", TextColor3=theme.Text, TextSize=18 }, { Create("UICorner", { CornerRadius=UDim.new(0,6) }), Create("UIStroke", { Color=theme.StrokeColor, Thickness=1 }) })
            local Lbl = Create("TextLabel", { Parent = F, BackgroundTransparency=1, Size=UDim2.new(0,40,1,0), Position=UDim2.new(1,-80,0,0), Font=Enum.Font.GothamBold, Text="0", TextColor3=theme.Accent, TextSize=18 })
            local BtnP = Create("TextButton", { Parent = F, BackgroundColor3=theme.TabBackground, Size=UDim2.new(0,34,0,34), Position=UDim2.new(1,-40,0.5,0), AnchorPoint=Vector2.new(0,0.5), Font=Enum.Font.GothamBold, Text="+", TextColor3=theme.Text, TextSize=18 }, { Create("UICorner", { CornerRadius=UDim.new(0,6) }), Create("UIStroke", { Color=theme.StrokeColor, Thickness=1 }) })
            BtnM.MouseButton1Click:Connect(function() count = count - 1 Lbl.Text = tostring(count) end)
            BtnP.MouseButton1Click:Connect(function() count = count + 1 Lbl.Text = tostring(count) end)
        end

        function TabObj:AddFPSCounter()
            local F = TabObj:AddStatistic("FPS", "0")
            local last = tick()
            local conn = RunService.RenderStepped:Connect(function()
                local n = tick()
                if not F or not WindowObj.Main.Parent then return end -- se destruido
                F:SetValue(math.floor(1 / (n - last)))
                last = n
            end)
            table.insert(DevLib.Connections, conn)
        end

