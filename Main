        function TabObj:AddMusicPlayer(soundId)
            local S = Create("Sound", { Parent = CoreGui, SoundId = soundId, Looped = true })
            local F = Create("Frame", { Parent = TabContainer, BackgroundColor3=theme.ElementBackground, Size=UDim2.new(1,0,0,60) }, { Create("UICorner", { CornerRadius=UDim.new(0,6) }) })
            local B = Create("TextButton", { Parent = F, BackgroundColor3=theme.Accent, Size=UDim2.new(0,40,0,40), Position=UDim2.new(0,10,0,10), Font=Enum.Font.GothamBold, Text="▶", TextColor3=Color3.new(1,1,1), TextSize=18 }, { Create("UICorner", { CornerRadius=UDim.new(0,6) }) })
            local playing = false
            B.MouseButton1Click:Connect(function() playing = not playing if playing then S:Play() B.Text="⏸" else S:Pause() B.Text="▶" end end)
            Create("TextLabel", { Parent = F, BackgroundTransparency=1, Size=UDim2.new(1,-70,1,0), Position=UDim2.new(0,60,0,0), Font=Enum.Font.GothamMedium, Text="Audio Player", TextColor3=theme.Text, TextSize=14, TextXAlignment=Enum.TextXAlignment.Left })
            return { Destroy = function() S:Destroy() end }
        end
        TabObj.AddAudioPlayer = TabObj.AddMusicPlayer

