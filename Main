-- Inject Language Metadata (Flags)
DevLib.Translations["pt-BR"]["pt-BR"] = "🇧🇷 Português (Brasil)"
DevLib.Translations["en-US"]["en-US"] = "🇺🇸 English"
DevLib.Translations["es-ES"]["es-ES"] = "🇪🇸 Español"
DevLib.Translations["fr-FR"]["fr-FR"] = "🇫🇷 Français"
DevLib.Translations["de-DE"]["de-DE"] = "🇩🇪 Deutsch"
DevLib.Translations["ru-RU"]["ru-RU"] = "🇷🇺 Русский"
DevLib.Translations["ja-JP"]["ja-JP"] = "🇯🇵 日本語"
DevLib.Translations["zh-CN"]["zh-CN"] = "🇨🇳 中文"
DevLib.Translations["ko-KR"]["ko-KR"] = "🇰🇷 한국어"

function DevLib:Translate(key)
    local langData = DevLib.Translations[DevLib.CurrentLanguage]
    if langData and langData[key] then return langData[key] end
    return (DevLib.Translations["en-US"] and DevLib.Translations["en-US"][key]) or key
end

function DevLib:SetLanguage(langCode)
    if DevLib.Translations[langCode] then
        DevLib.CurrentLanguage = langCode
        for labelObj, keyInfo in pairs(DevLib.ActiveLabels) do
            if labelObj and labelObj.Parent then
                local tText = DevLib:Translate(keyInfo.Key)
                if keyInfo.Format then
                    labelObj[keyInfo.Property] = string.gsub(keyInfo.Format, "{T}", tText)
                else
                    labelObj[keyInfo.Property] = tText
                end
            else
                DevLib.ActiveLabels[labelObj] = nil
            end
        end
    end
end

