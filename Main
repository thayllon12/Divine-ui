local grabThick = 8
local function createResizeHandle(name, size, pos)
local h = Create("TextButton", {
Name = name,
Parent = MainFrame,
Size = size,
Position = pos,
BackgroundTransparency = 1,
Text = "",
ZIndex = 100,
Active = true
})
return h
end
local handles = {
Top = createResizeHandle("ResizeTop", UDim2.new(1, -grabThick*2, 0, grabThick), UDim2.new(0, grabThick, 0, 0)),
Bottom = createResizeHandle("ResizeBottom", UDim2.new(1, -grabThick*2, 0, grabThick), UDim2.new(0, grabThick, 1, -grabThick)),
Left = createResizeHandle("ResizeLeft", UDim2.new(0, grabThick, 1, -grabThick*2), UDim2.new(0, 0, 0, grabThick)),
Right = createResizeHandle("ResizeRight", UDim2.new(0, grabThick, 1, -grabThick*2), UDim2.new(1, -grabThick, 0, grabThick)),
TopLeft = createResizeHandle("ResizeTopLeft", UDim2.new(0, grabThick, 0, grabThick), UDim2.new(0, 0, 0, 0)),
TopRight = createResizeHandle("ResizeTopRight", UDim2.new(0, grabThick, 0, grabThick), UDim2.new(1, -grabThick, 0, 0)),
BottomLeft = createResizeHandle("ResizeBottomLeft", UDim2.new(0, grabThick, 0, grabThick), UDim2.new(0, 0, 1, -grabThick)),
BottomRight = createResizeHandle("ResizeBottomRight", UDim2.new(0, grabThick, 0, grabThick), UDim2.new(1, -grabThick, 1, -grabThick))
}
local resType = ""
local resStartSize, resStartPos, resStartMouse
for edge, btn in pairs(handles) do
local hc = btn.InputBegan:Connect(function(input)
if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
DevLib.IsResizing = true
resType = edge
resStartSize = MainFrame.AbsoluteSize
resStartPos = MainFrame.AbsolutePosition
resStartMouse = input.Position
end
end)
table.insert(DevLib.Connections, hc)
end
local hEnd = UserInputService.InputEnded:Connect(function(input)
if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
resType = ""
DevLib.IsResizing = false
end
end)
table.insert(DevLib.Connections, hEnd)
local hChg = UserInputService.InputChanged:Connect(function(input)
if resType ~= "" and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
if WindowObj.IsMinimized then return end
local delta = input.Position - resStartMouse
local nW, nH = resStartSize.X, resStartSize.Y
local nX, nY = resStartPos.X, resStartPos.Y
if string.find(resType, "Right") then
nW = math.clamp(resStartSize.X + delta.X, minWidth, maxWidth)
elseif string.find(resType, "Left") then
nW = math.clamp(resStartSize.X - delta.X, minWidth, maxWidth)
nX = resStartPos.X + (resStartSize.X - nW)
end
if string.find(resType, "Bottom") then
nH = math.clamp(resStartSize.Y + delta.Y, minHeight, maxHeight)
elseif string.find(resType, "Top") then
nH = math.clamp(resStartSize.Y - delta.Y, minHeight, maxHeight)
nY = resStartPos.Y + (resStartSize.Y - nH)
end
currentWidth = nW
currentHeight = nH
MainFrame.Size = UDim2.new(0, nW, 0, nH)
MainFrame.Position = UDim2.new(0, nX, 0, nY)
WindowObj.OriginalSize = UDim2.new(0, nW, 0, nH)
end
end)
table.insert(DevLib.Connections, hChg)

function WindowObj:SelectTab(TabObj)
WindowObj.ActiveTab = TabObj
for _, t in pairs(WindowObj.Tabs) do
t.Container.Visible = (t == TabObj)
Tween(t.Button, {BackgroundTransparency = (t == TabObj) and 0 or 1}, 0.2)
Tween(t.Button.Title, {TextColor3 = (t == TabObj) and theme.Text or theme.SubText}, 0.2)
if t.Button:FindFirstChild("Icon") then
Tween(t.Button.Icon, {ImageColor3 = (t == TabObj) and theme.Accent or theme.SubText}, 0.2)
end
Tween(t.Button.Indicator, {Size = (t == TabObj) and UDim2.new(0, 3, 0, 20) or UDim2.new(0, 3, 0, 0)}, 0.2, Enum.EasingStyle.Back)
end
end

function WindowObj:AddTab(tabOptions)
if type(tabOptions) ~= "table" then tabOptions = {} end
local tabTitle = tabOptions.Title or "Tab"
local rawIcon = tabOptions.Icon or ""
local hasIcon = rawIcon ~= ""
local tabIcon = DevLib:GetIcon(rawIcon)

local TabButton = Create("TextButton", {
Parent = TabList,
BackgroundColor3 = theme.ElementBackground,
BackgroundTransparency = 1,
Size = UDim2.new(1, -16, 0, 34),
Text = "",
AutoButtonColor = false,
ZIndex = 4
})
Create("UICorner", {Parent = TabButton, CornerRadius = UDim.new(0, 6)})
Create("TextLabel", {
Name = "Title",
Parent = TabButton,
BackgroundTransparency = 1,
Size = UDim2.new(1, hasIcon and -40 or -20, 1, 0),
Position = UDim2.new(0, hasIcon and 35 or 15, 0, 0),
Font = Enum.Font.GothamMedium,
Text = tabTitle,
TextColor3 = theme.SubText,
TextSize = 13,
TextXAlignment = Enum.TextXAlignment.Left,
ZIndex = 5
})

local Indicator = Create("Frame", {
Name = "Indicator",
Parent = TabButton,
BackgroundColor3 = theme.Accent,
Size = UDim2.new(0, 3, 0, 0),
Position = UDim2.new(0, 0, 0.5, 0),
AnchorPoint = Vector2.new(0, 0.5),
BackgroundTransparency = 1,
ZIndex = 5
})
Create("UICorner", {Parent = Indicator, CornerRadius = UDim.new(0, 2)})

if hasIcon then
Create("ImageLabel", {
Name = "Icon",
Parent = TabButton,
BackgroundTransparency = 1,
Size = UDim2.new(0, 18, 0, 18),
Position = UDim2.new(0, 10, 0.5, 0),
AnchorPoint = Vector2.new(0, 0.5),
Image = tabIcon,
ImageColor3 = theme.SubText,
ZIndex = 5
})
end

local TabContainer = Create("ScrollingFrame", {
Name = tabTitle .. "Container",
Parent = ContentContainer,
BackgroundTransparency = 1,
Size = UDim2.new(1, 0, 1, 0),
ScrollBarThickness = 2,
ScrollBarImageColor3 = theme.StrokeColor,
Visible = false,
CanvasSize = UDim2.new(0, 0, 0, 0),
AutomaticCanvasSize = Enum.AutomaticSize.Y,
ZIndex = 3
})
Create("UIListLayout", {
Parent = TabContainer,
Padding = UDim.new(0, 10),
HorizontalAlignment = Enum.HorizontalAlignment.Center
})
Create("UIPadding", {
Parent = TabContainer,
PaddingTop = UDim.new(0, 15),
PaddingBottom = UDim.new(0, 15),
PaddingLeft = UDim.new(0, 15),
PaddingRight = UDim.new(0, 15)
})

local TabObj = {
Name = tabTitle,
Container = TabContainer,
Button = TabButton
}
TabButton.MouseButton1Click:Connect(function()
WindowObj:SelectTab(TabObj)
end)
table.insert(WindowObj.Tabs, TabObj)
if #WindowObj.Tabs == 1 then
WindowObj:SelectTab(TabObj)
end

function TabObj:AddSection(title)
title = title or "Section"
local SecFrame = Create("Frame", {
Parent = TabContainer,
BackgroundTransparency = 1,
Size = UDim2.new(1, 0, 0, 25),
ZIndex = 4
})
Create("TextLabel", {
Parent = SecFrame,
BackgroundTransparency = 1,
Size = UDim2.new(1, -10, 1, 0),
Position = UDim2.new(0, 5, 0, 0),
Font = Enum.Font.GothamBold,
Text = title,
TextColor3 = theme.Accent,
TextSize = 14,
TextXAlignment = Enum.TextXAlignment.Left,
ZIndex = 5
})
local SecObj = {}
function SecObj:SetText(newTitle)
local l = SecFrame:FindFirstChildWhichIsA("TextLabel")
if l then
l.Text = tostring(newTitle)
end
end
return SecObj
end

function TabObj:AddDivider()
