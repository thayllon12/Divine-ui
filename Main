            Create("TextLabel", { Parent = Card, BackgroundTransparency=1, Size=UDim2.new(1,-90,0,30), Position=UDim2.new(0,80,0,10), Font=Enum.Font.GothamBold, Text=player.DisplayName .. " (@"..player.Name..")", TextColor3=theme.Text, TextSize=16, TextXAlignment=Enum.TextXAlignment.Left, ZIndex=5 })
            local HealthLbl = Create("TextLabel", { Parent = Card, BackgroundTransparency=1, Size=UDim2.new(1,-90,0,30), Position=UDim2.new(0,80,0,40), Font=Enum.Font.Gotham, Text="Health: 100", TextColor3=theme.Success, TextSize=13, TextXAlignment=Enum.TextXAlignment.Left, ZIndex=5 })
            task.spawn(function()
                while Card.Parent and player.Character do
                    local hum = player.Character:FindFirstChild("Humanoid")
                    if hum then HealthLbl.Text = "Health: " .. math.floor(hum.Health) .. "/" .. math.floor(hum.MaxHealth) end
                    task.wait(0.5)
                end
            end)
        end

