                TextSize=14,
                ClearTextOnFocus=false,
                ZIndex=4
            })
            Create("UICorner", { Parent = Inp, CornerRadius=UDim.new(0,6) })
            Create("UIStroke", { Parent = Inp, Color=theme.StrokeColor, Thickness=1 })
            
            Inp.FocusLost:Connect(function(enter)
                if enter and callback then
                    pcall(function() callback(Inp.Text) end)
                    Inp.Text=""
                end
            end)
        end

        function TabObj:AddMiniWindow(title)
            local W = Create("Frame", {
                Parent = ScreenGui,
                BackgroundColor3=theme.WindowBackground,
                Size=UDim2.new(0, 300, 0, 200),
                Position=UDim2.new(0.5, 0, 0.5, 0),
                AnchorPoint=Vector2.new(0.5,0.5),
                ZIndex=100
            })
            Create("UICorner", { Parent = W, CornerRadius=UDim.new(0,8) })
            Create("UIStroke", { Parent = W, Color=theme.StrokeColor, Thickness=1 })
            
            local T = Create("TextLabel", {
                Parent = W,
                BackgroundColor3=theme.MainBackground,
                Size=UDim2.new(1, 0, 0, 35),
                Font=Enum.Font.GothamBold,
                Text="  " .. title,
                TextColor3=theme.Text,
                TextSize=14,
                TextXAlignment=Enum.TextXAlignment.Left,
                ZIndex=101
            })
            Create("UICorner", { Parent = T, CornerRadius=UDim.new(0,8) })
            
            MakeDraggable(T, W)
            
            local C = Create("Frame", {
                Parent = W,
                BackgroundTransparency=1,
                Size=UDim2.new(1, 0, 1, -35),
                Position=UDim2.new(0, 0, 0, 35),
                ZIndex=101
            })
            
            local B = Create("TextButton", {
                Parent = T,
                BackgroundTransparency=1,
                Size=UDim2.new(0,35,0,35),
                Position=UDim2.new(1,-35,0,0),
                Font=Enum.Font.GothamBold,
                Text="X",
                TextColor3=theme.Error,
                TextSize=16,
                ZIndex=102
            })
            B.MouseButton1Click:Connect(function()
                W:Destroy()
            end)
            return { Container = C, Destroy = function() W:Destroy() end }
        end
        TabObj.AddResizableFrame = TabObj.AddMiniWindow
