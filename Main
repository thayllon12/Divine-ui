        function TabObj:AddToggleGroup(togglesData, callback)
            local active = nil
            local btns = {}
            for _, d in ipairs(togglesData) do
                local t = TabObj:AddToggle(d, { Title = d, Callback = function(state)
                    if state then
                        for _, other in pairs(btns) do if other ~= t then other:SetValue(false) end end
                        active = d
                        if callback then callback(active) end
                    elseif active == d then active = nil end
                end })
                table.insert(btns, t)
            end
        end

        function TabObj:AddButtonGroup(btnsData)
            local F = Create("Frame", { Parent = TabContainer, BackgroundTransparency=1, Size=UDim2.new(1,0,0,40) })
            Create("UIListLayout", { Parent = F, FillDirection=Enum.FillDirection.Horizontal, Padding=UDim.new(0,5) })
            for _, d in ipairs(btnsData) do
                local b = Create("TextButton", { Parent = F, BackgroundColor3=theme.ElementBackground, Size=UDim2.new(1/#btnsData, -5, 1, 0), Font=Enum.Font.GothamMedium, Text=d.Name, TextColor3=theme.Text, TextSize=13 }, { Create("UICorner", { CornerRadius=UDim.new(0,6) }) })
                b.MouseButton1Click:Connect(d.Callback)
            end
        end
        TabObj.AddRadioButton = TabObj.AddToggleGroup

