            task.spawn(function()
                while F.Parent do
                    if playing and S.TimeLength > 0 then Tween(Bar, {Size=UDim2.new(S.TimePosition / S.TimeLength, 0, 1, 0)}, 0.1) end
                    task.wait(0.1)
                end
            end)
            return { Destroy = function() S:Destroy() end }
        end
