        function TabObj:AddPlayerDropdown(flag, cb)
            local plrs = {}
            for _, p in pairs(Players:GetPlayers()) do table.insert(plrs, p.Name) end
            local dd = TabObj:AddDropdown(flag, {Title = "Players", Values = plrs, Callback = cb})
            Players.PlayerAdded:Connect(function(p) table.insert(plrs, p.Name) dd:Refresh(plrs) end)
            Players.PlayerRemoving:Connect(function(p) for i,v in pairs(plrs) do if v==p.Name then table.remove(plrs,i) break end end dd:Refresh(plrs) end)
            return dd
        end

