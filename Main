        Warning = Color3.fromRGB(240, 180, 30),
        Error = Color3.fromRGB(230, 70, 70),
        Info = Color3.fromRGB(80, 160, 240)
    },

    -- O MEU TEMA (TEMA DEV SUPREMO)
    DEV = {
        MainBackground = Color3.fromRGB(5, 0, 0),
