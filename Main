        function TabObj:AddChart()
            local F = Create("Frame", { Parent = TabContainer, BackgroundColor3=theme.ElementBackground, Size=UDim2.new(1,0,0,100) }, { Create("UICorner", { CornerRadius=UDim.new(0,6) }) })
            Create("UIListLayout", { Parent = F, FillDirection=Enum.FillDirection.Horizontal, HorizontalAlignment=Enum.HorizontalAlignment.Center, VerticalAlignment=Enum.VerticalAlignment.Bottom, Padding=UDim.new(0,2) })
            return { Update = function(self, vals) 
                for _,c in pairs(F:GetChildren()) do if c:IsA("Frame") then c:Destroy() end end
                for _,v in pairs(vals) do Create("Frame", { Parent = F, BackgroundColor3=theme.Accent, Size=UDim2.new(0,10,math.clamp(v/100,0,1),0) }) end
            end }
        end
        TabObj.AddGraph = TabObj.AddChart
        TabObj.AddLineGraph = TabObj.AddChart
        TabObj.AddBarGraph = TabObj.AddChart
        TabObj.AddPieChart = TabObj.AddChart

