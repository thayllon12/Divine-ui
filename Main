        function TabObj:AddToggleGroup(togglesData, callback)
            local F = TabObj:AddFolder("Toggle Group")
            local active = nil
            local btns = {}
            for _, d in ipairs(togglesData) do
                local Btn = Create("TextButton", { Parent = F.Container, BackgroundColor3=theme.ElementBackground, Size=UDim2.new(1,0,0,30), Font=Enum.Font.GothamMedium, Text=d, TextColor3=theme.Text, TextSize=13, AutoButtonColor=false, ZIndex=6 }, { Create("UICorner", { CornerRadius=UDim.new(0,6) }), Create("UIStroke", { Color=theme.StrokeColor, Thickness=1 }) })
                Btn.MouseButton1Click:Connect(function()
                    for _, b in pairs(btns) do b.BackgroundColor3=theme.ElementBackground; b.TextColor3=theme.Text end
                    Btn.BackgroundColor3=theme.Accent; Btn.TextColor3=Color3.new(1,1,1)
                    active = d; if callback then callback(active) end
                end)
                table.insert(btns, Btn)
            end
        end
        TabObj.AddButtonGroup = TabObj.AddToggleGroup
        TabObj.AddRadioButton = TabObj.AddToggleGroup

        function TabObj:AddTimeline(events)
            local F = TabObj:AddFolder("Timeline")
            for i, e in ipairs(events) do
                local ev = Create("Frame", { Parent = F.Container, BackgroundTransparency=1, Size=UDim2.new(1,0,0,40), ZIndex=5 })
                Create("Frame", { Parent = ev, BackgroundColor3=theme.StrokeColor, Size=UDim2.new(0,2,1,0), Position=UDim2.new(0,10,0,0), ZIndex=6 })
                Create("Frame", { Parent = ev, BackgroundColor3=theme.Accent, Size=UDim2.new(0,12,0,12), Position=UDim2.new(0,5,0.5,0), AnchorPoint=Vector2.new(0,0.5), ZIndex=7 }, { Create("UICorner", { CornerRadius=UDim.new(1,0) }) })
                Create("TextLabel", { Parent = ev, BackgroundTransparency=1, Size=UDim2.new(1,-30,1,0), Position=UDim2.new(0,30,0,0), Font=Enum.Font.GothamMedium, Text=e, TextColor3=theme.Text, TextSize=13, TextXAlignment=Enum.TextXAlignment.Left, ZIndex=6 })
            end
        end

        function TabObj:AddSpoiler(text)
            local B = Create("TextButton", { Parent = TabContainer, BackgroundColor3=theme.ElementBackground, Size=UDim2.new(1, 0, 0, 40), Font=Enum.Font.GothamBold, Text="[ CLICK TO REVEAL SPOILER ]", TextColor3=theme.SubText, TextSize=13, ZIndex=4 }, { Create("UICorner", { CornerRadius=UDim.new(0,6) }), Create("UIStroke", { Color=theme.StrokeColor, Thickness=1 }) })
            B.MouseButton1Click:Connect(function() Tween(B, {BackgroundColor3 = theme.TabBackground}, 0.3); B.Text = text; B.TextColor3 = theme.Text end)
        end

        function TabObj:AddCommandBar(callback)
            local Inp = Create("TextBox", { Parent = TabContainer, BackgroundColor3=theme.ElementBackground, Size=UDim2.new(1, 0, 0, 45), Font=Enum.Font.Code, PlaceholderText="> enter command...", Text="", TextColor3=theme.Accent, TextSize=14, ClearTextOnFocus=false, ZIndex=4 }, { Create("UICorner", { CornerRadius=UDim.new(0,6) }), Create("UIStroke", { Color=theme.StrokeColor, Thickness=1 }) })
            Inp.FocusLost:Connect(function(enter) if enter and callback then callback(Inp.Text); Inp.Text="" end end)
        end

        function TabObj:AddMiniWindow(title)
            local W = Create("Frame", { Parent = ScreenGui, BackgroundColor3=theme.WindowBackground, Size=UDim2.new(0, 300, 0, 200), Position=UDim2.new(0.5, 0, 0.5, 0), AnchorPoint=Vector2.new(0.5,0.5), ZIndex=100 }, { Create("UICorner", { CornerRadius=UDim.new(0,8) }), Create("UIStroke", { Color=theme.StrokeColor, Thickness=1 }) })
            local T = Create("TextLabel", { Parent = W, BackgroundColor3=theme.MainBackground, Size=UDim2.new(1, 0, 0, 35), Font=Enum.Font.GothamBold, Text="  " .. title, TextColor3=theme.Text, TextSize=14, TextXAlignment=Enum.TextXAlignment.Left, ZIndex=101 }, { Create("UICorner", { CornerRadius=UDim.new(0,8) }) })
            MakeDraggable(T, W)
            local C = Create("Frame", { Parent = W, BackgroundTransparency=1, Size=UDim2.new(1, 0, 1, -35), Position=UDim2.new(0, 0, 0, 35), ZIndex=101 })
            local B = Create("TextButton", { Parent = T, BackgroundTransparency=1, Size=UDim2.new(0,35,0,35), Position=UDim2.new(1,-35,0,0), Font=Enum.Font.GothamBold, Text="X", TextColor3=theme.Error, TextSize=16, ZIndex=102 })
            B.MouseButton1Click:Connect(function() W:Destroy() end)
            return { Container = C, Destroy = function() W:Destroy() end }
        end
        TabObj.AddResizableFrame = TabObj.AddMiniWindow
        TabObj.AddDraggableFrame = TabObj.AddMiniWindow

        function TabObj:AddDock()
            local D = Create("Frame", { Parent = ScreenGui, BackgroundColor3=theme.MainBackground, Size=UDim2.new(0, 400, 0, 60), Position=UDim2.new(0.5, -200, 1, -80), ZIndex=100 }, { Create("UICorner", { CornerRadius=UDim.new(0,16) }), Create("UIStroke", { Color=theme.StrokeColor, Thickness=1 }) })
            Create("UIListLayout", { Parent = D, FillDirection=Enum.FillDirection.Horizontal, HorizontalAlignment=Enum.HorizontalAlignment.Center, VerticalAlignment=Enum.VerticalAlignment.Center, Padding=UDim.new(0,10) })
            MakeDraggable(D, D)
            return { Container = D }
        end
        TabObj.AddSidebar = TabObj.AddDock
        TabObj.AddTopbar = TabObj.AddDock
        TabObj.AddBottomBar = TabObj.AddDock

        function TabObj:AddBreadcrumb(pathArray)
            Create("TextLabel", { Parent = TabContainer, BackgroundTransparency=1, Size=UDim2.new(1, 0, 0, 20), Font=Enum.Font.GothamMedium, Text=table.concat(pathArray, "  <font color='rgb(100,100,100)'>></font>  "), RichText=true, TextColor3=theme.Accent, TextSize=13, TextXAlignment=Enum.TextXAlignment.Left, ZIndex=4 })
        end

        function TabObj:AddToast(text) DevLib:Notify({Title="Toast", Content=text, Duration=3}) end

        function TabObj:AddErrorBox(text)
            local F = Create("Frame", { Parent = TabContainer, BackgroundColor3=Color3.fromRGB(40,10,10), Size=UDim2.new(1, 0, 0, 50), ZIndex=4 }, { Create("UICorner", { CornerRadius=UDim.new(0,6) }), Create("UIStroke", { Color=theme.Error, Thickness=1 }) })
            Create("TextLabel", { Parent = F, BackgroundTransparency=1, Size=UDim2.new(1,-20,1,0), Position=UDim2.new(0,10,0,0), Font=Enum.Font.GothamMedium, Text="[ ERROR ] " .. text, TextColor3=theme.Error, TextSize=13, TextXAlignment=Enum.TextXAlignment.Left, ZIndex=5 })
        end
        function TabObj:AddSuccessBox(text)
            local F = Create("Frame", { Parent = TabContainer, BackgroundColor3=Color3.fromRGB(10,40,10), Size=UDim2.new(1, 0, 0, 50), ZIndex=4 }, { Create("UICorner", { CornerRadius=UDim.new(0,6) }), Create("UIStroke", { Color=theme.Success, Thickness=1 }) })
            Create("TextLabel", { Parent = F, BackgroundTransparency=1, Size=UDim2.new(1,-20,1,0), Position=UDim2.new(0,10,0,0), Font=Enum.Font.GothamMedium, Text="[ SUCCESS ] " .. text, TextColor3=theme.Success, TextSize=13, TextXAlignment=Enum.TextXAlignment.Left, ZIndex=5 })
        end
        function TabObj:AddWarningBox(text)
            local F = Create("Frame", { Parent = TabContainer, BackgroundColor3=Color3.fromRGB(40,40,10), Size=UDim2.new(1, 0, 0, 50), ZIndex=4 }, { Create("UICorner", { CornerRadius=UDim.new(0,6) }), Create("UIStroke", { Color=theme.Warning, Thickness=1 }) })
            Create("TextLabel", { Parent = F, BackgroundTransparency=1, Size=UDim2.new(1,-20,1,0), Position=UDim2.new(0,10,0,0), Font=Enum.Font.GothamMedium, Text="[ WARNING ] " .. text, TextColor3=theme.Warning, TextSize=13, TextXAlignment=Enum.TextXAlignment.Left, ZIndex=5 })
        end
        function TabObj:AddInfoBox(text)
            local F = Create("Frame", { Parent = TabContainer, BackgroundColor3=Color3.fromRGB(10,30,50), Size=UDim2.new(1, 0, 0, 50), ZIndex=4 }, { Create("UICorner", { CornerRadius=UDim.new(0,6) }), Create("UIStroke", { Color=theme.Info, Thickness=1 }) })
            Create("TextLabel", { Parent = F, BackgroundTransparency=1, Size=UDim2.new(1,-20,1,0), Position=UDim2.new(0,10,0,0), Font=Enum.Font.GothamMedium, Text="[ INFO ] " .. text, TextColor3=theme.Info, TextSize=13, TextXAlignment=Enum.TextXAlignment.Left, ZIndex=5 })
        end

        function TabObj:AddNotificationCenter()
            TabObj:AddButton({Title="Trigger Test Notification", Callback=function() DevLib:Notify({Title="Center", Content="Notification Center working perfectly!"}) end})
        end

        function TabObj:AddThemeEditor()
            local F = TabObj:AddFolder("Live Theme Editor")
            for k, v in pairs(DevLib.Themes[DevLib.CurrentTheme]) do
                if typeof(v) == "Color3" then
                    local cp = TabObj:AddColorpicker({Title = k, Default = v, Callback = function(c)
                        theme[k] = c
                        WindowObj:Maximize(); WindowObj:Minimize(); WindowObj:Maximize()
                    end})
                    cp.Parent = F.Container
                end
            end
        end
        TabObj.AddThemeCreator = TabObj.AddThemeEditor

        function TabObj:AddFontSelector() TabObj:AddDropdown({Title = "Global Font", Values = {"Gotham", "Code", "SciFi", "Arcade", "Oswald"}, Default = "Gotham"}) end
        TabObj.AddIconPicker = TabObj.AddFontSelector
        function TabObj:AddGradientEditor() TabObj:AddLabel("Gradient Editor Mocking") end
        function TabObj:AddShadowEditor() TabObj:AddSlider({Title="Shadow Opacity", Min=0, Max=100, Default=50}) end

        function TabObj:AddWatermark(text)
            Create("TextLabel", { Parent = ScreenGui, BackgroundTransparency=1, Size=UDim2.new(0, 200, 0, 30), Position=UDim2.new(1, -210, 0, 10), Font=Enum.Font.GothamBold, Text=text, TextColor3=theme.Accent, TextSize=16, TextXAlignment=Enum.TextXAlignment.Right, TextStrokeTransparency=0, ZIndex=999 })
        end

        function TabObj:AddMusicPlayer(soundId)
            local S = Create("Sound", { Parent = CoreGui, SoundId = soundId, Looped = true })
            local F = Create("Frame", { Parent = TabContainer, BackgroundColor3=theme.ElementBackground, Size=UDim2.new(1, 0, 0, 70), ZIndex=4 }, { Create("UICorner", { CornerRadius=UDim.new(0,6) }), Create("UIStroke", { Color=theme.StrokeColor, Thickness=1 }) })
            local B = Create("TextButton", { Parent = F, BackgroundColor3=theme.Accent, Size=UDim2.new(0,40,0,40), Position=UDim2.new(0,15,0,15), Font=Enum.Font.GothamBold, Text="▶", TextColor3=Color3.new(1,1,1), TextSize=18, ZIndex=5 }, { Create("UICorner", { CornerRadius=UDim.new(0,6) }) })
            local playing = false
            B.MouseButton1Click:Connect(function() playing = not playing; if playing then S:Play(); B.Text="⏸" else S:Pause(); B.Text="▶" end end)
            Create("TextLabel", { Parent = F, BackgroundTransparency=1, Size=UDim2.new(1,-80,0,20), Position=UDim2.new(0,70,0,15), Font=Enum.Font.GothamMedium, Text="Audio Track", TextColor3=theme.Text, TextSize=14, TextXAlignment=Enum.TextXAlignment.Left, ZIndex=5 })
            local BarBG = Create("Frame", { Parent = F, BackgroundColor3=theme.TabBackground, Size=UDim2.new(1,-80,0,6), Position=UDim2.new(0,70,0,45), ZIndex=5 }, { Create("UICorner", { CornerRadius=UDim.new(1,0) }) })
            local Bar = Create("Frame", { Parent = BarBG, BackgroundColor3=theme.Accent, Size=UDim2.new(0,0,1,0), ZIndex=6 }, { Create("UICorner", { CornerRadius=UDim.new(1,0) }) })
            task.spawn(function()
                while F.Parent do
                    if playing and S.TimeLength > 0 then Tween(Bar, {Size=UDim2.new(S.TimePosition / S.TimeLength, 0, 1, 0)}, 0.1) end
                    task.wait(0.1)
                end
            end)
            return { Destroy = function() S:Destroy() end }
        end
        TabObj.AddAudioPlayer = TabObj.AddMusicPlayer

        function TabObj:AddSearchBar(callback)
            TabObj:AddInput({Title = "Search Elements", Placeholder = "Type to filter...", Callback = function(txt)
                for _, child in pairs(TabContainer:GetChildren()) do
                    if child:IsA("Frame") or child:IsA("TextButton") then
                        local lbl = child:FindFirstChildWhichIsA("TextLabel", true)
                        if lbl then
                            if txt == "" or string.find(string.lower(lbl.Text), string.lower(txt)) then child.Visible = true else child.Visible = false end
                        end
                    end
                end
                if callback then callback(txt) end
            end})
        end
        TabObj.AddAutoComplete = TabObj.AddSearchBar

        function TabObj:AddDatePicker() TabObj:AddInput({Title = "Date Picker (DD/MM/YYYY)"}) end
        TabObj.AddTimePicker = TabObj.AddDatePicker
        TabObj.AddCalendar = TabObj.AddDatePicker

        function TabObj:AddPlayerDropdown(id, cb)
            local plrs = {}
            for _, p in pairs(Players:GetPlayers()) do table.insert(plrs, p.Name) end
            local dd = TabObj:AddDropdown(id, {Title = "Select Player", Values = plrs, Callback = cb})
            local c1 = Players.PlayerAdded:Connect(function(p) table.insert(plrs, p.Name); dd:Refresh(plrs) end)
            local c2 = Players.PlayerRemoving:Connect(function(p) for i,v in pairs(plrs) do if v==p.Name then table.remove(plrs,i) break end end; dd:Refresh(plrs) end)
            table.insert(DevLib.Connections, c1); table.insert(DevLib.Connections, c2)
            return dd
        end

        function TabObj:AddServerDropdown() TabObj:AddDropdown({Title = "Server List", Values = {"Server #1 [US]", "Server #2 [EU]"}}) end
        function TabObj:AddTeamDropdown() TabObj:AddDropdown({Title = "Team Selector", Values = {"Red", "Blue", "Green", "Yellow"}}) end

        function TabObj:AddTeleportButton(placeId) TabObj:AddButton({Title = "Teleport to Game", Description = "ID: " .. tostring(placeId), Callback = function() TeleportService:Teleport(placeId, LocalPlayer) end}) end

        function TabObj:AddCopyButton(textToCopy)
            TabObj:AddButton({Title = "Copy to Clipboard", Callback = function() if setclipboard then setclipboard(textToCopy) DevLib:Notify({Title="Clipboard", Content="Copied successfully!"}) else DevLib:Notify({Title="Error", Content="Executor does not support setclipboard.", Duration=3}) end end})
        end
        TabObj.AddPasteButton = TabObj.AddCopyButton
        TabObj.AddQRCode = TabObj.AddCopyButton

        function TabObj:AddChart(title, dataArray)
            local F = Create("Frame", { Parent = TabContainer, BackgroundColor3=theme.ElementBackground, Size=UDim2.new(1, 0, 0, 150), ZIndex=4 }, { Create("UICorner", { CornerRadius=UDim.new(0,6) }), Create("UIStroke", { Color=theme.StrokeColor, Thickness=1 }) })
            Create("TextLabel", { Parent = F, BackgroundTransparency=1, Size=UDim2.new(1,-20,0,20), Position=UDim2.new(0,10,0,5), Font=Enum.Font.GothamBold, Text=title or "Data Chart", TextColor3=theme.Text, TextSize=14, TextXAlignment=Enum.TextXAlignment.Left, ZIndex=5 })
            local GraphArea = Create("Frame", { Parent = F, BackgroundTransparency=1, Size=UDim2.new(1,-20,1,-40), Position=UDim2.new(0,10,0,30), ZIndex=5 })
            Create("UIListLayout", { Parent = GraphArea, FillDirection=Enum.FillDirection.Horizontal, HorizontalAlignment=Enum.HorizontalAlignment.Left, VerticalAlignment=Enum.VerticalAlignment.Bottom, Padding=UDim.new(0,4) })
            
            local function draw(arr)
                for _,c in pairs(GraphArea:GetChildren()) do if c:IsA("Frame") then c:Destroy() end end
                local max = 1; for _,v in pairs(arr) do if v > max then max = v end end
                local w = math.clamp((GraphArea.AbsoluteSize.X / #arr) - 4, 2, 40)
                for _,v in pairs(arr) do
                    local bar = Create("Frame", { Parent = GraphArea, BackgroundColor3=theme.Accent, Size=UDim2.new(0, w, 0, 0), ZIndex=6 }, { Create("UICorner", { CornerRadius=UDim.new(0,2) }) })
                    Tween(bar, {Size=UDim2.new(0, w, v/max, 0)}, 0.5, Enum.EasingStyle.Exponential)
                end
            end
            draw(dataArray or {10, 20, 50, 30, 80, 40, 90, 60})
            return { Update = function(self, arr) draw(arr) end }
        end
        TabObj.AddGraph = TabObj.AddChart
        TabObj.AddBarGraph = TabObj.AddChart
        function TabObj:AddLineGraph(title, dataArray) return TabObj:AddChart(title .. " (Line Render Mock)", dataArray) end
        TabObj.AddPieChart = TabObj.AddChart

        function TabObj:AddDataTable()
            local F = TabObj:AddFolder("Data Table")
            Create("TextLabel", { Parent = F.Container, BackgroundTransparency=1, Size=UDim2.new(1,0,0,20), Font=Enum.Font.Code, Text="ID | Name | Score\n1 | Player | 100\n2 | Guest | 50", TextColor3=theme.Text, TextSize=13, TextXAlignment=Enum.TextXAlignment.Left, TextYAlignment=Enum.TextYAlignment.Top, ZIndex=6 })
        end
        TabObj.AddSpreadsheet = TabObj.AddDataTable

        function TabObj:AddCanvas()
            local F = Create("Frame", { Parent = TabContainer, BackgroundColor3=Color3.new(1,1,1), Size=UDim2.new(1, 0, 0, 200), ClipsDescendants=true, ZIndex=4 }, { Create("UICorner", { CornerRadius=UDim.new(0,6) }) })
            local drawing = false
            F.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then drawing = true end end)
            UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then drawing = false end end)
            F.InputChanged:Connect(function(i)
                if drawing and i.UserInputType == Enum.UserInputType.MouseMovement then
                    Create("Frame", { Parent = F, BackgroundColor3=theme.Accent, Size=UDim2.new(0,6,0,6), Position=UDim2.new(0, i.Position.X - F.AbsolutePosition.X, 0, i.Position.Y - F.AbsolutePosition.Y), AnchorPoint=Vector2.new(0.5,0.5), BorderSizePixel=0, ZIndex=5 }, { Create("UICorner", { CornerRadius=UDim.new(1,0) }) })
                end
            end)
        end
        TabObj.AddDrawingBoard = TabObj.AddCanvas

        function TabObj:AddColorWheel() TabObj:AddColorpicker({Title="Color Wheel Editor"}) end
        function TabObj:AddColorPalette() TabObj:AddColorpicker({Title="Color Palette"}) end

        function TabObj:AddPinButton() TabObj:AddButton({Title="Pin Window", Callback=function() DevLib:Notify({Title="Pinned", Content="Window pinned to top!"}) end}) end
        TabObj.AddFavoriteButton = TabObj.AddPinButton
        TabObj.AddBookmark = TabObj.AddPinButton

        function TabObj:AddRecentItems() TabObj:AddDropdown({Title="Recent Files", Values={"Config1.json", "Save2.json"}}) end
        TabObj.AddHistoryPanel = TabObj.AddRecentItems

        function TabObj:AddCommandPalette() TabObj:AddCommandBar() end
        function TabObj:AddHotkeyManager() TabObj:AddKeybind({Title="Toggle Menu Hotkey"}) end
        function TabObj:AddPluginManager() TabObj:AddToggle({Title="Enable Custom Plugins"}) end
        function TabObj:AddModuleLoader() TabObj:AddButton({Title="Load URL Module"}) end

        function TabObj:AddConfigManager()
            TabObj:AddButton({Title="Save Configuration", Description="Saves your current flags to workspace", Callback=function() DevLib:SaveConfig(); DevLib:Notify({Title="Config", Content="Saved Config!"}) end})
            TabObj:AddButton({Title="Load Configuration", Description="Loads previous flags from workspace", Callback=function() DevLib:LoadConfig(); DevLib:Notify({Title="Config", Content="Loaded Config!"}) end})
        end
        TabObj.AddCloudConfig = TabObj.AddConfigManager
        TabObj.AddAutoSave = TabObj.AddConfigManager

        function TabObj:AddScriptHub() TabObj:AddButton({Title="Execute Internal Script", Callback=function() if loadstring then loadstring("print('Executed via DevLib')")() end end}) end
        function TabObj:AddExecutorInfo() TabObj:AddLabel("Running on: " .. (identifyexecutor and identifyexecutor() or "Unknown Executor")) end

        function TabObj:AddPerformanceMonitor()
            local Mem = TabObj:AddStatistic("Memory Usage", "0 MB")
            local conn = RunService.RenderStepped:Connect(function()
                if not Mem or not WindowObj.Main.Parent then return end
                Mem:SetValue(math.floor(Stats:GetTotalMemoryUsageMb()) .. " MB")
            end)
            table.insert(DevLib.Connections, conn)
        end
        TabObj.AddMemoryMonitor = TabObj.AddPerformanceMonitor
        TabObj.AddNetworkStats = TabObj.AddPerformanceMonitor

        function TabObj:AddLogger() TabObj:AddTerminal() end
        function TabObj:AddDebugPanel() TabObj:AddConsole() end
        function TabObj:AddPropertyEditor() TabObj:AddInput({Title="Property Name"}) TabObj:AddInput({Title="Property Value"}) end

        return TabObj
    end

    return WindowObj
end

