        function TabObj:AddGif(sheetUrl, frames, fps, height)
            local Img = Create("ImageLabel", { Parent = TabContainer, BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, height or 150), Image = sheetUrl, ScaleType = Enum.ScaleType.Crop, ZIndex=4 }, { Create("UICorner", { CornerRadius=UDim.new(0,6) }) })
            task.spawn(function()
                local w = Img.AbsoluteSize.X
                local i = 0
                while Img.Parent do i = (i + 1) % frames; Img.ImageRectOffset = Vector2.new(i * w, 0); Img.ImageRectSize = Vector2.new(w, Img.AbsoluteSize.Y); task.wait(1/fps) end
            end)
        end

