        end

        function TabObj:AddGif(sheetUrl, frames, fps)
            local Img = Create("ImageLabel", { Parent = TabContainer, BackgroundTransparency = 1, Size = UDim2.new(1,0,0,150), Image = sheetUrl })
            task.spawn(function()
                local i = 0
                while Img.Parent do
                    i = (i + 1) % frames
                    Img.ImageRectOffset = Vector2.new(i * 100, 0)
                    task.wait(1/fps)
                end
            end)
        end

