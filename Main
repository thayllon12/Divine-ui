        function TabObj:AddPerformanceMonitor()
            local L = TabObj:AddStatistic("Ping", "0 ms")
            task.spawn(function() while L do L:SetValue(math.floor(Stats.Network.ServerStatsItem["Data Ping"]:GetValue())) task.wait(1) end end)
        end
        TabObj.AddMemoryMonitor = TabObj.AddPerformanceMonitor
        TabObj.AddNetworkStats = TabObj.AddPerformanceMonitor

        function TabObj:AddLogger() TabObj:AddTerminal() end
