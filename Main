            local B = Create("TextButton", { Parent = D, BackgroundColor3=theme.Accent, Size=UDim2.new(1,-40,0,30), Position=UDim2.new(0,20,1,-40), Font=Enum.Font.GothamBold, Text="OK", TextColor3=Color3.new(1,1,1), TextSize=14, ZIndex=102 }, { Create("UICorner", { CornerRadius=UDim.new(0,6) }) })
            B.MouseButton1Click:Connect(function() BG:Destroy() if callback then callback() end end)
        end
