local function applyScale()
local nw = math.clamp(tonumber(wBox.Text) or currentWidth, minWidth, maxWidth)
local nh = math.clamp(tonumber(hBox.Text) or currentHeight, minHeight, maxHeight)
wBox.Text = tostring(nw)
hBox.Text = tostring(nh)
currentWidth = nw
currentHeight = nh
WindowObj.OriginalSize = UDim2.new(0, nw, 0, nh)
if not WindowObj.IsMinimized then
Tween(MainFrame, {Size = WindowObj.OriginalSize}, 0.3, Enum.EasingStyle.Exponential)
end
end
wBox.FocusLost:Connect(applyScale)
hBox.FocusLost:Connect(applyScale)

