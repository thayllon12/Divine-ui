    --=========================================================================
    -- 🔧 ELEMENT API FACTORY
    --=========================================================================
    local ElementAPI = {}

    function ElementAPI:AddSection(title, transKey)
        local SecFrame = Create("Frame", { Parent = self.Container, BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 25), ZIndex = 12 })
        local Lbl = Create("TextLabel", { Parent = SecFrame, BackgroundTransparency = 1, Size = UDim2.new(1, -10, 1, 0), Position = UDim2.new(0, 5, 0, 0), Font = Enum.Font.GothamBold, TextColor3 = theme.Accent, TextSize = 14, TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 13 })
        if transKey then RegisterTranslation(Lbl, transKey) else Lbl.Text = title or "Section" end
        return { SetText = function(_, newTitle) Lbl.Text = tostring(newTitle) end }
    end

    function ElementAPI:AddDivider()
        local DivFrame = Create("Frame", { Parent = self.Container, BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 15), ZIndex = 12 })
        Create("Frame", { Parent = DivFrame, BackgroundColor3 = theme.StrokeColor, Size = UDim2.new(1, -20, 0, 1), Position = UDim2.fromScale(0.5, 0.5), AnchorPoint = Vector2.new(0.5, 0.5), BorderSizePixel = 0, ZIndex = 13 })
    end

    function ElementAPI:AddToggle(id, options)
        id, options = getId(id, options)
        local state = options.Default or false
        local cb = options.Callback or function() end
        
        local TglFrame = Create("TextButton", { Parent = self.Container, BackgroundColor3 = theme.ElementBackground, Size = UDim2.new(1, 0, 0, 42), Text = "", AutoButtonColor = false, ZIndex = 12 })
        Create("UICorner", { Parent = TglFrame, CornerRadius = UDim.new(0, 6) })
        Create("UIStroke", { Parent = TglFrame, Color = theme.StrokeColor, Thickness = 1 })
        
        local Lbl = Create("TextLabel", { Parent = TglFrame, BackgroundTransparency = 1, Size = UDim2.new(1, -80, 0, 20), Position = UDim2.new(0, 15, 0, 11), Font = Enum.Font.GothamMedium, TextColor3 = theme.Text, TextSize = 14, TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 13 })
        if options.TransTitle then RegisterTranslation(Lbl, options.TransTitle) else Lbl.Text = options.Title or "Toggle" end
        
        local Switch = Create("Frame", { Parent = TglFrame, BackgroundColor3 = state and theme.Accent or theme.TabBackground, Size = UDim2.new(0, 42, 0, 22), Position = UDim2.new(1, -55, 0.5, 0), AnchorPoint = Vector2.new(0, 0.5), ZIndex = 13 })
        Create("UICorner", { Parent = Switch, CornerRadius = UDim.new(1, 0) })
        Create("UIStroke", { Parent = Switch, Color = theme.StrokeColor, Thickness = 1 })
        
        local Circle = Create("Frame", { Parent = Switch, BackgroundColor3 = Color3.fromRGB(255, 255, 255), Size = UDim2.new(0, 16, 0, 16), Position = state and UDim2.new(1, -19, 0.5, 0) or UDim2.new(0, 3, 0.5, 0), AnchorPoint = Vector2.new(0, 0.5), ZIndex = 14 })
        Create("UICorner", { Parent = Circle, CornerRadius = UDim.new(1, 0) })

        local TglObj = { Value = state }
        function TglObj:SetValue(val)
            self.Value = val
            state = val
            DevLib.Flags[id] = state
            Tween(Switch, { BackgroundColor3 = state and theme.Accent or theme.TabBackground }, 0.2)
            Tween(Circle, { Position = state and UDim2.new(1, -19, 0.5, 0) or UDim2.new(0, 3, 0.5, 0) }, 0.2, Enum.EasingStyle.Back)
            pcall(function() cb(state) end)
        end
        TglFrame.MouseButton1Click:Connect(function() TglObj:SetValue(not state) end)
        DevLib.Flags[id] = state
        DevLib.Options[id] = TglObj
        return TglObj
    end

    --=========================================================================
    -- 🔍 DROPDOWN WITH REAL SEARCHBAR ALGORITHM
    --=========================================================================
    function ElementAPI:AddDropdown(id, options)
        id, options = getId(id, options)
        local values = options.Values or {}
        local default = options.Default
        local multi = options.Multi or false
        local selected = multi and (type(default) == "table" and default or {}) or default
        local cb = options.Callback or function() end
        local isOpen = false

        local DdFrame = Create("Frame", { Parent = self.Container, BackgroundColor3 = theme.ElementBackground, Size = UDim2.new(1, 0, 0, 42), ClipsDescendants = true, ZIndex = 12 })
        Create("UICorner", { Parent = DdFrame, CornerRadius = UDim.new(0, 6) })
        Create("UIStroke", { Parent = DdFrame, Color = theme.StrokeColor, Thickness = 1 })
        
        local DdBtn = Create("TextButton", { Parent = DdFrame, BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 42), Text = "", ZIndex = 13 })
        local Lbl = Create("TextLabel", { Parent = DdBtn, BackgroundTransparency = 1, Size = UDim2.new(1, -120, 0, 20), Position = UDim2.new(0, 15, 0, 11), Font = Enum.Font.GothamMedium, TextColor3 = theme.Text, TextSize = 14, TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 14 })
        if options.TransTitle then RegisterTranslation(Lbl, options.TransTitle) else Lbl.Text = options.Title or "Dropdown" end
        
        local SelLbl = Create("TextLabel", { Parent = DdBtn, BackgroundTransparency = 1, Size = UDim2.new(0, 100, 0, 20), Position = UDim2.new(1, -135, 0, 11), Font = Enum.Font.Gotham, Text = "None", TextColor3 = theme.SubText, TextSize = 13, TextXAlignment = Enum.TextXAlignment.Right, ZIndex = 14 })
        local DropIcon = Create("ImageLabel", { Parent = DdBtn, BackgroundTransparency = 1, Size = UDim2.new(0, 16, 0, 16), Position = UDim2.new(1, -25, 0.5, 0), AnchorPoint = Vector2.new(0, 0.5), Image = DevLib:GetIcon("chevron-down"), ImageColor3 = theme.SubText, ZIndex = 14 })
        
        local SearchBox = Create("TextBox", { Parent = DdFrame, BackgroundColor3 = theme.TabBackground, Size = UDim2.new(1, -20, 0, 26), Position = UDim2.new(0, 10, 0, 47), Font = Enum.Font.Gotham, Text = "", TextColor3 = theme.Text, TextSize = 12, PlaceholderText = "Search...", ClearTextOnFocus = false, ZIndex = 14 })
        Create("UICorner", { Parent = SearchBox, CornerRadius = UDim.new(0, 4) })
        Create("UIStroke", { Parent = SearchBox, Color = theme.StrokeColor, Thickness = 1 })
        
        local ListScroll = Create("ScrollingFrame", { Parent = DdFrame, BackgroundTransparency = 1, Size = UDim2.new(1, -10, 0, 120), Position = UDim2.new(0, 5, 0, 78), ScrollBarThickness = 2, CanvasSize = UDim2.new(0,0,0,0), AutomaticCanvasSize = Enum.AutomaticSize.Y, ZIndex = 14 })
        Create("UIListLayout", { Parent = ListScroll, Padding = UDim.new(0, 4) })

        local DdObj = { Value = selected }
        local itemBtns = {}
        
        local function upVis()
            if multi then
                local arr = {}
                for k,v in pairs(selected) do if v then table.insert(arr, k) end end
                SelLbl.Text = #arr > 0 and table.concat(arr, ", ") or "None"
            else
                SelLbl.Text = tostring(selected or "None")
            end
            DdObj.Value = selected; DevLib.Flags[id] = selected
            pcall(function() cb(selected) end)
        end

        function DdObj:Refresh(newVals)
            values = newVals
            for _,c in pairs(ListScroll:GetChildren()) do if c:IsA("TextButton") then c:Destroy() end end
            itemBtns = {}
            for _, v in ipairs(values) do
                local isSel = multi and selected[v] or (not multi and selected == v)
                local btn = Create("TextButton", { Parent = ListScroll, BackgroundColor3 = isSel and theme.Accent or theme.TabBackground, Size = UDim2.new(1, -10, 0, 30), Text = "", AutoButtonColor = false, ZIndex = 15 })
                Create("UICorner", { Parent = btn, CornerRadius = UDim.new(0, 4) })
                local btnLbl = Create("TextLabel", { Parent = btn, BackgroundTransparency = 1, Size = UDim2.new(1, -20, 1, 0), Position = UDim2.new(0, 10, 0, 0), Font = Enum.Font.Gotham, Text = tostring(v), TextColor3 = isSel and Color3.new(1,1,1) or theme.Text, TextSize = 13, TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 16 })
                if DevLib.Translations[v] and DevLib.Translations[v][v] then btnLbl.Text = DevLib.Translations[v][v] end
                
                table.insert(itemBtns, {Btn = btn, Text = tostring(v):lower()})

                btn.MouseButton1Click:Connect(function()
                    if multi then
                        selected[v] = not selected[v]
                        btn.BackgroundColor3 = selected[v] and theme.Accent or theme.TabBackground
                        btnLbl.TextColor3 = selected[v] and Color3.new(1,1,1) or theme.Text
                    else
                        selected = v
                        for _,c in pairs(ListScroll:GetChildren()) do
                            if c:IsA("TextButton") then c.BackgroundColor3 = theme.TabBackground; c:FindFirstChildWhichIsA("TextLabel").TextColor3 = theme.Text end
                        end
                        btn.BackgroundColor3 = theme.Accent; btnLbl.TextColor3 = Color3.new(1,1,1)
                        isOpen = false
                        Tween(DdFrame, {Size=UDim2.new(1,0,0,42)}, 0.3); Tween(DropIcon, {Rotation=0}, 0.3)
                    end
                    upVis()
                end)
            end
        end

        SearchBox:GetPropertyChangedSignal("Text"):Connect(function()
            local q = SearchBox.Text:lower()
            for _, data in ipairs(itemBtns) do
                if q == "" or string.find(data.Text, q) then
                    data.Btn.Visible = true
                else
                    data.Btn.Visible = false
                end
            end
        end)

        DdBtn.MouseButton1Click:Connect(function()
            isOpen = not isOpen
            Tween(DdFrame, {Size = isOpen and UDim2.new(1, 0, 0, 203) or UDim2.new(1, 0, 0, 42)}, 0.3, Enum.EasingStyle.Exponential)
            Tween(DropIcon, {Rotation = isOpen and 180 or 0}, 0.3)
        end)

        DdObj:Refresh(values); upVis()
        DevLib.Flags[id] = selected; DevLib.Options[id] = DdObj
        return DdObj
    end

    --=========================================================================
    -- 🎚️ SLIDER COM TEXTBOX DE VALOR MANUAL
    --=========================================================================
    function ElementAPI:AddSlider(id, options)
        id, options = getId(id, options)
        local title = options.Title or "Slider"
        local min = options.Min or 0
        local max = options.Max or 100
        local val = options.Default or 0
        local rounding = options.Rounding or 0
        local cb = options.Callback or function() end

        local SldFrame = Create("Frame", { Parent = self.Container, BackgroundColor3 = theme.ElementBackground, Size = UDim2.new(1, 0, 0, 65), ZIndex = 12 })
        Create("UICorner", { Parent = SldFrame, CornerRadius = UDim.new(0, 6) })
        Create("UIStroke", { Parent = SldFrame, Color = theme.StrokeColor, Thickness = 1 })
        
        local Lbl = Create("TextLabel", { Parent = SldFrame, BackgroundTransparency = 1, Size = UDim2.new(1, -80, 0, 20), Position = UDim2.new(0, 15, 0, 10), Font = Enum.Font.GothamMedium, TextColor3 = theme.Text, TextSize = 14, TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 13 })
        if options.TransTitle then RegisterTranslation(Lbl, options.TransTitle) else Lbl.Text = title end

        -- Textbox de input manual
        local ManualInput = Create("TextBox", { Parent = SldFrame, BackgroundColor3 = theme.TabBackground, Size = UDim2.new(0, 50, 0, 20), Position = UDim2.new(1, -65, 0, 10), Font = Enum.Font.GothamBold, Text = tostring(val), TextColor3 = theme.SubText, TextSize = 13, ClearTextOnFocus = false, ZIndex = 13 })
        Create("UICorner", { Parent = ManualInput, CornerRadius = UDim.new(0,4) })
        Create("UIStroke", { Parent = ManualInput, Color = theme.StrokeColor, Thickness = 1 })

        local SliderBg = Create("TextButton", { Parent = SldFrame, BackgroundColor3 = theme.TabBackground, Size = UDim2.new(1, -30, 0, 6), Position = UDim2.new(0, 15, 1, -15), Text = "", AutoButtonColor = false, ZIndex = 13 })
        Create("UICorner", { Parent = SliderBg, CornerRadius = UDim.new(1, 0) })
        
        local SliderFill = Create("Frame", { Parent = SliderBg, BackgroundColor3 = theme.Accent, Size = UDim2.new((val - min)/(max - min), 0, 1, 0), ZIndex = 14 })
        Create("UICorner", { Parent = SliderFill, CornerRadius = UDim.new(1, 0) })
        
        local SliderCirc = Create("Frame", { Parent = SliderFill, BackgroundColor3 = Color3.fromRGB(255, 255, 255), Size = UDim2.new(0, 12, 0, 12), Position = UDim2.new(1, -6, 0.5, 0), AnchorPoint = Vector2.new(0, 0.5), ZIndex = 15 })
        Create("UICorner", { Parent = SliderCirc, CornerRadius = UDim.new(1, 0) })

        local SldObj = { Value = val }
        
        function SldObj:SetValue(v)
            val = math.clamp(math.round(v * (10^rounding)) / (10^rounding), min, max)
            self.Value = val; DevLib.Flags[id] = val
            ManualInput.Text = tostring(val)
            Tween(SliderFill, { Size = UDim2.new((val - min)/(max - min), 0, 1, 0) }, 0.1)
            pcall(function() cb(val) end)
        end

        ManualInput.FocusLost:Connect(function()
            local n = tonumber(ManualInput.Text)
            if n then SldObj:SetValue(n) else ManualInput.Text = tostring(val) end
        end)

        local dragging = false
        local function update(input)
            local sizeX = SliderBg.AbsoluteSize.X
            local posX = SliderBg.AbsolutePosition.X
            local pct = math.clamp((input.Position.X - posX) / sizeX, 0, 1)
            SldObj:SetValue(min + ((max - min) * pct))
        end
        
        SliderBg.InputBegan:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
                dragging = true; Tween(SliderCirc, {Size=UDim2.new(0,16,0,16)}, 0.2); update(i)
            end
        end)
        
        local conn1 = UserInputService.InputEnded:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
                dragging = false; Tween(SliderCirc, {Size=UDim2.new(0,12,0,12)}, 0.2)
            end
        end)
        
        local conn2 = UserInputService.InputChanged:Connect(function(i)
            if dragging and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then update(i) end
        end)
        
        table.insert(DevLib.Connections, conn1); table.insert(DevLib.Connections, conn2)
        DevLib.Flags[id] = val; DevLib.Options[id] = SldObj
        return SldObj
    end

    --=========================================================================
    -- 🖌️ ADVANCED COLOR PICKER (With HEX & RGB Math logic, Drag Signal)
    --=========================================================================
    function ElementAPI:AddColorpicker(id, options)
        id, options = getId(id, options)
        local default = options.Default or Color3.new(1,1,1)
        local cb = options.Callback or function() end
        local hasTransp = options.Transparency ~= nil
        local transp = options.Transparency or 0
        local color = default
        local h,s,v = Color3.toHSV(color)
        local isOpen = false

        local CpFrame = Create("Frame", { Parent = self.Container, BackgroundColor3 = theme.ElementBackground, Size = UDim2.new(1, 0, 0, 42), ClipsDescendants = true, ZIndex = 12 })
        Create("UICorner", { Parent = CpFrame, CornerRadius = UDim.new(0, 6) })
        Create("UIStroke", { Parent = CpFrame, Color = theme.StrokeColor, Thickness = 1 })
        
        local CpBtn = Create("TextButton", { Parent = CpFrame, BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 42), Text = "", ZIndex = 13 })
        local Lbl = Create("TextLabel", { Parent = CpBtn, BackgroundTransparency = 1, Size = UDim2.new(1, -80, 0, 20), Position = UDim2.new(0, 15, 0, 11), Font = Enum.Font.GothamMedium, TextColor3 = theme.Text, TextSize = 14, TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 14 })
        if options.TransTitle then RegisterTranslation(Lbl, options.TransTitle) else Lbl.Text = options.Title or "Colorpicker" end
        
        local DispColor = Create("Frame", { Parent = CpBtn, BackgroundColor3 = color, BackgroundTransparency = transp, Size = UDim2.new(0, 36, 0, 20), Position = UDim2.new(1, -55, 0.5, 0), AnchorPoint = Vector2.new(0, 0.5), ZIndex = 14 })
        Create("UICorner", { Parent = DispColor, CornerRadius = UDim.new(0, 4) })
        Create("UIStroke", { Parent = DispColor, Color = theme.StrokeColor, Thickness = 1 })
        
        local DropArea = Create("Frame", { Parent = CpFrame, BackgroundTransparency = 1, Size = UDim2.new(1, -30, 0, 180), Position = UDim2.new(0, 15, 0, 50), ZIndex = 13 })
        
        -- Saturação e Valor
        local SatVal = Create("TextButton", { Parent = DropArea, BackgroundColor3 = Color3.fromHSV(h,1,1), Size = UDim2.new(1, -30, 0, 100), Text = "", AutoButtonColor = false, ZIndex = 14 })
        Create("UICorner", { Parent = SatVal, CornerRadius = UDim.new(0, 4) })
        Create("UIGradient", { Parent = SatVal, Color = ColorSequence.new({ColorSequenceKeypoint.new(0, Color3.new(1,1,1)), ColorSequenceKeypoint.new(1, Color3.new(1,1,1))}), Transparency = NumberSequence.new({NumberSequenceKeypoint.new(0,0), NumberSequenceKeypoint.new(1,1)}) })
        local SatValShadow = Create("Frame", { Parent = SatVal, BackgroundColor3 = Color3.new(0,0,0), Size = UDim2.new(1,0,1,0), ZIndex = 15 })
        Create("UICorner", { Parent = SatValShadow, CornerRadius = UDim.new(0,4) })
        Create("UIGradient", { Parent = SatValShadow, Rotation = 90, Transparency = NumberSequence.new({NumberSequenceKeypoint.new(0,1), NumberSequenceKeypoint.new(1,0)}) })
        local SVMarker = Create("Frame", { Parent = SatVal, BackgroundColor3 = Color3.new(1,1,1), Size = UDim2.new(0,6,0,6), AnchorPoint = Vector2.new(0.5,0.5), Position = UDim2.new(s, 0, 1-v, 0), ZIndex=16 })
        Create("UICorner", { Parent = SVMarker, CornerRadius = UDim.new(1,0) })
        Create("UIStroke", { Parent = SVMarker, Color = Color3.new(0,0,0), Thickness = 1 })

        -- Matiz (Hue)
        local Hue = Create("TextButton", { Parent = DropArea, Size = UDim2.new(0, 20, 0, 100), Position = UDim2.new(1, -20, 0, 0), Text = "", AutoButtonColor = false, ZIndex = 14 })
        Create("UICorner", { Parent = Hue, CornerRadius = UDim.new(0, 4) })
        Create("UIGradient", { Parent = Hue, Rotation = 90, Color = ColorSequence.new({ColorSequenceKeypoint.new(0, Color3.new(1,0,0)), ColorSequenceKeypoint.new(0.16, Color3.new(1,1,0)), ColorSequenceKeypoint.new(0.33, Color3.new(0,1,0)), ColorSequenceKeypoint.new(0.5, Color3.new(0,1,1)), ColorSequenceKeypoint.new(0.66, Color3.new(0,0,1)), ColorSequenceKeypoint.new(0.83, Color3.new(1,0,1)), ColorSequenceKeypoint.new(1, Color3.new(1,0,0))}) })
        local HueMarker = Create("Frame", { Parent = Hue, BackgroundColor3 = Color3.new(1,1,1), Size = UDim2.new(1,2,0,4), AnchorPoint = Vector2.new(0.5,0.5), Position = UDim2.new(0.5, 0, 1-h, 0), ZIndex=15 })
        Create("UIStroke", { Parent = HueMarker, Color = Color3.new(0,0,0), Thickness = 1 })

        -- HEX & RGB Inputs Textboxes
        local InputArea = Create("Frame", { Parent = DropArea, BackgroundTransparency = 1, Size = UDim2.new(1,0,0,25), Position = UDim2.new(0,0,0,110), ZIndex=14 })
        local HexBox = Create("TextBox", { Parent = InputArea, BackgroundColor3 = theme.TabBackground, Size = UDim2.new(0.45,0,1,0), Position = UDim2.new(0,0,0,0), Font = Enum.Font.Code, Text = color:ToHex(), TextColor3 = theme.Text, TextSize=12, ClearTextOnFocus=false, ZIndex=15 })
        Create("UICorner", {Parent=HexBox, CornerRadius=UDim.new(0,4)}); Create("UIStroke", {Parent=HexBox, Color=theme.StrokeColor, Thickness=1})
        local RgbBox = Create("TextBox", { Parent = InputArea, BackgroundColor3 = theme.TabBackground, Size = UDim2.new(0.5,0,1,0), Position = UDim2.new(1,0,0,0), AnchorPoint=Vector2.new(1,0), Font = Enum.Font.Code, Text = math.floor(color.R*255)..", "..math.floor(color.G*255)..", "..math.floor(color.B*255), TextColor3 = theme.Text, TextSize=12, ClearTextOnFocus=false, ZIndex=15 })
        Create("UICorner", {Parent=RgbBox, CornerRadius=UDim.new(0,4)}); Create("UIStroke", {Parent=RgbBox, Color=theme.StrokeColor, Thickness=1})

        local CpObj = { Value = color, Transparency = transp, OnColorChanged = Signal.new(), OnDrag = Signal.new() }
        
        local function updateVis()
            color = Color3.fromHSV(h,s,v)
            DispColor.BackgroundColor3 = color
            SatVal.BackgroundColor3 = Color3.fromHSV(h,1,1)
            SVMarker.Position = UDim2.new(s, 0, 1-v, 0)
            HueMarker.Position = UDim2.new(0.5, 0, 1-h, 0)
            HexBox.Text = color:ToHex()
            RgbBox.Text = math.floor(color.R*255)..", "..math.floor(color.G*255)..", "..math.floor(color.B*255)
            
            CpObj.Value = color; CpObj.Transparency = transp
            DevLib.Flags[id] = {R = color.R, G = color.G, B = color.B, T = transp}
            CpObj.OnColorChanged:Fire(color, transp)
            pcall(function() cb(color, transp) end)
        end

        HexBox.FocusLost:Connect(function()
            local success, res = pcall(function() return Color3.fromHex(HexBox.Text) end)
            if success and res then color = res; h,s,v = Color3.toHSV(res); updateVis() else HexBox.Text = color:ToHex() end
        end)

        local dragSV, dragHue = false, false
        SatVal.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then dragSV = true CpObj.OnDrag:Fire() end end)
        Hue.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then dragHue = true CpObj.OnDrag:Fire() end end)

        local conn1 = UserInputService.InputChanged:Connect(function(i)
            if (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then
                if dragSV then
                    local absPos, absSize = SatVal.AbsolutePosition, SatVal.AbsoluteSize
                    s = math.clamp((i.Position.X - absPos.X) / absSize.X, 0, 1)
                    v = 1 - math.clamp((i.Position.Y - absPos.Y) / absSize.Y, 0, 1)
                    updateVis(); CpObj.OnDrag:Fire()
                elseif dragHue then
                    local absPos, absSize = Hue.AbsolutePosition, Hue.AbsoluteSize
                    h = 1 - math.clamp((i.Position.Y - absPos.Y) / absSize.Y, 0, 1)
                    updateVis(); CpObj.OnDrag:Fire()
                end
            end
        end)

        local conn2 = UserInputService.InputEnded:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then dragSV = false; dragHue = false end
        end)
        
        table.insert(DevLib.Connections, conn1); table.insert(DevLib.Connections, conn2)

        CpBtn.MouseButton1Click:Connect(function()
            isOpen = not isOpen
            Tween(CpFrame, {Size = isOpen and UDim2.new(1,0,0, 200) or UDim2.new(1,0,0,42)}, 0.3, Enum.EasingStyle.Exponential)
        end)

        DevLib.Flags[id] = {R = color.R, G = color.G, B = color.B, T = transp}; DevLib.Options[id] = CpObj
        return CpObj
    end

    function ElementAPI:AddInput(id, options)
        id, options = getId(id, options)
        local default = options.Default or ""
        local numeric = options.Numeric or false
        local cb = options.Callback or function() end

        local InpFrame = Create("Frame", { Parent = self.Container, BackgroundColor3 = theme.ElementBackground, Size = UDim2.new(1, 0, 0, 42), ZIndex = 12 })
        Create("UICorner", { Parent = InpFrame, CornerRadius = UDim.new(0, 6) })
        Create("UIStroke", { Parent = InpFrame, Color = theme.StrokeColor, Thickness = 1 })
        
        local Lbl = Create("TextLabel", { Parent = InpFrame, BackgroundTransparency = 1, Size = UDim2.new(0.4, 0, 0, 20), Position = UDim2.new(0, 15, 0, 11), Font = Enum.Font.GothamMedium, TextColor3 = theme.Text, TextSize = 14, TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 13 })
        if options.TransTitle then RegisterTranslation(Lbl, options.TransTitle) else Lbl.Text = options.Title or "Input" end

        local TextBox = Create("TextBox", { Parent = InpFrame, BackgroundColor3 = theme.TabBackground, Size = UDim2.new(0.5, -15, 0, 26), Position = UDim2.new(0.5, 0, 0.5, 0), AnchorPoint = Vector2.new(0, 0.5), Font = Enum.Font.Gotham, Text = default, TextColor3 = theme.Text, TextSize = 13, PlaceholderText = "Type...", ClearTextOnFocus = false, ZIndex = 13 })
        Create("UICorner", { Parent = TextBox, CornerRadius = UDim.new(0, 4) })
        Create("UIStroke", { Parent = TextBox, Color = theme.StrokeColor, Thickness = 1 })
        if options.TransPlaceholder then RegisterTranslation(TextBox, options.TransPlaceholder, "PlaceholderText") end

        local InpObj = { Value = default }
        local function handleInput()
            local txt = TextBox.Text
            if numeric and not tonumber(txt) and txt ~= "" then txt = InpObj.Value; TextBox.Text = tostring(txt) end
            InpObj.Value = txt; DevLib.Flags[id] = txt
            pcall(function() cb(txt) end)
        end
        TextBox.FocusLost:Connect(function() handleInput() end)
        if not options.Finished then TextBox:GetPropertyChangedSignal("Text"):Connect(handleInput) end

        DevLib.Flags[id] = default; DevLib.Options[id] = InpObj
        return InpObj
    end

    --=========================================================================
    -- ⚙️ INTERNAL SETTINGS OVERLAY BUILDER
    --=========================================================================
    setmetatable(PseudoTab, {__index = ElementAPI})
    
    PseudoTab:AddDropdown("Sys_Language", {
        TransTitle = "Language",
        Values = {"pt-BR", "en-US", "es-ES", "fr-FR", "de-DE", "ru-RU", "ja-JP", "zh-CN", "ko-KR"},
        Default = DevLib.CurrentLanguage,
        Callback = function(val) DevLib:SetLanguage(val) end
    })

    local tList = {} for k,_ in pairs(DevLib.Themes) do table.insert(tList, k) end
    PseudoTab:AddDropdown("Sys_Theme", {
        TransTitle = "Theme",
        Values = tList,
        Default = DevLib.CurrentTheme,
        Callback = function(val)
            DevLib:SetTheme(val)
            theme = DevLib:GetTheme()
            DevLib:Notify({Title="Theme Core", Content="Theme set to " .. val .. ". Re-inject to apply full palette."})
        end
    })

    PseudoTab:AddToggle("Sys_Blur", {
        TransTitle = "Blur",
        Default = useAcrylic,
        Callback = function(state) if Blur then Tween(Blur, {Size = state and 15 or 0}, 0.3) end end
    })

    DevLib:SetLanguage(DevLib.CurrentLanguage)
    return WindowObj
end

