DevLib.CurrentTheme = "DEV"

function DevLib:GetTheme()
    return DevLib.Themes[DevLib.CurrentTheme]
end

--=============================================================================================================================
-- [7] 🛠️ CORE FACTORY & TWEENING UTILS
--=============================================================================================================================
local function Create(className, properties, children)
    local instance = Instance.new(className)
    if type(properties) == "table" then
        for property, value in pairs(properties) do
            local success, err = pcall(function() instance[property] = value end)
            if not success then warn("[DevLib Create Engine] Error on", property, ":", err) end
        end
    end
    if type(children) == "table" then
        for _, child in pairs(children) do
            if typeof(child) == "Instance" then child.Parent = instance end
        end
    end
    table.insert(DevLib.Instances, instance)
    return instance
end

local function Tween(instance, properties, duration, style, direction)
    if typeof(instance) ~= "Instance" or not instance.Parent then return end
    duration = duration or 0.3
    style = style or Enum.EasingStyle.Quad
    direction = direction or Enum.EasingDirection.Out
    local tweenInfo = TweenInfo.new(duration, style, direction)
    local success, tween = pcall(function() return TweenService:Create(instance, tweenInfo, properties) end)
    if success and tween then tween:Play() return tween end
    return nil
end

local function RegisterTranslation(labelObj, translationKey, property, formatStr)
    property = property or "Text"
    DevLib.ActiveLabels[labelObj] = { Key = translationKey, Property = property, Format = formatStr }
    local tText = DevLib:Translate(translationKey)
    if formatStr then
        labelObj[property] = string.gsub(formatStr, "{T}", tText)
    else
        labelObj[property] = tText
    end
end

-- Universal Drag Logic (PC + Mobile support)
local function MakeDraggable(dragPart, targetPart)
    local dragging = false
    local dragInput, mousePos, framePos
    local dragStartConn, dragChangeConn, inputChangeConn

    dragStartConn = dragPart.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            mousePos = input.Position
            framePos = targetPart.Position
            
            local releaseConn
            releaseConn = input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                    if releaseConn then releaseConn:Disconnect() releaseConn = nil end
                end
            end)
        end
    end)

    dragChangeConn = dragPart.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)

    inputChangeConn = UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - mousePos
            targetPart.Position = UDim2.new(
                framePos.X.Scale, framePos.X.Offset + delta.X,
                framePos.Y.Scale, framePos.Y.Offset + delta.Y
            )
        end
    end)

    table.insert(DevLib.Connections, dragStartConn)
    table.insert(DevLib.Connections, dragChangeConn)
    table.insert(DevLib.Connections, inputChangeConn)
end

local function getId(id, options)
    if type(id) == "table" then
        options = id
        id = options.Id or options.Title or ("DevAuto_" .. tostring(math.random(100000, 999999)))
    end
    if type(options) ~= "table" then options = {} end
    return id, options
end

function DevLib:GetIcon(name)
    if type(name) ~= "string" or name == "" then return "" end
    if string.find(name, "rbxassetid") then return name end
    if DevLib.Icons["lucide-" .. name] then return DevLib.Icons["lucide-" .. name] end
    if DevLib.Icons[name] then return DevLib.Icons[name] end
    return ""
end

function DevLib:SaveConfig(customName)
    local name = customName or DevLib.SaveName
    if writefile then
        local success, encoded = pcall(HttpService.JSONEncode, HttpService, DevLib.Flags)
        if success then
            -- Use our Base64 layer to prevent tampering/easy reading
            local safeData = Base64.encode(encoded)
            writefile(name .. ".txt", safeData)
            return true
        end
    end
    return false
end

function DevLib:LoadConfig(customName)
    local name = customName or DevLib.SaveName
    if readfile and isfile and isfile(name .. ".txt") then
        local safeData = readfile(name .. ".txt")
        local success, decodedStr = pcall(Base64.decode, safeData)
        if success and decodedStr then
            local s2, decoded = pcall(HttpService.JSONDecode, HttpService, decodedStr)
            if s2 then
                for key, value in pairs(decoded) do
                    if DevLib.Options[key] and type(DevLib.Options[key].SetValue) == "function" then
                        pcall(function() DevLib.Options[key]:SetValue(value) end)
                    end
                end
                return true
            end
        end
    end
    return false
end

--=============================================================================================================================
-- [8] 📡 NOTIFICATION ENGINE (With Progress Bar, Timer, and Disconnect Events)
--=============================================================================================================================
function DevLib:Notify(options)
    if type(options) ~= "table" then options = {} end
    local title = options.Title or "Notification"
    local content = options.Content or ""
    local duration = options.Duration or 5
    local theme = DevLib:GetTheme()

    if not DevLib.NotificationGui then
        DevLib.NotificationGui = Create("ScreenGui", { Name = "DevLibNotifications", Parent = GUI_TARGET, ZIndexBehavior = Enum.ZIndexBehavior.Sibling, ResetOnSpawn = false })
        DevLib.NotificationContainer = Create("Frame", { Name = "Container", Parent = DevLib.NotificationGui, BackgroundTransparency = 1, Size = UDim2.new(0, 320, 1, 0), Position = UDim2.new(1, -20, 0, 0), AnchorPoint = Vector2.new(1, 0) })
        Create("UIListLayout", { Parent = DevLib.NotificationContainer, SortOrder = Enum.SortOrder.LayoutOrder, VerticalAlignment = Enum.VerticalAlignment.Bottom, HorizontalAlignment = Enum.HorizontalAlignment.Right, Padding = UDim.new(0, 10) })
        Create("UIPadding", { Parent = DevLib.NotificationContainer, PaddingBottom = UDim.new(0, 20), PaddingRight = UDim.new(0, 20) })
    end

    local NotifObj = {
        OnClose = Signal.new(),
        OnTimeout = Signal.new(),
        Closed = false
    }

    local notifFrame = Create("Frame", {
        Parent = DevLib.NotificationContainer,
        Size = UDim2.new(1, 0, 0, 0),
        BackgroundColor3 = theme.WindowBackground,
        BackgroundTransparency = 0.1,
        AutomaticSize = Enum.AutomaticSize.Y,
        ClipsDescendants = true,
        ZIndex = 1000
    })
    Create("UICorner", { Parent = notifFrame, CornerRadius = UDim.new(0, 8) })
    Create("UIStroke", { Parent = notifFrame, Color = theme.StrokeColor, Thickness = 1 })
    Create("UIPadding", { Parent = notifFrame, PaddingTop = UDim.new(0, 15), PaddingBottom = UDim.new(0, 15), PaddingLeft = UDim.new(0, 15), PaddingRight = UDim.new(0, 15) })
    
    local TopRow = Create("Frame", { Parent = notifFrame, BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 20), ZIndex = 1001 })
    local TitleLbl = Create("TextLabel", { Parent = TopRow, BackgroundTransparency = 1, Size = UDim2.new(1, -60, 1, 0), Font = Enum.Font.GothamBold, Text = title, TextColor3 = theme.Text, TextSize = 14, TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 1001 })
    local TimerLbl = Create("TextLabel", { Parent = TopRow, BackgroundTransparency = 1, Size = UDim2.new(0, 40, 1, 0), Position = UDim2.new(1, -55, 0, 0), Font = Enum.Font.GothamMedium, Text = "["..duration.."s]", TextColor3 = theme.Accent, TextSize = 12, TextXAlignment = Enum.TextXAlignment.Right, ZIndex = 1001 })
    
    local CloseBtn = Create("TextButton", { Parent = TopRow, BackgroundTransparency = 1, Size = UDim2.new(0, 20, 0, 20), Position = UDim2.new(1, -10, 0, 0), AnchorPoint = Vector2.new(1, 0), Text = "", ZIndex = 1002 })
    Create("ImageLabel", { Parent = CloseBtn, BackgroundTransparency = 1, Size = UDim2.new(0, 14, 0, 14), Position = UDim2.new(0.5,0,0.5,0), AnchorPoint = Vector2.new(0.5,0.5), Image = DevLib:GetIcon("x"), ImageColor3 = theme.SubText, ZIndex = 1002 })

    local ContentLbl = Create("TextLabel", { Parent = notifFrame, BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 0), Position = UDim2.new(0, 0, 0, 25), AutomaticSize = Enum.AutomaticSize.Y, Font = Enum.Font.Gotham, Text = content, TextColor3 = theme.SubText, TextSize = 13, TextXAlignment = Enum.TextXAlignment.Left, TextWrapped = true, ZIndex = 1001 })
    
    local ProgressBarBg = Create("Frame", { Parent = notifFrame, BackgroundColor3 = theme.TabBackground, Size = UDim2.new(1, 30, 0, 3), Position = UDim2.new(0, -15, 1, 12), AnchorPoint = Vector2.new(0, 1), ZIndex = 1002 })
    local ProgressBar = Create("Frame", { Parent = ProgressBarBg, BackgroundColor3 = theme.Accent, Size = UDim2.new(1, 0, 1, 0), ZIndex = 1003 })

    local function destroyNotif()
        if NotifObj.Closed then return end
        NotifObj.Closed = true
        if notifFrame and notifFrame.Parent then
            local sizeY = notifFrame.AbsoluteSize.Y
            local t = Tween(notifFrame, { Size = UDim2.new(0, 0, 0, sizeY), BackgroundTransparency = 1 }, 0.4, Enum.EasingStyle.Quad)
            if t then t.Completed:Connect(function() notifFrame:Destroy() end) else notifFrame:Destroy() end
        end
    end

    CloseBtn.MouseButton1Click:Connect(function()
        NotifObj.OnClose:Fire()
        destroyNotif()
    end)

    task.defer(function()
        if notifFrame and notifFrame.Parent then
            local sizeY = notifFrame.AbsoluteSize.Y
            if sizeY < 10 then sizeY = 60 end
            notifFrame.Size = UDim2.new(1, 0, 0, sizeY)
            Tween(notifFrame, { Size = UDim2.new(1, 0, 0, sizeY) }, 0.4, Enum.EasingStyle.Back)
            
            local startTime = tick()
            local conn
            conn = RunService.RenderStepped:Connect(function()
                if NotifObj.Closed then conn:Disconnect() return end
                local elapsed = tick() - startTime
                local remaining = math.max(0, duration - elapsed)
                TimerLbl.Text = string.format("[%ds]", math.ceil(remaining))
                ProgressBar.Size = UDim2.new(remaining/duration, 0, 1, 0)
                if remaining <= 0 then
                    conn:Disconnect()
                    NotifObj.OnTimeout:Fire()
                    destroyNotif()
                end
            end)
            table.insert(DevLib.Connections, conn)
        end
    end)

    return NotifObj
end

--=============================================================================================================================
-- [9] 🖥️ CORE ENGINE: CREATE WINDOW
--=============================================================================================================================
function DevLib:CreateWindow(options)
    if type(options) ~= "table" then options = {} end
    
    local windowTitle = options.Title or "Divine UI"
    local windowSubTitle = options.SubTitle or "Ultimate"
    local windowSize = options.Size or UDim2.fromOffset(650, 480)
    local themeName = options.Theme or "DEV"
    local useAcrylic = options.Acrylic == nil and true or options.Acrylic
    local tabWidth = options.TabWidth or 170

    DevLib:SetTheme(themeName)
    local theme = DevLib:GetTheme()

    local ScreenGui = Create("ScreenGui", { Name = "DevLibWindow", Parent = GUI_TARGET, ZIndexBehavior = Enum.ZIndexBehavior.Sibling, ResetOnSpawn = false, IgnoreGuiInset = true })

    local Blur
    if useAcrylic then
        Blur = Create("BlurEffect", { Size = 0, Parent = Lighting })
        table.insert(DevLib.Instances, Blur)
    end

    local MainFrame = Create("Frame", {
        Name = "MainFrame", Parent = ScreenGui, BackgroundColor3 = theme.MainBackground,
        BackgroundTransparency = useAcrylic and 0.15 or 0, Size = UDim2.fromScale(0, 0),
        Position = UDim2.fromScale(0.5, 0.5), AnchorPoint = Vector2.new(0.5, 0.5),
        ClipsDescendants = true, ZIndex = 10, Visible = false
    })
    Create("UICorner", { Parent = MainFrame, CornerRadius = UDim.new(0, 10) })
    Create("UIStroke", { Parent = MainFrame, Color = theme.StrokeColor, Thickness = 1 })
    Create("ImageLabel", {
        Name = "Shadow", Parent = MainFrame, BackgroundTransparency = 1, Image = "rbxassetid://6015897843",
        ImageColor3 = theme.Shadow, ImageTransparency = 0.5, ScaleType = Enum.ScaleType.Slice, SliceCenter = Rect.new(49, 49, 450, 450),
        Size = UDim2.new(1, 40, 1, 40), Position = UDim2.new(0, -20, 0, -20), ZIndex = 9
    })

    -- 📜 Signal Setup
    local WindowObj = {
        Tabs = {}, ActiveTab = nil, Gui = ScreenGui, Main = MainFrame, Blur = Blur,
        OriginalSize = windowSize, IsMinimized = false, IsExpanded = false,
        OnResize = Signal.new(), OnExpand = Signal.new(), OnRestore = Signal.new(),
        OnMinimize = Signal.new(), OnDestroy = Signal.new(),
        ResizeLimits = { MinWidth = 450, MinHeight = 350, MaxWidth = 1400, MaxHeight = 900 }
    }

    function WindowObj:SetResizeLimits(limits)
        if type(limits) == "table" then
            for k, v in pairs(limits) do self.ResizeLimits[k] = v end
        end
    end

    --=========================================================================
    -- 📐 ABSOLUTE MATH RESIZE SYSTEM (8 Grabbers)
    --=========================================================================
    local function CreateGrabber(name, size, pos, cursor, actionX, actionY)
        local Grabber = Create("Frame", {
            Name = "Grab_" .. name, Parent = MainFrame, BackgroundTransparency = 1,
            Size = size, Position = pos, AnchorPoint = Vector2.new(0.5, 0.5), ZIndex = 100
        })
        local dragging = false
        local dragStartPos, startSize, startPos

        Grabber.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                dragging = true
                dragStartPos = input.Position
                startSize = MainFrame.AbsoluteSize
                startPos = MainFrame.AbsolutePosition
                
                local releaseConn
                releaseConn = input.Changed:Connect(function()
                    if input.UserInputState == Enum.UserInputState.End then
                        dragging = false
                        if releaseConn then releaseConn:Disconnect() releaseConn = nil end
                    end
                end)
            end
        end)

        UserInputService.InputChanged:Connect(function(input)
            if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                local delta = input.Position - dragStartPos
                local newW = startSize.X
                local newH = startSize.Y
                local newX = startPos.X + (startSize.X/2) 
                local newY = startPos.Y + (startSize.Y/2)

                if actionX == 1 then
                    newW = math.clamp(startSize.X + delta.X, WindowObj.ResizeLimits.MinWidth, WindowObj.ResizeLimits.MaxWidth)
                    newX = startPos.X + (newW/2)
                elseif actionX == -1 then
                    newW = math.clamp(startSize.X - delta.X, WindowObj.ResizeLimits.MinWidth, WindowObj.ResizeLimits.MaxWidth)
                    newX = (startPos.X + startSize.X) - (newW/2)
                end

                if actionY == 1 then
                    newH = math.clamp(startSize.Y + delta.Y, WindowObj.ResizeLimits.MinHeight, WindowObj.ResizeLimits.MaxHeight)
                    newY = startPos.Y + (newH/2)
                elseif actionY == -1 then
                    newH = math.clamp(startSize.Y - delta.Y, WindowObj.ResizeLimits.MinHeight, WindowObj.ResizeLimits.MaxHeight)
                    newY = (startPos.Y + startSize.Y) - (newH/2)
                end

                MainFrame.Size = UDim2.fromOffset(newW, newH)
                MainFrame.Position = UDim2.fromOffset(newX, newY)
                WindowObj.OriginalSize = MainFrame.Size
                WindowObj.OnResize:Fire(newW, newH)
            end
        end)
    end

    CreateGrabber("Right", UDim2.new(0, 10, 1, -20), UDim2.new(1, 0, 0.5, 0), "SizeEW", 1, 0)
    CreateGrabber("Left", UDim2.new(0, 10, 1, -20), UDim2.new(0, 0, 0.5, 0), "SizeEW", -1, 0)
    CreateGrabber("Bottom", UDim2.new(1, -20, 0, 10), UDim2.new(0.5, 0, 1, 0), "SizeNS", 0, 1)
    CreateGrabber("Top", UDim2.new(1, -20, 0, 10), UDim2.new(0.5, 0, 0, 0), "SizeNS", 0, -1)
    CreateGrabber("BR", UDim2.new(0, 15, 0, 15), UDim2.new(1, 0, 1, 0), "SizeNWSE", 1, 1)
    CreateGrabber("BL", UDim2.new(0, 15, 0, 15), UDim2.new(0, 0, 1, 0), "SizeNESW", -1, 1)
    CreateGrabber("TR", UDim2.new(0, 15, 0, 15), UDim2.new(1, 0, 0, 0), "SizeNESW", 1, -1)
    CreateGrabber("TL", UDim2.new(0, 15, 0, 15), UDim2.new(0, 0, 0, 0), "SizeNWSE", -1, -1)

