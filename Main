        function TabObj:AddCounter(title)
            local count = 0
            local F = Create("Frame", { Parent = TabContainer, BackgroundColor3=theme.ElementBackground, Size=UDim2.new(1,0,0,40) }, { Create("UICorner", { CornerRadius=UDim.new(0,6) }) })
            Create("TextLabel", { Parent = F, BackgroundTransparency=1, Size=UDim2.new(0.5,0,1,0), Position=UDim2.new(0,10,0,0), Font=Enum.Font.GothamMedium, Text=title, TextColor3=theme.Text, TextSize=14, TextXAlignment=Enum.TextXAlignment.Left })
            local BtnM = Create("TextButton", { Parent = F, BackgroundColor3=theme.TabBackground, Size=UDim2.new(0,30,0,30), Position=UDim2.new(1,-110,0.5,0), AnchorPoint=Vector2.new(0,0.5), Font=Enum.Font.GothamBold, Text="-", TextColor3=theme.Text, TextSize=16 }, { Create("UICorner", { CornerRadius=UDim.new(0,4) }) })
            local Lbl = Create("TextLabel", { Parent = F, BackgroundTransparency=1, Size=UDim2.new(0,30,1,0), Position=UDim2.new(1,-75,0,0), Font=Enum.Font.GothamBold, Text="0", TextColor3=theme.Accent, TextSize=16 })
            local BtnP = Create("TextButton", { Parent = F, BackgroundColor3=theme.TabBackground, Size=UDim2.new(0,30,0,30), Position=UDim2.new(1,-40,0.5,0), AnchorPoint=Vector2.new(0,0.5), Font=Enum.Font.GothamBold, Text="+", TextColor3=theme.Text, TextSize=16 }, { Create("UICorner", { CornerRadius=UDim.new(0,4) }) })
            BtnM.MouseButton1Click:Connect(function() count = count - 1 Lbl.Text = tostring(count) end)
            BtnP.MouseButton1Click:Connect(function() count = count + 1 Lbl.Text = tostring(count) end)
        end

        function TabObj:AddFPSCounter()
            local F = TabObj:AddStatistic("FPS", "0")
            local last = tick()
            RunService.RenderStepped:Connect(function()
                local n = tick()
                F:SetValue(math.floor(1 / (n - last)))
                last = n
            end)
        end

        function TabObj:AddLoadingSpinner()
            local Img = Create("ImageLabel", { Parent = TabContainer, BackgroundTransparency=1, Size=UDim2.new(0,40,0,40), Image="rbxassetid://10723396652", ImageColor3=theme.Accent })
            task.spawn(function() while Img.Parent do Tween(Img, {Rotation=Img.Rotation+180}, 0.5, Enum.EasingStyle.Linear) task.wait(0.5) end end)
        end

        function TabObj:AddLoadingBar()
            local F = Create("Frame", { Parent = TabContainer, BackgroundColor3=theme.ElementBackground, Size=UDim2.new(1,0,0,10) }, { Create("UICorner", { CornerRadius=UDim.new(1,0) }) })
            local Bar = Create("Frame", { Parent = F, BackgroundColor3=theme.Accent, Size=UDim2.new(0,0,1,0) }, { Create("UICorner", { CornerRadius=UDim.new(1,0) }) })
            return { SetProgress = function(self, pct) Tween(Bar, {Size=UDim2.new(math.clamp(pct,0,1),0,1,0)}, 0.2) end }
        end

        function TabObj:AddCircleProgress()
