        function TabObj:AddFolder(name)
            local Folder = Create("Frame", { Parent = TabContainer, BackgroundColor3 = theme.ElementBackground, Size = UDim2.new(1, 0, 0, 40), ClipsDescendants = true }, { Create("UICorner", { CornerRadius=UDim.new(0,6) }), Create("UIStroke", { Color=theme.StrokeColor, Thickness=1 }) })
            local Btn = Create("TextButton", { Parent = Folder, BackgroundTransparency=1, Size=UDim2.new(1,0,0,40), Text="" })
            local Lbl = Create("TextLabel", { Parent = Btn, BackgroundTransparency=1, Size=UDim2.new(1,-40,1,0), Position=UDim2.new(0,10,0,0), Font=Enum.Font.GothamBold, Text="+ " .. name, TextColor3=theme.Accent, TextSize=14, TextXAlignment=Enum.TextXAlignment.Left })
            local Content = Create("Frame", { Parent = Folder, BackgroundTransparency=1, Size=UDim2.new(1,0,0,0), Position=UDim2.new(0,0,0,40), AutomaticSize=Enum.AutomaticSize.Y })
            Create("UIListLayout", { Parent = Content, Padding=UDim.new(0,5) })
            Create("UIPadding", { Parent = Content, PaddingTop=UDim.new(0,5), PaddingBottom=UDim.new(0,5), PaddingLeft=UDim.new(0,15), PaddingRight=UDim.new(0,5) })
            local open = false
            Btn.MouseButton1Click:Connect(function() open = not open Lbl.Text = (open and "- " or "+ ") .. name Tween(Folder, {Size = open and UDim2.new(1,0,0,40 + Content.AbsoluteSize.Y) or UDim2.new(1,0,0,40)}, 0.3, Enum.EasingStyle.Exponential) end)
            Content:GetPropertyChangedSignal("AbsoluteSize"):Connect(function() if open then Tween(Folder, {Size = UDim2.new(1,0,0,40 + Content.AbsoluteSize.Y)}, 0.1) end end)
            return { Container = Content }
        end
        TabObj.AddAccordion = TabObj.AddFolder

        function TabObj:AddExplorer(parentInstance)
            local F = TabObj:AddFolder("Explorer: " .. parentInstance.Name)
            for _, child in ipairs(parentInstance:GetChildren()) do
                Create("TextLabel", { Parent = F.Container, BackgroundTransparency=1, Size=UDim2.new(1,0,0,20), Font=Enum.Font.Gotham, Text=child.Name .. "  <font color='rgb(150,150,150)'>["..child.ClassName.."]</font>", RichText=true, TextColor3=theme.Text, TextSize=13, TextXAlignment=Enum.TextXAlignment.Left })
            end
        end
