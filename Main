        function TabObj:AddSyntaxHighlighter(codeStr)
            local function highlight(c)
                local res = c:gsub("local", "<font color='rgb(86,156,214)'>local</font>")
                res = res:gsub("function", "<font color='rgb(86,156,214)'>function</font>")
                res = res:gsub("end", "<font color='rgb(86,156,214)'>end</font>")
                res = res:gsub("if", "<font color='rgb(197,134,192)'>if</font>")
                res = res:gsub("then", "<font color='rgb(197,134,192)'>then</font>")
                res = res:gsub("else", "<font color='rgb(197,134,192)'>else</font>")
                return res
            end
            
            local Frame = Create("Frame", {
                Parent = TabContainer,
                BackgroundColor3 = Color3.fromRGB(20,20,20),
                Size = UDim2.new(1, 0, 0, 150),
                ClipsDescendants = true,
                ZIndex = 4
            })
            Create("UICorner", { Parent = Frame, CornerRadius=UDim.new(0,6) })
            Create("UIStroke", { Parent = Frame, Color=theme.StrokeColor, Thickness=1 })
            
            Create("TextLabel", {
                Parent = Frame,
                BackgroundTransparency = 1,
                Size = UDim2.new(1,-20,1,-10),
                Position = UDim2.new(0,10,0,5),
                Font = Enum.Font.Code,
                Text = highlight(codeStr),
                RichText = true,
                TextColor3 = theme.Text,
                TextSize = 13,
                TextXAlignment = Enum.TextXAlignment.Left,
                TextYAlignment = Enum.TextYAlignment.Top,
                TextWrapped = true,
                ZIndex = 5
            })
        end

