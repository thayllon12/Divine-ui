                    local cp = TabObj:AddColorpicker({
                        Title = k,
                        Default = v,
                        Callback = function(c)
                            theme[k] = c
                            WindowObj:Maximize()
                            WindowObj:Minimize()
                            WindowObj:Maximize()
                        end
                    })
                end
            end
        end
