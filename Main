                Create("TextLabel", { Parent = ev, BackgroundTransparency=1, Size=UDim2.new(1,-30,1,0), Position=UDim2.new(0,30,0,0), Font=Enum.Font.GothamMedium, Text=e, TextColor3=theme.Text, TextSize=13, TextXAlignment=Enum.TextXAlignment.Left })
            end
        end

