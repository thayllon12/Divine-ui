        function TabObj:AddPlayerCard(player)
            local Card = Create("Frame", { Parent = TabContainer, BackgroundColor3 = theme.ElementBackground, Size = UDim2.new(1, 0, 0, 80) }, { Create("UICorner", { CornerRadius=UDim.new(0,6) }), Create("UIStroke", { Color=theme.StrokeColor, Thickness=1 }) })
            Create("ImageLabel", { Parent = Card, BackgroundTransparency=1, Size=UDim2.new(0,60,0,60), Position=UDim2.new(0,10,0,10), Image="rbxthumb://type=AvatarHeadShot&id="..player.UserId.."&w=150&h=150" }, { Create("UICorner", { CornerRadius=UDim.new(1,0) }) })
            Create("TextLabel", { Parent = Card, BackgroundTransparency=1, Size=UDim2.new(1,-90,0,30), Position=UDim2.new(0,80,0,10), Font=Enum.Font.GothamBold, Text=player.DisplayName .. " (@"..player.Name..")", TextColor3=theme.Text, TextSize=16, TextXAlignment=Enum.TextXAlignment.Left })
            local HealthLbl = Create("TextLabel", { Parent = Card, BackgroundTransparency=1, Size=UDim2.new(1,-90,0,30), Position=UDim2.new(0,80,0,40), Font=Enum.Font.Gotham, Text="Health: 100", TextColor3=theme.Success, TextSize=13, TextXAlignment=Enum.TextXAlignment.Left })
            task.spawn(function()
                while Card.Parent and player.Character do
                    local hum = player.Character:FindFirstChild("Humanoid")
                    if hum then HealthLbl.Text = "Health: " .. math.floor(hum.Health) .. "/" .. math.floor(hum.MaxHealth) end
                    task.wait(0.5)
                end
            end)
        end

