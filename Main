        function TabObj:AddCanvas()
            local F = Create("Frame", {
                Parent = TabContainer,
                BackgroundColor3=Color3.new(1,1,1),
                Size=UDim2.new(1, 0, 0, 200),
                ClipsDescendants=true,
                ZIndex=4
            })
            Create("UICorner", { Parent = F, CornerRadius=UDim.new(0,6) })
            
            local drawing = false
            F.InputBegan:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 then drawing = true end
            end)
            UserInputService.InputEnded:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 then drawing = false end
            end)
            F.InputChanged:Connect(function(i)
                if drawing and i.UserInputType == Enum.UserInputType.MouseMovement then
                    local dot = Create("Frame", {
                        Parent = F,
                        BackgroundColor3=theme.Accent,
                        Size=UDim2.new(0,6,0,6),
                        Position=UDim2.new(0, i.Position.X - F.AbsolutePosition.X, 0, i.Position.Y - F.AbsolutePosition.Y),
                        AnchorPoint=Vector2.new(0.5,0.5),
                        BorderSizePixel=0,
                        ZIndex=5
                    })
                    Create("UICorner", { Parent = dot, CornerRadius=UDim.new(1,0) })
                end
            end)
        end
        TabObj.AddDrawingBoard = TabObj.AddCanvas

        function TabObj:AddColorWheel() TabObj:AddColorpicker({Title="Color Wheel Editor"}) end
        function TabObj:AddColorPalette() TabObj:AddColorpicker({Title="Color Palette"}) end

