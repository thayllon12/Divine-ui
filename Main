        end

        function TabObj:AddTreeView(treeData)
            local Tree = Create("Frame", { Parent = TabContainer, BackgroundTransparency = 1, Size = UDim2.new(1,0,0,0), AutomaticSize = Enum.AutomaticSize.Y })
            local List = Create("UIListLayout", { Parent = Tree, Padding = UDim.new(0,2) })
            local function r(node, parent, level)
                for k, v in pairs(node) do
                    local btn = Create("TextButton", { Parent = parent, BackgroundTransparency = 1, Size = UDim2.new(1,0,0,25), Text = "", AutoButtonColor = false })
                    Create("TextLabel", { Parent = btn, BackgroundTransparency = 1, Size = UDim2.new(1, -(level*15), 1, 0), Position = UDim2.new(0, level*15, 0, 0), Font = Enum.Font.Gotham, Text = (type(v) == "table" and "+ " or "- ") .. k, TextColor3 = theme.Text, TextSize = 13, TextXAlignment = Enum.TextXAlignment.Left })
                    if type(v) == "table" then
                        local sub = Create("Frame", { Parent = parent, BackgroundTransparency = 1, Size = UDim2.new(1,0,0,0), AutomaticSize = Enum.AutomaticSize.Y, Visible = false })
                        Create("UIListLayout", { Parent = sub, Padding = UDim.new(0,2) })
                        btn.MouseButton1Click:Connect(function() sub.Visible = not sub.Visible btn.TextLabel.Text = (sub.Visible and "- " or "+ ") .. k end)
                        r(v, sub, level + 1)
                    end
                end
            end
            r(treeData, Tree, 1)
        end

        function TabObj:AddFolder(name)
            local Folder = Create("Frame", { Parent = TabContainer, BackgroundColor3 = theme.ElementBackground, Size = UDim2.new(1,0,0,40), ClipsDescendants = true }, { Create("UICorner", { CornerRadius=UDim.new(0,6) }) })
            local Btn = Create("TextButton", { Parent = Folder, BackgroundTransparency=1, Size=UDim2.new(1,0,0,40), Text="" })
            Create("TextLabel", { Parent = Btn, BackgroundTransparency=1, Size=UDim2.new(1,-40,1,0), Position=UDim2.new(0,10,0,0), Font=Enum.Font.GothamBold, Text=name, TextColor3=theme.Accent, TextSize=14, TextXAlignment=Enum.TextXAlignment.Left })
            local Content = Create("Frame", { Parent = Folder, BackgroundTransparency=1, Size=UDim2.new(1,0,0,0), Position=UDim2.new(0,0,0,40), AutomaticSize=Enum.AutomaticSize.Y })
            Create("UIListLayout", { Parent = Content, Padding=UDim.new(0,5) })
            Create("UIPadding", { Parent = Content, PaddingTop=UDim.new(0,5), PaddingBottom=UDim.new(0,5), PaddingLeft=UDim.new(0,5), PaddingRight=UDim.new(0,5) })
            local open = false
            Btn.MouseButton1Click:Connect(function() open = not open Tween(Folder, {Size = open and UDim2.new(1,0,0,40 + Content.AbsoluteSize.Y) or UDim2.new(1,0,0,40)}, 0.3) end)
            Content:GetPropertyChangedSignal("AbsoluteSize"):Connect(function() if open then Tween(Folder, {Size = UDim2.new(1,0,0,40 + Content.AbsoluteSize.Y)}, 0.1) end end)
            return { Container = Content }
        end

        function TabObj:AddExplorer(parentInstance)
