        function TabObj:AddThemeEditor()
            for k, v in pairs(DevLib.Themes.Dark) do
                if typeof(v) == "Color3" then
                    TabObj:AddColorPicker(k.."_ed", {Title = k, Default = v, Callback = function(c)
                        theme[k] = c
                        WindowObj:Maximize()
                        WindowObj:Minimize()
                        WindowObj:Maximize()
                    end})
                end
            end
        end
        TabObj.AddThemeCreator = TabObj.AddThemeEditor

