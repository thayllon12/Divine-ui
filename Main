        function TabObj:AddCommandBar(callback)
            local Inp = Create("TextBox", {
                Parent = TabContainer,
                BackgroundColor3=theme.ElementBackground,
                Size=UDim2.new(1, 0, 0, 45),
                Font=Enum.Font.Code,
