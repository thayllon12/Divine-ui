function DevLib:CreateWindow(options)
    if type(options) ~= "table" then options = {} end
    
    local windowTitle = options.Title or "DevLib"
    local windowSubTitle = options.SubTitle or "Edition"
    local windowSize = options.Size or UDim2.fromOffset(580, 460)
    local themeName = options.Theme or "DEV"
    local useAcrylic = options.Acrylic == nil and true or options.Acrylic
    local minimizeKey = options.MinimizeKey or Enum.KeyCode.RightControl
    local tabWidth = options.TabWidth or 160
    local keySystem = options.KeySystem or false
    local keySettings = options.KeySettings or {}

    DevLib:SetTheme(themeName)
    local theme = DevLib:GetTheme()

    local ScreenGui = Create("ScreenGui", {
        Name = "DevLibWindow",
        Parent = GUI_TARGET,
        ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
        ResetOnSpawn = false,
        IgnoreGuiInset = true
    })

    local Blur
    if useAcrylic then
        Blur = Create("BlurEffect", {
            Size = 0,
            Parent = Lighting
        })
        table.insert(DevLib.Instances, Blur)
    end

    local MainFrame = Create("Frame", {
        Name = "MainFrame",
        Parent = ScreenGui,
        BackgroundColor3 = theme.MainBackground,
        BackgroundTransparency = useAcrylic and 0.15 or 0,
        Size = UDim2.fromScale(0, 0),
        Position = UDim2.fromScale(0.5, 0.5),
        AnchorPoint = Vector2.new(0.5, 0.5),
        ClipsDescendants = true,
        ZIndex = 1,
        Visible = false
    })
    
    Create("UICorner", { Parent = MainFrame, CornerRadius = UDim.new(0, 10) })
    Create("UIStroke", { Parent = MainFrame, Color = theme.StrokeColor, Thickness = 1 })
    
    Create("ImageLabel", {
        Name = "Shadow",
        Parent = MainFrame,
        BackgroundTransparency = 1,
        Image = "rbxassetid://6015897843",
        ImageColor3 = theme.Shadow,
        ImageTransparency = 0.5,
        ScaleType = Enum.ScaleType.Slice,
        SliceCenter = Rect.new(49, 49, 450, 450),
        Size = UDim2.new(1, 40, 1, 40),
        Position = UDim2.new(0, -20, 0, -20),
        ZIndex = 0
    })

    local function OpenMainUI()
        MainFrame.Visible = true
        Tween(MainFrame, { Size = windowSize }, 0.5, Enum.EasingStyle.Exponential)
        if useAcrylic and Blur then
            Tween(Blur, { Size = 15 }, 0.5)
        end
    end

    if keySystem then
        local validKeys = keySettings.Keys or {"DevLib123"}
        local savedKeyPath = "DevLibKey.txt"
        local hasSavedKey = false
        
        if isfile and readfile then
            pcall(function()
                if isfile(savedKeyPath) then
                    local sKey = readfile(savedKeyPath)
                    for _, k in pairs(validKeys) do
                        if k == sKey then
                            hasSavedKey = true
                            break
                        end
                    end
                end
            end)
        end

        if hasSavedKey then
            OpenMainUI()
        else
            if useAcrylic and Blur then
                Tween(Blur, { Size = 15 }, 0.5)
            end
            
            local KeyFrame = Create("Frame", {
                Parent = ScreenGui,
                BackgroundColor3 = theme.WindowBackground,
                Size = UDim2.new(0, 400, 0, 200),
                Position = UDim2.fromScale(0.5, 0.5),
                AnchorPoint = Vector2.new(0.5, 0.5),
                ClipsDescendants = true
            })
            
            Create("UICorner", { Parent = KeyFrame, CornerRadius = UDim.new(0, 10) })
            Create("UIStroke", { Parent = KeyFrame, Color = theme.StrokeColor, Thickness = 1 })
            
            Create("TextLabel", {
                Parent = KeyFrame,
                BackgroundTransparency = 1,
                Size = UDim2.new(1, 0, 0, 40),
                Font = Enum.Font.GothamBold,
                Text = keySettings.Title or "Key System",
                TextColor3 = theme.Text,
                TextSize = 18
            })
            
            Create("TextLabel", {
                Parent = KeyFrame,
                BackgroundTransparency = 1,
                Size = UDim2.new(1, 0, 0, 20),
                Position = UDim2.new(0, 0, 0, 40),
                Font = Enum.Font.Gotham,
                Text = keySettings.Note or "Enter your key to continue",
                TextColor3 = theme.SubText,
                TextSize = 13
            })
            
            local KeyInput = Create("TextBox", {
                Name = "KeyInput",
                Parent = KeyFrame,
                BackgroundColor3 = theme.ElementBackground,
                Size = UDim2.new(1, -40, 0, 40),
                Position = UDim2.new(0, 20, 0, 80),
                Font = Enum.Font.Gotham,
                PlaceholderText = "Enter Key Here...",
                Text = "",
                TextColor3 = theme.Text,
                TextSize = 14,
                ClearTextOnFocus = false
            })
            Create("UICorner", { Parent = KeyInput, CornerRadius = UDim.new(0, 6) })
            local KeyStroke = Create("UIStroke", { Parent = KeyInput, Color = theme.StrokeColor, Thickness = 1 })
            
            local CheckBtn = Create("TextButton", {
                Name = "CheckBtn",
                Parent = KeyFrame,
                BackgroundColor3 = theme.Accent,
                Size = UDim2.new(1, -40, 0, 40),
                Position = UDim2.new(0, 20, 0, 135),
                Font = Enum.Font.GothamBold,
                Text = "Verify Key",
                TextColor3 = Color3.fromRGB(255, 255, 255),
                TextSize = 14
            })
            Create("UICorner", { Parent = CheckBtn, CornerRadius = UDim.new(0, 6) })
            
            KeyFrame.Size = UDim2.new(0,0,0,0)
            Tween(KeyFrame, {Size = UDim2.new(0,400,0,200)}, 0.5, Enum.EasingStyle.Exponential)

            CheckBtn.MouseButton1Click:Connect(function()
                local typed = KeyInput.Text
                local correct = false
                for _, k in pairs(validKeys) do
                    if k == typed then
                        correct = true
                        break
                    end
                end
                if correct then
                    if writefile then
                        pcall(writefile, savedKeyPath, typed)
                    end
                    Tween(KeyFrame, {Size = UDim2.new(0,0,0,0)}, 0.5, Enum.EasingStyle.Exponential)
                    task.delay(0.5, function()
                        KeyFrame:Destroy()
                        OpenMainUI()
                    end)
                else
                    KeyInput.Text = "INVALID KEY"
                    Tween(KeyStroke, {Color = theme.Error}, 0.2)
                    task.delay(1, function()
                        KeyInput.Text = ""
                        Tween(KeyStroke, {Color = theme.StrokeColor}, 0.2)
                    end)
                end
            end)
        end
    else
        OpenMainUI()
    end

    local Topbar = Create("Frame", {
        Name = "Topbar",
        Parent = MainFrame,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 45),
        Position = UDim2.new(0, 0, 0, 0),
        ZIndex = 2
    })
    
    Create("Frame", {
        Parent = Topbar,
        BackgroundColor3 = theme.StrokeColor,
        Size = UDim2.new(1, 0, 0, 1),
        Position = UDim2.new(0, 0, 1, -1),
        BorderSizePixel = 0,
        ZIndex = 2
    })

    MakeDraggable(Topbar, MainFrame)

    local TitleLabel = Create("TextLabel", {
        Name = "Title",
        Parent = Topbar,
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 15, 0, 0),
        Size = UDim2.new(0, 0, 1, 0),
        AutomaticSize = Enum.AutomaticSize.X,
        Font = Enum.Font.GothamBold,
        Text = windowTitle,
        TextColor3 = theme.Text,
        TextSize = 16,
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 3
    })

    local SubTitleLabel = Create("TextLabel", {
        Name = "SubTitle",
        Parent = Topbar,
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 15, 0, 0),
        Size = UDim2.new(0, 0, 1, 0),
        AutomaticSize = Enum.AutomaticSize.X,
        Font = Enum.Font.Gotham,
        Text = windowSubTitle,
        TextColor3 = theme.SubText,
        TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 3
    })

    TitleLabel:GetPropertyChangedSignal("AbsoluteSize"):Connect(function()
        SubTitleLabel.Position = UDim2.new(0, TitleLabel.AbsoluteSize.X + 25, 0, 0)
    end)
    
    task.defer(function()
        if TitleLabel and TitleLabel.Parent then
            SubTitleLabel.Position = UDim2.new(0, TitleLabel.AbsoluteSize.X + 25, 0, 0)
        end
    end)

    local Sidebar = Create("Frame", {
        Name = "Sidebar",
        Parent = MainFrame,
        BackgroundColor3 = theme.WindowBackground,
        BackgroundTransparency = 0.5,
        Size = UDim2.new(0, tabWidth, 1, -45),
        Position = UDim2.new(0, 0, 0, 45),
        ZIndex = 2
    })
    
    Create("UIStroke", { Parent = Sidebar, Color = theme.StrokeColor, Thickness = 1 })
    
    local TabList = Create("ScrollingFrame", {
        Name = "TabList",
        Parent = Sidebar,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 1, 0),
        ScrollBarThickness = 0,
        CanvasSize = UDim2.new(0, 0, 0, 0),
        AutomaticCanvasSize = Enum.AutomaticSize.Y,
        ZIndex = 3
    })
    
    Create("UIListLayout", {
        Parent = TabList,
        Padding = UDim.new(0, 5),
        HorizontalAlignment = Enum.HorizontalAlignment.Center
    })
    
    Create("UIPadding", {
        Parent = TabList,
        PaddingTop = UDim.new(0, 10),
        PaddingBottom = UDim.new(0, 10)
    })

    local ContentContainer = Create("Frame", {
        Name = "ContentContainer",
        Parent = MainFrame,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, -tabWidth, 1, -45),
        Position = UDim2.new(0, tabWidth, 0, 45),
        ZIndex = 2
    })

    local WindowObj = {
        Tabs = {},
        ActiveTab = nil,
        Gui = ScreenGui,
        Main = MainFrame,
        Blur = Blur,
        OriginalSize = windowSize,
        IsMinimized = false
    }

    function WindowObj:Destroy()
        for _, conn in ipairs(DevLib.Connections) do
            if conn then
                pcall(function() conn:Disconnect() end)
            end
        end
        for _, inst in ipairs(DevLib.Instances) do
            if inst then
                pcall(function() inst:Destroy() end)
            end
        end
        DevLib.Connections = {}
        DevLib.Instances = {}
        if DevLib.NotificationGui then
            pcall(function() DevLib.NotificationGui:Destroy() end)
        end
        if self.Gui then
            pcall(function() self.Gui:Destroy() end)
        end
    end

    function WindowObj:Dialog(dlgOptions)
        if type(dlgOptions) ~= "table" then dlgOptions = {} end
        local title = dlgOptions.Title or "Dialog"
        local content = dlgOptions.Content or "Content"
        local buttons = dlgOptions.Buttons or {}
        
        local DialogBG = Create("Frame", {
            Parent = ScreenGui,
            BackgroundColor3 = Color3.new(0, 0, 0),
            BackgroundTransparency = 1,
            Size = UDim2.new(1, 0, 1, 0),
            ZIndex = 9999
        })
        Tween(DialogBG, { BackgroundTransparency = 0.5 }, 0.3)
        
        local DialogFrame = Create("Frame", {
            Parent = DialogBG,
            BackgroundColor3 = theme.WindowBackground,
            Size = UDim2.new(0, 340, 0, 180),
            Position = UDim2.fromScale(0.5, 0.5),
            AnchorPoint = Vector2.new(0.5, 0.5),
            ClipsDescendants = true,
            ZIndex = 10000
        })
        
        Create("UICorner", { Parent = DialogFrame, CornerRadius = UDim.new(0, 10) })
        Create("UIStroke", { Parent = DialogFrame, Color = theme.StrokeColor, Thickness = 1 })
        
        Create("TextLabel", {
            Parent = DialogFrame,
            BackgroundTransparency = 1,
            Size = UDim2.new(1, -40, 0, 40),
            Position = UDim2.new(0, 20, 0, 10),
            Font = Enum.Font.GothamBold,
            Text = title,
            TextColor3 = theme.Text,
            TextSize = 16,
            TextXAlignment = Enum.TextXAlignment.Left,
            ZIndex = 10001
        })
        
        Create("TextLabel", {
            Parent = DialogFrame,
            BackgroundTransparency = 1,
            Size = UDim2.new(1, -40, 1, -110),
            Position = UDim2.new(0, 20, 0, 50),
            Font = Enum.Font.Gotham,
            Text = content,
            TextColor3 = theme.SubText,
            TextSize = 13,
            TextXAlignment = Enum.TextXAlignment.Left,
            TextYAlignment = Enum.TextYAlignment.Top,
            TextWrapped = true,
            ZIndex = 10001
        })
        
        local ButtonContainer = Create("Frame", {
            Parent = DialogFrame,
            BackgroundTransparency = 1,
            Size = UDim2.new(1, -40, 0, 40),
            Position = UDim2.new(0, 20, 1, -50),
            ZIndex = 10001
        })
        
        Create("UIListLayout", {
            Parent = ButtonContainer,
            FillDirection = Enum.FillDirection.Horizontal,
            HorizontalAlignment = Enum.HorizontalAlignment.Right,
            VerticalAlignment = Enum.VerticalAlignment.Center,
            Padding = UDim.new(0, 10)
        })
        
        for _, btnData in ipairs(buttons) do
            local Btn = Create("TextButton", {
                Parent = ButtonContainer,
                BackgroundColor3 = theme.ElementBackground,
                Size = UDim2.new(0, 100, 0, 35),
                Font = Enum.Font.GothamMedium,
                Text = btnData.Title or "Btn",
                TextColor3 = theme.Text,
                TextSize = 13,
                AutoButtonColor = false,
                ZIndex = 10002
            })
            
            Create("UICorner", { Parent = Btn, CornerRadius = UDim.new(0, 6) })
            Create("UIStroke", { Parent = Btn, Color = theme.StrokeColor, Thickness = 1 })
            
            Btn.MouseEnter:Connect(function()
                Tween(Btn, { BackgroundColor3 = theme.ElementHover }, 0.2)
            end)
            
            Btn.MouseLeave:Connect(function()
                Tween(Btn, { BackgroundColor3 = theme.ElementBackground }, 0.2)
            end)
            
            Btn.MouseButton1Click:Connect(function()
                Tween(DialogBG, { BackgroundTransparency = 1 }, 0.3)
                Tween(DialogFrame, { Size = UDim2.new(0, 0, 0, 0) }, 0.3)
                task.delay(0.3, function()
                    if DialogBG then DialogBG:Destroy() end
                end)
                if btnData.Callback then
                    btnData.Callback()
                end
            end)
        end
        
        DialogFrame.Size = UDim2.new(0, 0, 0, 0)
        Tween(DialogFrame, { Size = UDim2.new(0, 340, 0, 180) }, 0.4, Enum.EasingStyle.Back)
    end

    function WindowObj:Minimize()
        self.IsMinimized = true
        Tween(MainFrame, { Size = UDim2.fromScale(0, 0), BackgroundTransparency = 1 }, 0.5, Enum.EasingStyle.Exponential)
        if useAcrylic and Blur then
            Tween(Blur, { Size = 0 }, 0.5)
        end
        task.delay(0.5, function()
            if self.IsMinimized and MainFrame then
                MainFrame.Visible = false
            end
        end)
    end

    function WindowObj:Maximize()
        self.IsMinimized = false
        MainFrame.Visible = true
        Tween(MainFrame, { Size = self.OriginalSize, BackgroundTransparency = useAcrylic and 0.15 or 0 }, 0.5, Enum.EasingStyle.Exponential)
        if useAcrylic and Blur then
            Tween(Blur, { Size = 15 }, 0.5)
        end
    end

    local minimConn = UserInputService.InputBegan:Connect(function(input, gpe)
        if not gpe and input.KeyCode == minimizeKey then
            if WindowObj.IsMinimized then
                WindowObj:Maximize()
            else
                WindowObj:Minimize()
            end
        end
    end)
    table.insert(DevLib.Connections, minimConn)

    function WindowObj:AddMinimizeButton(minOptions)
        if type(minOptions) ~= "table" then minOptions = {} end
        local minSize = minOptions.Size or UDim2.fromOffset(40, 40)
        local minPos = minOptions.Position or UDim2.new(1, -60, 1, -60)
        local minVisible = minOptions.Visible == nil and true or minOptions.Visible
        local minText = minOptions.Text or "DEV"

        local MinGui = Create("ScreenGui", {
            Parent = GUI_TARGET,
            ResetOnSpawn = false
        })
        table.insert(DevLib.Instances, MinGui)

        local FloatingBtn = Create("TextButton", {
            Parent = MinGui,
            Size = minSize,
            Position = minPos,
            BackgroundColor3 = theme.ElementBackground,
            Text = minText,
            Font = Enum.Font.GothamBold,
            TextColor3 = theme.Text,
            AutoButtonColor = false,
            Visible = minVisible
        })
        
        Create("UICorner", { Parent = FloatingBtn, CornerRadius = UDim.new(0, 20) })
        Create("UIStroke", { Parent = FloatingBtn, Color = theme.StrokeColor, Thickness = 2 })

        MakeDraggable(FloatingBtn, FloatingBtn)

        FloatingBtn.MouseButton1Click:Connect(function()
            if MainFrame.Visible then
                WindowObj:Minimize()
            else
                WindowObj:Maximize()
            end
        end)
    end

    function WindowObj:SelectTab(TabObj)
        WindowObj.ActiveTab = TabObj
        for _, t in pairs(WindowObj.Tabs) do
            t.Container.Visible = (t == TabObj)
            Tween(t.Button, { BackgroundTransparency = (t == TabObj) and 0 or 1 }, 0.2)
            Tween(t.Button.Title, { TextColor3 = (t == TabObj) and theme.Text or theme.SubText }, 0.2)
            if t.Button:FindFirstChild("Icon") then
                Tween(t.Button.Icon, { ImageColor3 = (t == TabObj) and theme.Accent or theme.SubText }, 0.2)
            end
            Tween(t.Button.Indicator, { Size = (t == TabObj) and UDim2.new(0, 3, 0, 20) or UDim2.new(0, 3, 0, 0) }, 0.2, Enum.EasingStyle.Back)
        end
    end

    function WindowObj:AddTab(tabOptions)
        if type(tabOptions) ~= "table" then tabOptions = {} end
        local tabTitle = tabOptions.Title or "Tab"
        local rawIcon = tabOptions.Icon or ""
        local hasIcon = rawIcon ~= ""
        local tabIcon = DevLib:GetIcon(rawIcon)

        local TabButton = Create("TextButton", {
            Parent = TabList,
            BackgroundColor3 = theme.ElementBackground,
            BackgroundTransparency = 1,
            Size = UDim2.new(1, -16, 0, 34),
            Text = "",
            AutoButtonColor = false,
            ZIndex = 4
        })
        
        Create("UICorner", { Parent = TabButton, CornerRadius = UDim.new(0, 6) })
        
        Create("TextLabel", {
            Name = "Title",
            Parent = TabButton,
            BackgroundTransparency = 1,
            Size = UDim2.new(1, hasIcon and -40 or -20, 1, 0),
            Position = UDim2.new(0, hasIcon and 35 or 15, 0, 0),
            Font = Enum.Font.GothamMedium,
            Text = tabTitle,
            TextColor3 = theme.SubText,
            TextSize = 13,
            TextXAlignment = Enum.TextXAlignment.Left,
            ZIndex = 5
        })
        
        local Indicator = Create("Frame", {
            Name = "Indicator",
            Parent = TabButton,
            BackgroundColor3 = theme.Accent,
            Size = UDim2.new(0, 3, 0, 0),
            Position = UDim2.new(0, 0, 0.5, 0),
            AnchorPoint = Vector2.new(0, 0.5),
            BackgroundTransparency = 1,
            ZIndex = 5
        })
        Create("UICorner", { Parent = Indicator, CornerRadius = UDim.new(0, 2) })
        
        if hasIcon then
            Create("ImageLabel", {
                Name = "Icon",
                Parent = TabButton,
                BackgroundTransparency = 1,
                Size = UDim2.new(0, 18, 0, 18),
                Position = UDim2.new(0, 10, 0.5, 0),
                AnchorPoint = Vector2.new(0, 0.5),
                Image = tabIcon,
                ImageColor3 = theme.SubText,
                ZIndex = 5
            })
        end

        local TabContainer = Create("ScrollingFrame", {
            Name = tabTitle .. "Container",
            Parent = ContentContainer,
            BackgroundTransparency = 1,
            Size = UDim2.new(1, 0, 1, 0),
            ScrollBarThickness = 2,
            ScrollBarImageColor3 = theme.StrokeColor,
            Visible = false,
            CanvasSize = UDim2.new(0, 0, 0, 0),
            AutomaticCanvasSize = Enum.AutomaticSize.Y,
            ZIndex = 3
        })
        
        Create("UIListLayout", {
            Parent = TabContainer,
            Padding = UDim.new(0, 10),
            HorizontalAlignment = Enum.HorizontalAlignment.Center
        })
        
        Create("UIPadding", {
            Parent = TabContainer,
            PaddingTop = UDim.new(0, 15),
            PaddingBottom = UDim.new(0, 15),
            PaddingLeft = UDim.new(0, 15),
            PaddingRight = UDim.new(0, 15)
        })

        local TabObj = {
            Name = tabTitle,
            Container = TabContainer,
            Button = TabButton
        }
        
        TabButton.MouseButton1Click:Connect(function()
            WindowObj:SelectTab(TabObj)
        end)
        
        table.insert(WindowObj.Tabs, TabObj)
        
        if #WindowObj.Tabs == 1 then
            WindowObj:SelectTab(TabObj)
        end

