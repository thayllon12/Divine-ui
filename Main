local GUI_TARGET = RunService:IsStudio() and LocalPlayer.PlayerGui or (gethui and gethui() or CoreGui)

local function Create(className, properties, children)
    local instance = Instance.new(className)
    for property, value in pairs(properties or {}) do
        instance[property] = value
    end
    for _, child in pairs(children or {}) do
        child.Parent = instance
    end
    table.insert(DevLib.Instances, instance)
    return instance
end

local function Tween(instance, properties, duration, style, direction)
    if not instance or not instance.Parent then return end
    local tweenInfo = TweenInfo.new(duration or 0.3, style or Enum.EasingStyle.Quad, direction or Enum.EasingDirection.Out)
    local tween = TweenService:Create(instance, tweenInfo, properties)
    tween:Play()
    return tween
end

local function MakeDraggable(dragPart, targetPart)
    local dragging = false
    local dragInput, mousePos, framePos

    local conn1 = dragPart.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            mousePos = input.Position
            framePos = targetPart.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)

    local conn2 = dragPart.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)

    local conn3 = UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - mousePos
            targetPart.Position = UDim2.new(framePos.X.Scale, framePos.X.Offset + delta.X, framePos.Y.Scale, framePos.Y.Offset + delta.Y)
        end
    end)

    table.insert(DevLib.Connections, conn1)
    table.insert(DevLib.Connections, conn2)
    table.insert(DevLib.Connections, conn3)
end

function DevLib:GetIcon(name)
    if not name or name == "" then return "" end
    if string.find(name, "rbxassetid") then return name end
    if DevLib.Icons["lucide-" .. name] then return DevLib.Icons["lucide-" .. name] end
    if DevLib.Icons[name] then return DevLib.Icons[name] end
    return ""
end

function DevLib:SetTheme(name)
    if DevLib.Themes[name] then DevLib.CurrentTheme = name end
end

function DevLib:GetTheme()
    return DevLib.Themes[DevLib.CurrentTheme]
end

function DevLib:SendWebhook(url, embedData)
    if not RequestFunc then return end
    local data = {
        username = "DevLib System",
        avatar_url = "https://i.imgur.com/3Z6KxH7.png",
        embeds = {embedData}
    }
    pcall(function()
        RequestFunc({
            Url = url,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode(data)
        })
    end)
end

function DevLib:SaveConfig(customName)
    local name = customName or DevLib.SaveName
    if writefile then
        local success, encoded = pcall(HttpService.JSONEncode, HttpService, DevLib.Flags)
        if success then writefile(name .. ".json", encoded) end
    end
end

function DevLib:LoadConfig(customName)
    local name = customName or DevLib.SaveName
    if readfile and isfile and isfile(name .. ".json") then
        local success, decoded = pcall(HttpService.JSONDecode, HttpService, readfile(name .. ".json"))
        if success then
            for key, value in pairs(decoded) do
                if DevLib.Options[key] and type(DevLib.Options[key].SetValue) == "function" then
                    pcall(function() DevLib.Options[key]:SetValue(value) end)
                end
            end
        end
    end
end

function DevLib:Notify(options)
    options = options or {}
    local title = options.Title or "Notification"
    local content = options.Content or ""
    local subContent = options.SubContent or ""
    local duration = options.Duration or 5
    local theme = DevLib:GetTheme()

    if not DevLib.NotificationGui then
        DevLib.NotificationGui = Create("ScreenGui", { Name = "DevLibNotifications", Parent = GUI_TARGET, ZIndexBehavior = Enum.ZIndexBehavior.Sibling, ResetOnSpawn = false })
        DevLib.NotificationContainer = Create("Frame", { Name = "Container", Parent = DevLib.NotificationGui, BackgroundTransparency = 1, Size = UDim2.fromScale(0.25, 1), Position = UDim2.fromScale(0.75, 0), AnchorPoint = Vector2.new(0, 0) }, {
            Create("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, VerticalAlignment = Enum.VerticalAlignment.Bottom, HorizontalAlignment = Enum.HorizontalAlignment.Right, Padding = UDim.new(0, 10) }),
            Create("UIPadding", { PaddingBottom = UDim.new(0, 20), PaddingRight = UDim.new(0, 20) })
        })
    end

    local notifFrame = Create("Frame", { Size = UDim2.new(1, 0, 0, 0), BackgroundColor3 = theme.WindowBackground, BackgroundTransparency = 0.1, AutomaticSize = Enum.AutomaticSize.Y, ClipsDescendants = true, Parent = DevLib.NotificationContainer }, {
        Create("UICorner", { CornerRadius = UDim.new(0, 8) }),
        Create("UIStroke", { Color = theme.StrokeColor, Thickness = 1 }),
        Create("UIPadding", { PaddingTop = UDim.new(0, 10), PaddingBottom = UDim.new(0, 10), PaddingLeft = UDim.new(0, 15), PaddingRight = UDim.new(0, 15) }),
        Create("TextLabel", { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 20), Font = Enum.Font.GothamBold, Text = title, TextColor3 = theme.Text, TextSize = 15, TextXAlignment = Enum.TextXAlignment.Left }),
        Create("TextLabel", { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 0), Position = UDim2.new(0, 0, 0, 25), AutomaticSize = Enum.AutomaticSize.Y, Font = Enum.Font.Gotham, Text = content .. (subContent ~= "" and ("\n" .. subContent) or ""), TextColor3 = theme.SubText, TextSize = 13, TextXAlignment = Enum.TextXAlignment.Left, TextWrapped = true })
    })

    notifFrame.Size = UDim2.new(0, 0, 0, notifFrame.AbsoluteSize.Y)
    Tween(notifFrame, { Size = UDim2.new(1, 0, 0, notifFrame.AbsoluteSize.Y) }, 0.4, Enum.EasingStyle.Back)

    if duration then
        task.delay(duration, function()
            local t = Tween(notifFrame, { Size = UDim2.new(0, 0, 0, notifFrame.AbsoluteSize.Y), BackgroundTransparency = 1 }, 0.4, Enum.EasingStyle.Quad)
            t.Completed:Connect(function() notifFrame:Destroy() end)
        end)
    end
end

function DevLib:CreateWindow(options)
    options = options or {}
    local windowTitle = options.Title or "Fluent " .. DevLib.Version
    local windowSubTitle = options.SubTitle or "by Dev AI"
    local windowSize = options.Size or UDim2.fromOffset(580, 460)
    local themeName = options.Theme or "Dark"
    local useAcrylic = options.Acrylic == nil and true or options.Acrylic
    local minimizeKey = options.MinimizeKey or Enum.KeyCode.LeftControl
    local keySystem = options.KeySystem or false
    local keySettings = options.KeySettings or {}

    DevLib:SetTheme(themeName)
    local theme = DevLib:GetTheme()

    local ScreenGui = Create("ScreenGui", { Name = "DevLibWindow", Parent = GUI_TARGET, ZIndexBehavior = Enum.ZIndexBehavior.Sibling, ResetOnSpawn = false, IgnoreGuiInset = true })
    local Blur
    if useAcrylic then
        Blur = Create("BlurEffect", { Size = 0, Parent = Lighting })
        table.insert(DevLib.Instances, Blur)
    end

    local MainFrame = Create("Frame", { Name = "MainFrame", Parent = ScreenGui, BackgroundColor3 = theme.MainBackground, BackgroundTransparency = useAcrylic and 0.15 or 0, Size = UDim2.fromScale(0, 0), Position = UDim2.fromScale(0.5, 0.5), AnchorPoint = Vector2.new(0.5, 0.5), ClipsDescendants = true, Visible = false }, {
        Create("UICorner", { CornerRadius = UDim.new(0, 10) }),
        Create("UIStroke", { Color = theme.StrokeColor, Thickness = 1 }),
        Create("ImageLabel", { Name = "Shadow", BackgroundTransparency = 1, Image = "rbxassetid://6015897843", ImageColor3 = theme.Shadow, ImageTransparency = 0.5, ScaleType = Enum.ScaleType.Slice, SliceCenter = Rect.new(49, 49, 450, 450), Size = UDim2.new(1, 40, 1, 40), Position = UDim2.new(0, -20, 0, -20), ZIndex = 0 })
    })

    local function OpenMainUI()
        MainFrame.Visible = true
        Tween(MainFrame, { Size = windowSize }, 0.5, Enum.EasingStyle.Exponential)
        if useAcrylic and Blur then Tween(Blur, { Size = 15 }, 0.5) end
    end

    if keySystem then
        local validKeys = keySettings.Keys or {"DevLib123"}
        local savedKeyPath = "DevLibKey.txt"
        local hasSavedKey = false
        if isfile and readfile and isfile(savedKeyPath) then
            local sKey = readfile(savedKeyPath)
            for _, k in pairs(validKeys) do if k == sKey then hasSavedKey = true break end end
        end

        if hasSavedKey then OpenMainUI() else
            if useAcrylic and Blur then Tween(Blur, { Size = 15 }, 0.5) end
            local KeyFrame = Create("Frame", { Parent = ScreenGui, BackgroundColor3 = theme.WindowBackground, Size = UDim2.new(0, 400, 0, 200), Position = UDim2.fromScale(0.5, 0.5), AnchorPoint = Vector2.new(0.5, 0.5), ClipsDescendants = true }, {
                Create("UICorner", { CornerRadius = UDim.new(0, 10) }), Create("UIStroke", { Color = theme.StrokeColor, Thickness = 1 }),
                Create("TextLabel", { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 40), Font = Enum.Font.GothamBold, Text = keySettings.Title or "Key System", TextColor3 = theme.Text, TextSize = 18 }),
                Create("TextLabel", { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 20), Position = UDim2.new(0, 0, 0, 40), Font = Enum.Font.Gotham, Text = keySettings.Note or "Enter your key to continue", TextColor3 = theme.SubText, TextSize = 13 }),
                Create("TextBox", { Name = "KeyInput", BackgroundColor3 = theme.ElementBackground, Size = UDim2.new(1, -40, 0, 40), Position = UDim2.new(0, 20, 0, 80), Font = Enum.Font.Gotham, PlaceholderText = "Enter Key Here...", Text = "", TextColor3 = theme.Text, TextSize = 14, ClearTextOnFocus = false }, { Create("UICorner", { CornerRadius = UDim.new(0, 6) }), Create("UIStroke", { Color = theme.StrokeColor, Thickness = 1 }) }),
                Create("TextButton", { Name = "CheckBtn", BackgroundColor3 = theme.Accent, Size = UDim2.new(1, -40, 0, 40), Position = UDim2.new(0, 20, 0, 135), Font = Enum.Font.GothamBold, Text = "Verify Key", TextColor3 = Color3.fromRGB(255, 255, 255), TextSize = 14 }, { Create("UICorner", { CornerRadius = UDim.new(0, 6) }) })
            })
            KeyFrame.Size = UDim2.new(0,0,0,0)
            Tween(KeyFrame, {Size = UDim2.new(0,400,0,200)}, 0.5, Enum.EasingStyle.Exponential)

            KeyFrame.CheckBtn.MouseButton1Click:Connect(function()
                local typed = KeyFrame.KeyInput.Text
                local correct = false
                for _, k in pairs(validKeys) do if k == typed then correct = true break end end
                if correct then
                    if writefile then pcall(writefile, savedKeyPath, typed) end
                    Tween(KeyFrame, {Size = UDim2.new(0,0,0,0)}, 0.5, Enum.EasingStyle.Exponential)
                    task.wait(0.5) KeyFrame:Destroy() OpenMainUI()
                else
                    KeyFrame.KeyInput.Text = "INVALID KEY"
                    Tween(KeyFrame.KeyInput.UIStroke, {Color = theme.Error}, 0.2)
                    task.wait(1) KeyFrame.KeyInput.Text = "" Tween(KeyFrame.KeyInput.UIStroke, {Color = theme.StrokeColor}, 0.2)
                end
            end)
        end
    else
        OpenMainUI()
    end

    local Topbar = Create("Frame", { Name = "Topbar", Parent = MainFrame, BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 45), Position = UDim2.new(0, 0, 0, 0) })
    MakeDraggable(Topbar, MainFrame)
    Create("Frame", { Parent = Topbar, BackgroundColor3 = theme.StrokeColor, Size = UDim2.new(1, 0, 0, 1), Position = UDim2.new(0, 0, 1, -1), BorderSizePixel = 0 })

    local TitleLabel = Create("TextLabel", { Name = "Title", Parent = Topbar, BackgroundTransparency = 1, Position = UDim2.new(0, 15, 0, 0), Size = UDim2.new(0, 0, 1, 0), AutomaticSize = Enum.AutomaticSize.X, Font = Enum.Font.GothamBold, Text = windowTitle, TextColor3 = theme.Text, TextSize = 16, TextXAlignment = Enum.TextXAlignment.Left })
    local SubTitleLabel = Create("TextLabel", { Name = "SubTitle", Parent = Topbar, BackgroundTransparency = 1, Position = UDim2.new(0, TitleLabel.AbsoluteSize.X + 25, 0, 0), Size = UDim2.new(0, 0, 1, 0), AutomaticSize = Enum.AutomaticSize.X, Font = Enum.Font.Gotham, Text = windowSubTitle, TextColor3 = theme.SubText, TextSize = 13, TextXAlignment = Enum.TextXAlignment.Left })
    TitleLabel:GetPropertyChangedSignal("AbsoluteSize"):Connect(function() SubTitleLabel.Position = UDim2.new(0, TitleLabel.AbsoluteSize.X + 25, 0, 0) end)

    local Sidebar = Create("Frame", { Name = "Sidebar", Parent = MainFrame, BackgroundColor3 = theme.WindowBackground, BackgroundTransparency = 0.5, Size = UDim2.new(0, options.TabWidth or 160, 1, -45), Position = UDim2.new(0, 0, 0, 45) }, {
        Create("UIStroke", { Color = theme.StrokeColor, Thickness = 1 }),
        Create("ScrollingFrame", { Name = "TabList", BackgroundTransparency = 1, Size = UDim2.new(1, 0, 1, 0), ScrollBarThickness = 0, CanvasSize = UDim2.new(0, 0, 0, 0), AutomaticCanvasSize = Enum.AutomaticSize.Y }, {
            Create("UIListLayout", { Padding = UDim.new(0, 4), HorizontalAlignment = Enum.HorizontalAlignment.Center }),
            Create("UIPadding", { PaddingTop = UDim.new(0, 8), PaddingBottom = UDim.new(0, 8) })
        })
    })

    local ContentContainer = Create("Frame", { Name = "ContentContainer", Parent = MainFrame, BackgroundTransparency = 1, Size = UDim2.new(1, -(options.TabWidth or 160), 1, -45), Position = UDim2.new(0, options.TabWidth or 160, 0, 45) })

    local WindowObj = { Tabs = {}, ActiveTab = nil, Gui = ScreenGui, Main = MainFrame, Blur = Blur, Dialogs = {} }
    DevLib.ActiveWindow = WindowObj

    local isMinimized = false
    function WindowObj:Minimize()
        isMinimized = true
        Tween(MainFrame, { Size = UDim2.fromScale(0, 0), BackgroundTransparency = 1 }, 0.5, Enum.EasingStyle.Exponential)
        if useAcrylic and Blur then Tween(Blur, { Size = 0 }, 0.5) end
        task.delay(0.5, function() if isMinimized then MainFrame.Visible = false end end)
    end

    function WindowObj:Maximize()
        isMinimized = false
        MainFrame.Visible = true
        Tween(MainFrame, { Size = windowSize, BackgroundTransparency = useAcrylic and 0.15 or 0 }, 0.5, Enum.EasingStyle.Exponential)
        if useAcrylic and Blur then Tween(Blur, { Size = 15 }, 0.5) end
    end

    table.insert(DevLib.Connections, UserInputService.InputBegan:Connect(function(input, gpe)
        if not gpe and input.KeyCode == minimizeKey then
            if isMinimized then WindowObj:Maximize() else WindowObj:Minimize() end
        end
    end))

    function WindowObj:Dialog(dlgOptions)
        local title = dlgOptions.Title or "Dialog"
        local content = dlgOptions.Content or "Content"
        local buttons = dlgOptions.Buttons or {}
        
        local BG = Create("Frame", { Parent = ScreenGui, BackgroundColor3 = Color3.new(0,0,0), BackgroundTransparency = 1, Size = UDim2.new(1,0,1,0), ZIndex = 100 })
        Tween(BG, {BackgroundTransparency = 0.6}, 0.3)
        local Dlg = Create("Frame", { Parent = BG, BackgroundColor3 = theme.WindowBackground, Size = UDim2.new(0, 320, 0, 160), Position = UDim2.fromScale(0.5, 0.5), AnchorPoint = Vector2.new(0.5, 0.5), ZIndex = 101, ClipsDescendants = true }, {
            Create("UICorner", { CornerRadius = UDim.new(0, 8) }), Create("UIStroke", { Color = theme.StrokeColor, Thickness = 1 }),
            Create("TextLabel", { BackgroundTransparency = 1, Size = UDim2.new(1, -30, 0, 40), Position = UDim2.new(0, 15, 0, 5), Font = Enum.Font.GothamBold, Text = title, TextColor3 = theme.Text, TextSize = 16, TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 102 }),
            Create("TextLabel", { BackgroundTransparency = 1, Size = UDim2.new(1, -30, 1, -100), Position = UDim2.new(0, 15, 0, 40), Font = Enum.Font.Gotham, Text = content, TextColor3 = theme.SubText, TextSize = 13, TextXAlignment = Enum.TextXAlignment.Left, TextYAlignment = Enum.TextYAlignment.Top, TextWrapped = true, ZIndex = 102 })
        })
        
        local BtnContainer = Create("Frame", { Parent = Dlg, BackgroundTransparency = 1, Size = UDim2.new(1, -30, 0, 40), Position = UDim2.new(0, 15, 1, -45), ZIndex = 102 })
        Create("UIListLayout", { Parent = BtnContainer, FillDirection = Enum.FillDirection.Horizontal, HorizontalAlignment = Enum.HorizontalAlignment.Right, VerticalAlignment = Enum.VerticalAlignment.Center, Padding = UDim.new(0, 10) })
        
        for _, btnData in ipairs(buttons) do
            local B = Create("TextButton", { Parent = BtnContainer, BackgroundColor3 = theme.ElementBackground, Size = UDim2.new(0, 100, 0, 30), Font = Enum.Font.GothamMedium, Text = btnData.Title, TextColor3 = theme.Text, TextSize = 13, AutoButtonColor = false, ZIndex = 103 }, { Create("UICorner", { CornerRadius = UDim.new(0, 6) }), Create("UIStroke", { Color = theme.StrokeColor, Thickness = 1 }) })
            B.MouseEnter:Connect(function() Tween(B, {BackgroundColor3 = theme.ElementHover}, 0.2) end)
            B.MouseLeave:Connect(function() Tween(B, {BackgroundColor3 = theme.ElementBackground}, 0.2) end)
            B.MouseButton1Click:Connect(function()
                Tween(BG, {BackgroundTransparency = 1}, 0.3)
                Tween(Dlg, {Size = UDim2.new(0,0,0,0)}, 0.3)
                task.delay(0.3, function() BG:Destroy() end)
                if btnData.Callback then btnData.Callback() end
            end)
        end
        
        Dlg.Size = UDim2.new(0,0,0,0)
        Tween(Dlg, {Size = UDim2.new(0, 320, 0, 160)}, 0.4, Enum.EasingStyle.Back)
    end

    function WindowObj:SelectTab(TabObj)
        WindowObj.ActiveTab = TabObj
        for _, t in pairs(WindowObj.Tabs) do
            t.Container.Visible = (t == TabObj)
            Tween(t.Button, { BackgroundTransparency = (t == TabObj) and 0 or 1 }, 0.2)
            Tween(t.Button.Title, { TextColor3 = (t == TabObj) and theme.Text or theme.SubText }, 0.2)
            if t.Button:FindFirstChild("Icon") then Tween(t.Button.Icon, { ImageColor3 = (t == TabObj) and theme.Accent or theme.SubText }, 0.2) end
            Tween(t.Button.Indicator, { Size = (t == TabObj) and UDim2.new(0, 3, 0, 20) or UDim2.new(0, 3, 0, 0) }, 0.2, Enum.EasingStyle.Back)
        end
    end

    function WindowObj:AddTab(tabOptions)
        tabOptions = tabOptions or {}
        local tabTitle = tabOptions.Title or "Tab"
        local rawIcon = tabOptions.Icon or ""
        local hasIcon = rawIcon ~= ""
        local tabIcon = DevLib:GetIcon(rawIcon)

        local TabButton = Create("TextButton", { Parent = Sidebar.TabList, BackgroundColor3 = theme.ElementBackground, BackgroundTransparency = 1, Size = UDim2.new(1, -16, 0, 34), Text = "", AutoButtonColor = false }, {
            Create("UICorner", { CornerRadius = UDim.new(0, 6) }),
            Create("TextLabel", { Name = "Title", BackgroundTransparency = 1, Size = UDim2.new(1, hasIcon and -40 or -20, 1, 0), Position = UDim2.new(0, hasIcon and 35 or 15, 0, 0), Font = Enum.Font.GothamMedium, Text = tabTitle, TextColor3 = theme.SubText, TextSize = 13, TextXAlignment = Enum.TextXAlignment.Left }),
            Create("Frame", { Name = "Indicator", BackgroundColor3 = theme.Accent, Size = UDim2.new(0, 3, 0, 0), Position = UDim2.new(0, 0, 0.5, 0), AnchorPoint = Vector2.new(0, 0.5), BackgroundTransparency = 1 }, { Create("UICorner", { CornerRadius = UDim.new(0, 2) }) })
        })
        if hasIcon then
            Create("ImageLabel", { Name = "Icon", Parent = TabButton, BackgroundTransparency = 1, Size = UDim2.new(0, 18, 0, 18), Position = UDim2.new(0, 10, 0.5, 0), AnchorPoint = Vector2.new(0, 0.5), Image = tabIcon, ImageColor3 = theme.SubText })
        end

        local TabContainer = Create("ScrollingFrame", { Name = tabTitle .. "Container", Parent = ContentContainer, BackgroundTransparency = 1, Size = UDim2.new(1, 0, 1, 0), ScrollBarThickness = 2, ScrollBarImageColor3 = theme.StrokeColor, Visible = false, CanvasSize = UDim2.new(0, 0, 0, 0), AutomaticCanvasSize = Enum.AutomaticSize.Y }, {
            Create("UIListLayout", { Padding = UDim.new(0, 10), HorizontalAlignment = Enum.HorizontalAlignment.Center }),
            Create("UIPadding", { PaddingTop = UDim.new(0, 15), PaddingBottom = UDim.new(0, 15), PaddingLeft = UDim.new(0, 15), PaddingRight = UDim.new(0, 15) })
        })

        local TabObj = { Name = tabTitle, Container = TabContainer, Button = TabButton }
        TabButton.MouseButton1Click:Connect(function() WindowObj:SelectTab(TabObj) end)
        table.insert(WindowObj.Tabs, TabObj)
        if #WindowObj.Tabs == 1 then WindowObj:SelectTab(TabObj) end

        -- FUNÇÕES DA FLUENT
        function TabObj:AddParagraph(options)
            local title = options.Title or "Paragraph"
            local content = options.Content or ""
            local PFrame = Create("Frame", { Parent = TabContainer, BackgroundColor3 = theme.ElementBackground, Size = UDim2.new(1, 0, 0, 0), AutomaticSize = Enum.AutomaticSize.Y }, {
                Create("UICorner", { CornerRadius = UDim.new(0, 6) }), Create("UIStroke", { Color = theme.StrokeColor, Thickness = 1 }),
                Create("UIPadding", { PaddingTop = UDim.new(0, 10), PaddingBottom = UDim.new(0, 10), PaddingLeft = UDim.new(0, 15), PaddingRight = UDim.new(0, 15) }),
                Create("UIListLayout", { Padding = UDim.new(0, 5) }),
                Create("TextLabel", { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 20), Font = Enum.Font.GothamBold, Text = title, TextColor3 = theme.Text, TextSize = 14, TextXAlignment = Enum.TextXAlignment.Left }),
                Create("TextLabel", { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 0), AutomaticSize = Enum.AutomaticSize.Y, Font = Enum.Font.Gotham, Text = content, TextColor3 = theme.SubText, TextSize = 13, TextXAlignment = Enum.TextXAlignment.Left, TextWrapped = true, RichText = true })
            })
        end

        function TabObj:AddButton(options)
            local title = options.Title or "Button"
            local desc = options.Description or ""
            local cb = options.Callback or function() end
            local BtnFrame = Create("TextButton", { Parent = TabContainer, BackgroundColor3 = theme.ElementBackground, Size = UDim2.new(1, 0, 0, desc == "" and 42 or 55), Text = "", AutoButtonColor = false }, {
                Create("UICorner", { CornerRadius = UDim.new(0, 6) }), Create("UIStroke", { Color = theme.StrokeColor, Thickness = 1 }),
                Create("TextLabel", { BackgroundTransparency = 1, Size = UDim2.new(1, -20, 0, 20), Position = UDim2.new(0, 15, 0, desc == "" and 11 or 8), Font = Enum.Font.GothamMedium, Text = title, TextColor3 = theme.Text, TextSize = 14, TextXAlignment = Enum.TextXAlignment.Left }),
                Create("ImageLabel", { BackgroundTransparency = 1, Size = UDim2.new(0, 16, 0, 16), Position = UDim2.new(1, -25, 0.5, 0), AnchorPoint = Vector2.new(0, 0.5), Image = DevLib:GetIcon("mouse-pointer-click") ~= "" and DevLib:GetIcon("mouse-pointer-click") or "rbxassetid://10736930004", ImageColor3 = theme.SubText })
            })
            if desc ~= "" then
                Create("TextLabel", { Parent = BtnFrame, BackgroundTransparency = 1, Size = UDim2.new(1, -40, 0, 15), Position = UDim2.new(0, 15, 0, 28), Font = Enum.Font.Gotham, Text = desc, TextColor3 = theme.SubText, TextSize = 12, TextXAlignment = Enum.TextXAlignment.Left })
            end
            BtnFrame.MouseEnter:Connect(function() Tween(BtnFrame, { BackgroundColor3 = theme.ElementHover }, 0.2) Tween(BtnFrame.UIStroke, { Color = theme.StrokeHover }, 0.2) end)
            BtnFrame.MouseLeave:Connect(function() Tween(BtnFrame, { BackgroundColor3 = theme.ElementBackground }, 0.2) Tween(BtnFrame.UIStroke, { Color = theme.StrokeColor }, 0.2) end)
            BtnFrame.MouseButton1Down:Connect(function() Tween(BtnFrame, { BackgroundColor3 = theme.ElementPress }, 0.1) end)
            BtnFrame.MouseButton1Up:Connect(function() Tween(BtnFrame, { BackgroundColor3 = theme.ElementHover }, 0.1) cb() end)
        end

        function TabObj:AddToggle(id, options)
            if type(id) == "table" then options = id id = options.Title or "Toggle" end
            local title = options.Title or "Toggle"
            local desc = options.Description or ""
            local state = options.Default or false
            local cb = options.Callback or function() end
            
            local TglFrame = Create("TextButton", { Parent = TabContainer, BackgroundColor3 = theme.ElementBackground, Size = UDim2.new(1, 0, 0, desc == "" and 42 or 55), Text = "", AutoButtonColor = false }, {
                Create("UICorner", { CornerRadius = UDim.new(0, 6) }), Create("UIStroke", { Color = theme.StrokeColor, Thickness = 1 }),
                Create("TextLabel", { BackgroundTransparency = 1, Size = UDim2.new(1, -80, 0, 20), Position = UDim2.new(0, 15, 0, desc == "" and 11 or 8), Font = Enum.Font.GothamMedium, Text = title, TextColor3 = theme.Text, TextSize = 14, TextXAlignment = Enum.TextXAlignment.Left })
            })
            if desc ~= "" then
                Create("TextLabel", { Parent = TglFrame, BackgroundTransparency = 1, Size = UDim2.new(1, -80, 0, 15), Position = UDim2.new(0, 15, 0, 28), Font = Enum.Font.Gotham, Text = desc, TextColor3 = theme.SubText, TextSize = 12, TextXAlignment = Enum.TextXAlignment.Left })
            end
            
            local Switch = Create("Frame", { Parent = TglFrame, BackgroundColor3 = state and theme.Accent or theme.TabBackground, Size = UDim2.new(0, 42, 0, 22), Position = UDim2.new(1, -55, 0.5, 0), AnchorPoint = Vector2.new(0, 0.5) }, { Create("UICorner", { CornerRadius = UDim.new(1, 0) }), Create("UIStroke", { Color = theme.StrokeColor, Thickness = 1 }) })
            local Circle = Create("Frame", { Parent = Switch, BackgroundColor3 = Color3.fromRGB(255, 255, 255), Size = UDim2.new(0, 16, 0, 16), Position = state and UDim2.new(1, -19, 0.5, 0) or UDim2.new(0, 3, 0.5, 0), AnchorPoint = Vector2.new(0, 0.5) }, { Create("UICorner", { CornerRadius = UDim.new(1, 0) }), Create("ImageLabel", { BackgroundTransparency = 1, Image = "rbxassetid://6015897843", ImageColor3 = theme.Shadow, ImageTransparency = 0.5, ScaleType = Enum.ScaleType.Slice, SliceCenter = Rect.new(49, 49, 450, 450), Size = UDim2.new(1, 10, 1, 10), Position = UDim2.new(0, -5, 0, -5), ZIndex = 0 }) })

            local TglObj = { Value = state }
            local changeCb = cb
            function TglObj:SetValue(val)
                self.Value = val state = val DevLib.Flags[id] = state
                Tween(Switch, { BackgroundColor3 = state and theme.Accent or theme.TabBackground }, 0.2)
                Tween(Circle, { Position = state and UDim2.new(1, -19, 0.5, 0) or UDim2.new(0, 3, 0.5, 0) }, 0.2, Enum.EasingStyle.Back)
                changeCb(state)
            end
            function TglObj:OnChanged(newCb) changeCb = newCb end
            
            TglFrame.MouseButton1Click:Connect(function() TglObj:SetValue(not state) end)
            DevLib.Flags[id] = state
            DevLib.Options[id] = TglObj
            return TglObj
        end

        function TabObj:AddSlider(id, options)
            if type(id) == "table" then options = id id = options.Title or "Slider" end
            local title = options.Title or "Slider"
            local desc = options.Description or ""
            local min, max, val = options.Min or 0, options.Max or 100, options.Default or 0
            local rounding = options.Rounding or 0
            local cb = options.Callback or function() end

            local SldFrame = Create("Frame", { Parent = TabContainer, BackgroundColor3 = theme.ElementBackground, Size = UDim2.new(1, 0, 0, desc == "" and 65 or 80) }, {
                Create("UICorner", { CornerRadius = UDim.new(0, 6) }), Create("UIStroke", { Color = theme.StrokeColor, Thickness = 1 }),
                Create("TextLabel", { BackgroundTransparency = 1, Size = UDim2.new(1, -80, 0, 20), Position = UDim2.new(0, 15, 0, 10), Font = Enum.Font.GothamMedium, Text = title, TextColor3 = theme.Text, TextSize = 14, TextXAlignment = Enum.TextXAlignment.Left }),
                Create("TextLabel", { Name = "ValLbl", BackgroundTransparency = 1, Size = UDim2.new(0, 50, 0, 20), Position = UDim2.new(1, -65, 0, 10), Font = Enum.Font.GothamBold, Text = tostring(val), TextColor3 = theme.SubText, TextSize = 14, TextXAlignment = Enum.TextXAlignment.Right })
            })
            if desc ~= "" then Create("TextLabel", { Parent = SldFrame, BackgroundTransparency = 1, Size = UDim2.new(1, -80, 0, 15), Position = UDim2.new(0, 15, 0, 28), Font = Enum.Font.Gotham, Text = desc, TextColor3 = theme.SubText, TextSize = 12, TextXAlignment = Enum.TextXAlignment.Left }) end

            local SliderBg = Create("TextButton", { Parent = SldFrame, BackgroundColor3 = theme.TabBackground, Size = UDim2.new(1, -30, 0, 6), Position = UDim2.new(0, 15, 1, -15), Text = "", AutoButtonColor = false }, { Create("UICorner", { CornerRadius = UDim.new(1, 0) }), Create("UIStroke", { Color = theme.StrokeColor, Thickness = 1 }) })
            local SliderFill = Create("Frame", { Parent = SliderBg, BackgroundColor3 = theme.Accent, Size = UDim2.new((val - min)/(max - min), 0, 1, 0) }, { Create("UICorner", { CornerRadius = UDim.new(1, 0) }) })
            local SliderCirc = Create("Frame", { Parent = SliderFill, BackgroundColor3 = Color3.fromRGB(255, 255, 255), Size = UDim2.new(0, 12, 0, 12), Position = UDim2.new(1, -6, 0.5, 0), AnchorPoint = Vector2.new(0, 0.5) }, { Create("UICorner", { CornerRadius = UDim.new(1, 0) }) })

            local SldObj = { Value = val }
            local changeCb = cb
            function SldObj:SetValue(v)
                val = math.clamp(math.round(v * (10^rounding)) / (10^rounding), min, max)
                self.Value = val DevLib.Flags[id] = val SldFrame.ValLbl.Text = tostring(val)
                Tween(SliderFill, { Size = UDim2.new((val - min)/(max - min), 0, 1, 0) }, 0.1)
                changeCb(val)
            end
            function SldObj:OnChanged(newCb) changeCb = newCb end

            local dragging = false
            local function update(input)
                local pct = math.clamp((input.Position.X - SliderBg.AbsolutePosition.X) / SliderBg.AbsoluteSize.X, 0, 1)
                SldObj:SetValue(min + ((max - min) * pct))
            end
            SliderBg.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true Tween(SliderCirc, {Size=UDim2.new(0,16,0,16)}, 0.2) update(i) end end)
            UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false Tween(SliderCirc, {Size=UDim2.new(0,12,0,12)}, 0.2) end end)
            UserInputService.InputChanged:Connect(function(i) if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then update(i) end end)

            DevLib.Flags[id] = val DevLib.Options[id] = SldObj return SldObj
        end

        function TabObj:AddDropdown(id, options)
            if type(id) == "table" then options = id id = options.Title or "Dropdown" end
            local title = options.Title or "Dropdown"
            local desc = options.Description or ""
            local values = options.Values or {}
            local multi = options.Multi or false
            local default = options.Default or (multi and {} or nil)
            local cb = options.Callback or function() end
            local selected = default
            local isOpen = false

            local DdFrame = Create("Frame", { Parent = TabContainer, BackgroundColor3 = theme.ElementBackground, Size = UDim2.new(1, 0, 0, desc == "" and 42 or 55), ClipsDescendants = true }, { Create("UICorner", { CornerRadius = UDim.new(0, 6) }), Create("UIStroke", { Color = theme.StrokeColor, Thickness = 1 }) })
            local DdBtn = Create("TextButton", { Parent = DdFrame, BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, desc == "" and 42 or 55), Text = "" }, {
                Create("TextLabel", { BackgroundTransparency = 1, Size = UDim2.new(1, -120, 0, 20), Position = UDim2.new(0, 15, 0, desc == "" and 11 or 8), Font = Enum.Font.GothamMedium, Text = title, TextColor3 = theme.Text, TextSize = 14, TextXAlignment = Enum.TextXAlignment.Left }),
                Create("TextLabel", { Name = "SelLbl", BackgroundTransparency = 1, Size = UDim2.new(0, 100, 0, 20), Position = UDim2.new(1, -135, 0, desc == "" and 11 or 8), Font = Enum.Font.Gotham, Text = "None", TextColor3 = theme.SubText, TextSize = 13, TextXAlignment = Enum.TextXAlignment.Right }),
                Create("ImageLabel", { Name = "Icon", BackgroundTransparency = 1, Size = UDim2.new(0, 16, 0, 16), Position = UDim2.new(1, -25, 0.5, 0), AnchorPoint = Vector2.new(0, 0.5), Image = DevLib:GetIcon("chevron-down") ~= "" and DevLib:GetIcon("chevron-down") or "rbxassetid://10709790948", ImageColor3 = theme.SubText })
            })
            if desc ~= "" then Create("TextLabel", { Parent = DdBtn, BackgroundTransparency = 1, Size = UDim2.new(1, -120, 0, 15), Position = UDim2.new(0, 15, 0, 28), Font = Enum.Font.Gotham, Text = desc, TextColor3 = theme.SubText, TextSize = 12, TextXAlignment = Enum.TextXAlignment.Left }) end
            
            local ListScroll = Create("ScrollingFrame", { Parent = DdFrame, BackgroundTransparency = 1, Size = UDim2.new(1, -10, 0, 120), Position = UDim2.new(0, 5, 0, desc == "" and 47 or 60), ScrollBarThickness = 2, CanvasSize = UDim2.new(0,0,0,0), AutomaticCanvasSize = Enum.AutomaticSize.Y }, { Create("UIListLayout", { Padding = UDim.new(0, 4) }) })

            local DdObj = { Value = selected }
            local changeCb = cb
            local function upVis()
                if multi then
                    local arr = {} for k,v in pairs(selected) do if v then table.insert(arr, k) end end
                    DdBtn.SelLbl.Text = #arr > 0 and table.concat(arr, ", ") or "None"
                else DdBtn.SelLbl.Text = tostring(selected or "None") end
                DdObj.Value = selected DevLib.Flags[id] = selected changeCb(selected)
            end

            function DdObj:Refresh(newVals)
                values = newVals
                for _,c in pairs(ListScroll:GetChildren()) do if c:IsA("TextButton") then c:Destroy() end end
                for _, v in ipairs(values) do
                    local isSel = multi and selected[v] or (not multi and selected == v)
                    local btn = Create("TextButton", { Parent = ListScroll, BackgroundColor3 = isSel and theme.Accent or theme.TabBackground, Size = UDim2.new(1, -10, 0, 30), Text = "", AutoButtonColor = false }, {
                        Create("UICorner", { CornerRadius = UDim.new(0, 4) }),
                        Create("TextLabel", { Name = "Lbl", BackgroundTransparency=1, Size=UDim2.new(1,-20,1,0), Position=UDim2.new(0,10,0,0), Font=Enum.Font.Gotham, Text=tostring(v), TextColor3=isSel and Color3.new(1,1,1) or theme.Text, TextSize=13, TextXAlignment=Enum.TextXAlignment.Left })
                    })
                    btn.MouseButton1Click:Connect(function()
                        if multi then
                            selected[v] = not selected[v]
                            btn.BackgroundColor3 = selected[v] and theme.Accent or theme.TabBackground
                            btn.Lbl.TextColor3 = selected[v] and Color3.new(1,1,1) or theme.Text
                        else
                            selected = v
                            for _,c in pairs(ListScroll:GetChildren()) do if c:IsA("TextButton") then c.BackgroundColor3 = theme.TabBackground c.Lbl.TextColor3 = theme.Text end end
                            btn.BackgroundColor3 = theme.Accent btn.Lbl.TextColor3 = Color3.new(1,1,1)
                            isOpen = false Tween(DdFrame, {Size=UDim2.new(1,0,0,desc=="" and 42 or 55)}, 0.3) Tween(DdBtn.Icon, {Rotation=0}, 0.3)
                        end
                        upVis()
                    end)
                end
            end

            function DdObj:SetValue(val) selected = val self:Refresh(values) upVis() end
            function DdObj:OnChanged(newCb) changeCb = newCb end

            DdBtn.MouseButton1Click:Connect(function()
                isOpen = not isOpen
                Tween(DdFrame, {Size = isOpen and UDim2.new(1, 0, 0, (desc=="" and 42 or 55) + 130) or UDim2.new(1, 0, 0, desc=="" and 42 or 55)}, 0.3, Enum.EasingStyle.Exponential)
                Tween(DdBtn.Icon, {Rotation = isOpen and 180 or 0}, 0.3)
            end)

            DdObj:Refresh(values) upVis()
            DevLib.Flags[id] = selected DevLib.Options[id] = DdObj return DdObj
        end

        function TabObj:AddColorpicker(id, options)
            if type(id) == "table" then options = id id = options.Title or "Colorpicker" end
            local title = options.Title or "Colorpicker"
            local desc = options.Description or ""
            local default = options.Default or Color3.new(1,1,1)
            local cb = options.Callback or function() end
            local hasTransp = options.Transparency ~= nil
            local transp = options.Transparency or 0
            local color = default
            local h,s,v = Color3.toHSV(color)
            local isOpen = false

            local CpFrame = Create("Frame", { Parent = TabContainer, BackgroundColor3 = theme.ElementBackground, Size = UDim2.new(1, 0, 0, desc == "" and 42 or 55), ClipsDescendants = true }, { Create("UICorner", { CornerRadius = UDim.new(0, 6) }), Create("UIStroke", { Color = theme.StrokeColor, Thickness = 1 }) })
            local CpBtn = Create("TextButton", { Parent = CpFrame, BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, desc == "" and 42 or 55), Text = "" }, {
                Create("TextLabel", { BackgroundTransparency = 1, Size = UDim2.new(1, -80, 0, 20), Position = UDim2.new(0, 15, 0, desc == "" and 11 or 8), Font = Enum.Font.GothamMedium, Text = title, TextColor3 = theme.Text, TextSize = 14, TextXAlignment = Enum.TextXAlignment.Left }),
                Create("Frame", { Name = "Disp", BackgroundColor3 = color, BackgroundTransparency = transp, Size = UDim2.new(0, 36, 0, 20), Position = UDim2.new(1, -55, 0.5, 0), AnchorPoint = Vector2.new(0, 0.5) }, { Create("UICorner", { CornerRadius = UDim.new(0, 4) }), Create("UIStroke", { Color = theme.StrokeColor, Thickness = 1 }) })
            })
            if desc ~= "" then Create("TextLabel", { Parent = CpBtn, BackgroundTransparency = 1, Size = UDim2.new(1, -80, 0, 15), Position = UDim2.new(0, 15, 0, 28), Font = Enum.Font.Gotham, Text = desc, TextColor3 = theme.SubText, TextSize = 12, TextXAlignment = Enum.TextXAlignment.Left }) end
            
            local DropArea = Create("Frame", { Parent = CpFrame, BackgroundTransparency = 1, Size = UDim2.new(1, -30, 0, 140), Position = UDim2.new(0, 15, 0, desc == "" and 50 or 65) })
            local SatVal = Create("TextButton", { Parent = DropArea, BackgroundColor3 = Color3.fromHSV(h,1,1), Size = UDim2.new(1, -30, 0, 100), Text = "", AutoButtonColor = false }, {
                Create("UICorner", { CornerRadius = UDim.new(0, 4) }),
                Create("UIGradient", { Color = ColorSequence.new({ColorSequenceKeypoint.new(0, Color3.new(1,1,1)), ColorSequenceKeypoint.new(1, Color3.new(1,1,1))}), Transparency = NumberSequence.new({NumberSequenceKeypoint.new(0,0), NumberSequenceKeypoint.new(1,1)}) }),
                Create("Frame", { BackgroundColor3 = Color3.new(0,0,0), Size = UDim2.new(1,0,1,0), ZIndex = 2 }, { Create("UICorner", { CornerRadius = UDim.new(0,4) }), Create("UIGradient", { Rotation = 90, Transparency = NumberSequence.new({NumberSequenceKeypoint.new(0,1), NumberSequenceKeypoint.new(1,0)}) }) })
            })
            local Hue = Create("TextButton", { Parent = DropArea, Size = UDim2.new(0, 20, 0, 100), Position = UDim2.new(1, -20, 0, 0), Text = "", AutoButtonColor = false }, {
                Create("UICorner", { CornerRadius = UDim.new(0, 4) }),
                Create("UIGradient", { Rotation = 90, Color = ColorSequence.new({ColorSequenceKeypoint.new(0, Color3.new(1,0,0)), ColorSequenceKeypoint.new(0.16, Color3.new(1,1,0)), ColorSequenceKeypoint.new(0.33, Color3.new(0,1,0)), ColorSequenceKeypoint.new(0.5, Color3.new(0,1,1)), ColorSequenceKeypoint.new(0.66, Color3.new(0,0,1)), ColorSequenceKeypoint.new(0.83, Color3.new(1,0,1)), ColorSequenceKeypoint.new(1, Color3.new(1,0,0))}) })
            })

            local TranspSlider = nil
            if hasTransp then
                TranspSlider = Create("TextButton", { Parent = DropArea, BackgroundColor3 = Color3.new(1,1,1), Size = UDim2.new(1, 0, 0, 15), Position = UDim2.new(0, 0, 0, 115), Text = "", AutoButtonColor = false }, {
                    Create("UICorner", { CornerRadius = UDim.new(0, 4) }),
                    Create("UIGradient", { Color = ColorSequence.new({ColorSequenceKeypoint.new(0, Color3.new(1,1,1)), ColorSequenceKeypoint.new(1, Color3.new(0,0,0))}) })
                })
            end

            local CpObj = { Value = color, Transparency = transp }
            local changeCb = cb

            local function updateVis()
                color = Color3.fromHSV(h,s,v)
                CpBtn.Disp.BackgroundColor3 = color
                CpBtn.Disp.BackgroundTransparency = transp
                SatVal.BackgroundColor3 = Color3.fromHSV(h,1,1)
                CpObj.Value = color CpObj.Transparency = transp
                DevLib.Flags[id] = {R = color.R, G = color.G, B = color.B, T = transp}
                changeCb(color, transp)
            end

            function CpObj:SetValueRGB(c) color = c h,s,v = Color3.toHSV(c) updateVis() end
            function CpObj:OnChanged(newCb) changeCb = newCb end

            local ds, dh, dt = false, false, false
            SatVal.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then ds = true end end)
            Hue.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dh = true end end)
            if hasTransp then TranspSlider.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dt = true end end) end

            UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then ds, dh, dt = false, false, false end end)
            UserInputService.InputChanged:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseMovement then
                    if ds then s = math.clamp((i.Position.X - SatVal.AbsolutePosition.X)/SatVal.AbsoluteSize.X,0,1) v = 1 - math.clamp((i.Position.Y - SatVal.AbsolutePosition.Y)/SatVal.AbsoluteSize.Y,0,1) updateVis() end
                    if dh then h = 1 - math.clamp((i.Position.Y - Hue.AbsolutePosition.Y)/Hue.AbsoluteSize.Y,0,1) updateVis() end
                    if dt and hasTransp then transp = math.clamp((i.Position.X - TranspSlider.AbsolutePosition.X)/TranspSlider.AbsoluteSize.X,0,1) updateVis() end
                end
            end)

            CpBtn.MouseButton1Click:Connect(function() isOpen = not isOpen Tween(CpFrame, {Size = isOpen and UDim2.new(1,0,0, (desc=="" and 42 or 55) + 150) or UDim2.new(1,0,0,desc=="" and 42 or 55)}, 0.3, Enum.EasingStyle.Exponential) end)

            DevLib.Flags[id] = {R = color.R, G = color.G, B = color.B, T = transp} DevLib.Options[id] = CpObj return CpObj
        end

        function TabObj:AddKeybind(id, options)
            if type(id) == "table" then options = id id = options.Title or "Keybind" end
            local title = options.Title or "Keybind"
            local desc = options.Description or ""
            local mode = options.Mode or "Toggle"
            local default = options.Default or "None"
            if type(default) == "string" and default ~= "None" then default = Enum.KeyCode[default] or Enum.UserInputType[default] or Enum.KeyCode.Unknown end
            local key = default
            local cb = options.Callback or function() end
            local changeCb = options.ChangedCallback or function() end
            
            local KbFrame = Create("Frame", { Parent = TabContainer, BackgroundColor3 = theme.ElementBackground, Size = UDim2.new(1, 0, 0, desc == "" and 42 or 55) }, {
                Create("UICorner", { CornerRadius = UDim.new(0, 6) }), Create("UIStroke", { Color = theme.StrokeColor, Thickness = 1 }),
                Create("TextLabel", { BackgroundTransparency = 1, Size = UDim2.new(1, -120, 0, 20), Position = UDim2.new(0, 15, 0, desc == "" and 11 or 8), Font = Enum.Font.GothamMedium, Text = title, TextColor3 = theme.Text, TextSize = 14, TextXAlignment = Enum.TextXAlignment.Left })
            })
            if desc ~= "" then Create("TextLabel", { Parent = KbFrame, BackgroundTransparency = 1, Size = UDim2.new(1, -120, 0, 15), Position = UDim2.new(0, 15, 0, 28), Font = Enum.Font.Gotham, Text = desc, TextColor3 = theme.SubText, TextSize = 12, TextXAlignment = Enum.TextXAlignment.Left }) end
            
            local BindBtn = Create("TextButton", { Parent = KbFrame, BackgroundColor3 = theme.TabBackground, Size = UDim2.new(0, 80, 0, 26), Position = UDim2.new(1, -95, 0.5, 0), AnchorPoint = Vector2.new(0, 0.5), Text = key == Enum.KeyCode.Unknown and "None" or key.Name, Font = Enum.Font.Gotham, TextColor3 = theme.Text, TextSize = 13, AutoButtonColor = false }, { Create("UICorner", { CornerRadius = UDim.new(0, 4) }), Create("UIStroke", { Color = theme.StrokeColor, Thickness = 1 }) })

            local KbObj = { Value = key, State = false }
            local clickCb = cb
            local binding = false

            function KbObj:SetValue(newKey, newMode)
                if type(newKey) == "string" then newKey = Enum.KeyCode[newKey] or Enum.UserInputType[newKey] or Enum.KeyCode.Unknown end
                key = newKey if newMode then mode = newMode end
                BindBtn.Text = key == Enum.KeyCode.Unknown and "None" or key.Name
                self.Value = key DevLib.Flags[id] = key.Name changeCb(key)
            end
            function KbObj:GetState() return self.State end
            function KbObj:OnClick(c) clickCb = c end
            function KbObj:OnChanged(c) changeCb = c end

            BindBtn.MouseButton1Click:Connect(function() binding = true BindBtn.Text = "..." Tween(BindBtn.UIStroke, {Color=theme.Accent}, 0.2) end)

            table.insert(DevLib.Connections, UserInputService.InputBegan:Connect(function(input, gpe)
                if binding then
                    if input.KeyCode == Enum.KeyCode.Escape or input.KeyCode == Enum.KeyCode.Backspace then KbObj:SetValue(Enum.KeyCode.Unknown)
                    elseif input.UserInputType == Enum.UserInputType.Keyboard then KbObj:SetValue(input.KeyCode)
                    elseif input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.MouseButton2 or input.UserInputType == Enum.UserInputType.MouseButton3 then KbObj:SetValue(input.UserInputType) end
                    binding = false Tween(BindBtn.UIStroke, {Color=theme.StrokeColor}, 0.2)
                elseif not gpe and (input.KeyCode == key or input.UserInputType == key) then
                    if mode == "Toggle" then KbObj.State = not KbObj.State clickCb(KbObj.State)
                    elseif mode == "Hold" then KbObj.State = true clickCb(true)
                    elseif mode == "Always" then clickCb(true) end
                end
            end))
            table.insert(DevLib.Connections, UserInputService.InputEnded:Connect(function(input, gpe)
                if not binding and not gpe and mode == "Hold" and (input.KeyCode == key or input.UserInputType == key) then
                    KbObj.State = false clickCb(false)
                end
            end))

            DevLib.Flags[id] = key.Name DevLib.Options[id] = KbObj return KbObj
        end

        function TabObj:AddInput(id, options)
            if type(id) == "table" then options = id id = options.Title or "Input" end
            local title = options.Title or "Input"
            local desc = options.Description or ""
            local default = options.Default or ""
            local placeholder = options.Placeholder or "Type here..."
            local numeric = options.Numeric or false
            local finished = options.Finished or false
            local cb = options.Callback or function() end

            local InpFrame = Create("Frame", { Parent = TabContainer, BackgroundColor3 = theme.ElementBackground, Size = UDim2.new(1, 0, 0, desc == "" and 42 or 55) }, {
                Create("UICorner", { CornerRadius = UDim.new(0, 6) }), Create("UIStroke", { Color = theme.StrokeColor, Thickness = 1 }),
                Create("TextLabel", { BackgroundTransparency = 1, Size = UDim2.new(0.4, 0, 0, 20), Position = UDim2.new(0, 15, 0, desc == "" and 11 or 8), Font = Enum.Font.GothamMedium, Text = title, TextColor3 = theme.Text, TextSize = 14, TextXAlignment = Enum.TextXAlignment.Left })
            })
            if desc ~= "" then Create("TextLabel", { Parent = InpFrame, BackgroundTransparency = 1, Size = UDim2.new(0.4, 0, 0, 15), Position = UDim2.new(0, 15, 0, 28), Font = Enum.Font.Gotham, Text = desc, TextColor3 = theme.SubText, TextSize = 12, TextXAlignment = Enum.TextXAlignment.Left }) end

            local TextBox = Create("TextBox", { Parent = InpFrame, BackgroundColor3 = theme.TabBackground, Size = UDim2.new(0.5, -15, 0, 26), Position = UDim2.new(0.5, 0, 0.5, 0), AnchorPoint = Vector2.new(0, 0.5), Font = Enum.Font.Gotham, Text = default, TextColor3 = theme.Text, TextSize = 13, PlaceholderText = placeholder, ClearTextOnFocus = false }, { Create("UICorner", { CornerRadius = UDim.new(0, 4) }), Create("UIStroke", { Color = theme.StrokeColor, Thickness = 1 }) })

            local InpObj = { Value = default }
            local changeCb = cb

            function InpObj:SetValue(val)
                self.Value = val TextBox.Text = tostring(val) DevLib.Flags[id] = val changeCb(val)
            end
            function InpObj:OnChanged(newCb) changeCb = newCb end

            local function handleInput()
                local txt = TextBox.Text
                if numeric and not tonumber(txt) and txt ~= "" then txt = InpObj.Value TextBox.Text = tostring(txt) end
                InpObj:SetValue(txt)
            end

            TextBox.FocusLost:Connect(function(enter) if finished and not enter then return end handleInput() end)
            if not finished then TextBox:GetPropertyChangedSignal("Text"):Connect(handleInput) end

            DevLib.Flags[id] = default DevLib.Options[id] = InpObj return InpObj
        end

