                if setclipboard then
                    setclipboard(textToCopy)
                    DevLib:Notify({Title="Clipboard", Content="Copied successfully!"})
                else
                    DevLib:Notify({Title="Error", Content="Executor does not support setclipboard.", Duration=3})
                end
            end})
        end
        TabObj.AddPasteButton = TabObj.AddCopyButton
        TabObj.AddQRCode = TabObj.AddCopyButton

        function TabObj:AddChart(title, dataArray)
            local F = Create("Frame", {
                Parent = TabContainer,
                BackgroundColor3=theme.ElementBackground,
                Size=UDim2.new(1, 0, 0, 150),
                ZIndex=4
            })
            Create("UICorner", { Parent = F, CornerRadius=UDim.new(0,6) })
            Create("UIStroke", { Parent = F, Color=theme.StrokeColor, Thickness=1 })
            
            Create("TextLabel", {
                Parent = F,
                BackgroundTransparency=1,
                Size=UDim2.new(1,-20,0,20),
                Position=UDim2.new(0,10,0,5),
                Font=Enum.Font.GothamBold,
                Text=title or "Data Chart",
                TextColor3=theme.Text,
                TextSize=14,
                TextXAlignment=Enum.TextXAlignment.Left,
                ZIndex=5
            })
            
            local GraphArea = Create("Frame", {
                Parent = F,
                BackgroundTransparency=1,
                Size=UDim2.new(1,-20,1,-40),
                Position=UDim2.new(0,10,0,30),
                ZIndex=5
            })
            Create("UIListLayout", {
                Parent = GraphArea,
                FillDirection=Enum.FillDirection.Horizontal,
                HorizontalAlignment=Enum.HorizontalAlignment.Left,
                VerticalAlignment=Enum.VerticalAlignment.Bottom,
                Padding=UDim.new(0,4)
            })
            
            local function draw(arr)
                for _,c in pairs(GraphArea:GetChildren()) do
                    if c:IsA("Frame") then c:Destroy() end
                end
                local max = 1
                for _,v in pairs(arr) do
                    if v > max then max = v end
                end
                local w = math.clamp((GraphArea.AbsoluteSize.X / #arr) - 4, 2, 40)
                for _,v in pairs(arr) do
                    local bar = Create("Frame", {
                        Parent = GraphArea,
                        BackgroundColor3=theme.Accent,
                        Size=UDim2.new(0, w, 0, 0),
                        ZIndex=6
                    })
                    Create("UICorner", { Parent = bar, CornerRadius=UDim.new(0,2) })
                    Tween(bar, {Size=UDim2.new(0, w, v/max, 0)}, 0.5, Enum.EasingStyle.Exponential)
                end
            end
            
            draw(dataArray or {10, 20, 50, 30, 80, 40, 90, 60})
            
            return {
                Update = function(self, arr)
                    draw(arr)
                end
            }
        end
        TabObj.AddGraph = TabObj.AddChart
        TabObj.AddBarGraph = TabObj.AddChart
        function TabObj:AddLineGraph(title, dataArray) return TabObj:AddChart(title .. " (Line Render Mock)", dataArray) end
        TabObj.AddPieChart = TabObj.AddChart

