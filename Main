        TabObj.AddObjectViewer = TabObj.AddExplorer

        function TabObj:AddTreeView(treeData)
            local F = TabObj:AddFolder("Tree View")
            local function recurse(node, parent)
                for k, v in pairs(node) do
                    if type(v) == "table" then
                        local sub = Create("Frame", { Parent = parent, BackgroundTransparency=1, Size=UDim2.new(1,0,0,20), AutomaticSize=Enum.AutomaticSize.Y })
                        local btn = Create("TextButton", { Parent = sub, BackgroundTransparency=1, Size=UDim2.new(1,0,0,20), Text="", AutoButtonColor=false })
                        local lbl = Create("TextLabel", { Parent = btn, BackgroundTransparency=1, Size=UDim2.new(1,0,1,0), Font=Enum.Font.GothamMedium, Text="+ " .. k, TextColor3=theme.Accent, TextSize=13, TextXAlignment=Enum.TextXAlignment.Left })
                        local cont = Create("Frame", { Parent = sub, BackgroundTransparency=1, Size=UDim2.new(1,0,0,0), Position=UDim2.new(0,10,0,20), AutomaticSize=Enum.AutomaticSize.Y, Visible=false })
                        Create("UIListLayout", { Parent = cont, Padding=UDim.new(0,2) })
                        local open = false
                        btn.MouseButton1Click:Connect(function() open = not open lbl.Text = (open and "- " or "+ ") .. k cont.Visible = open end)
                        recurse(v, cont)
                    else
                        Create("TextLabel", { Parent = parent, BackgroundTransparency=1, Size=UDim2.new(1,0,0,20), Font=Enum.Font.Gotham, Text=k .. " = " .. tostring(v), TextColor3=theme.Text, TextSize=13, TextXAlignment=Enum.TextXAlignment.Left })
                    end
                end
            end
            recurse(treeData, F.Container)
        end

        function TabObj:AddRichText(text)
