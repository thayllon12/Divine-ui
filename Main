                TextWrapped=true,
                ZIndex=4
            })
        end

        function TabObj:AddMarkdown(md)
            local rt = md:gsub("%*%*(.-)%*%*", "<b>%1</b>")
            rt = rt:gsub("%*(.-)%*", "<i>%1</i>")
            rt = rt:gsub("_(.-)_", "<i>%1</i>")
            rt = rt:gsub("~(.-)~", "<s>%1</s>")
            TabObj:AddRichText(rt)
        end

