            Create("TextLabel", { Parent = Frame, BackgroundTransparency = 1, Size = UDim2.new(1,-10,1,-10), Position = UDim2.new(0,5,0,5), Font = Enum.Font.Code, Text = code, TextColor3 = theme.Text, TextSize = 12, TextXAlignment = Enum.TextXAlignment.Left, TextYAlignment = Enum.TextYAlignment.Top, TextWrapped = true })
        end

        function TabObj:AddSyntaxHighlighter(code)
            local Frame = Create("Frame", { Parent = TabContainer, BackgroundColor3 = Color3.fromRGB(20,20,20), Size = UDim2.new(1,0,0,150) }, { Create("UICorner", { CornerRadius=UDim.new(0,6) }), Create("UIStroke", { Color=theme.StrokeColor, Thickness=1 }) })
            local format = code:gsub("local", "<font color='rgb(86,156,214)'>local</font>"):gsub("function", "<font color='rgb(86,156,214)'>function</font>")
            Create("TextLabel", { Parent = Frame, BackgroundTransparency = 1, Size = UDim2.new(1,-10,1,-10), Position = UDim2.new(0,5,0,5), Font = Enum.Font.Code, Text = format, RichText = true, TextColor3 = theme.Text, TextSize = 12, TextXAlignment = Enum.TextXAlignment.Left, TextYAlignment = Enum.TextYAlignment.Top, TextWrapped = true })
        end

